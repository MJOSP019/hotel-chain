@code {
    List<CityDto> cities = new();
    string? error;

    int selectedCityId = 0;
    DateTime checkIn = DateTime.Today.AddDays(1);
    DateTime checkOut = DateTime.Today.AddDays(2);
    int guests = 2;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            cities = await Http.GetFromJsonAsync<List<CityDto>>("/api/public/cities") ?? new();
        }
        catch
        {
            error = "No se pudo cargar ciudades. ¿La API está corriendo?";
        }
    }

    void GoSearch()
    {
        if (selectedCityId == 0)
        {
            error = "Selecciona una ciudad";
            return;
        }

        if (checkOut <= checkIn)
        {
            error = "Check-out debe ser después de Check-in";
            return;
        }

        Nav.NavigateTo($"/search?cityId={selectedCityId}&checkIn={checkIn:yyyy-MM-dd}&checkOut={checkOut:yyyy-MM-dd}&guests={guests}");
    }

    class CityDto
    {
        public int id { get; set; }
        public string name { get; set; } = "";
        public string countryCode { get; set; } = "";
    }
}
