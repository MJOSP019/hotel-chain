@page "/my-reservations"
@using System.Net.Http.Headers
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>Mis reservaciones</PageTitle>

<div class="my-stays-page">
    <section class="my-stays-hero">
        <div class="my-stays-hero__media"></div>
        <div class="my-stays-hero__overlay"></div>
        <div class="my-stays-hero__content">
            <div class="my-stays-badge">Área de huésped</div>
            <h1>Mis viajes y reservaciones</h1>
            <p>
                Consulta tus reservaciones activas y pasadas, revisa el detalle financiero de cada estancia,
                abre tu PDF y gestiona cambios o cancelaciones cuando las reglas del sistema lo permitan.
            </p>
            <div class="my-stays-hero__actions">
                <a class="btn my-stays-btn-primary" href="/search">Buscar hoteles</a>
                <a class="btn my-stays-btn-secondary" href="/checkout">Gestionar por código</a>
            </div>
        </div>
    </section>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger my-stays-alert">@errorMessage</div>
    }
    else if (reservations == null)
    {
        <section class="my-stays-state">
            <div class="my-stays-state__card">
                <h4>Cargando reservaciones...</h4>
                <p>Estamos obteniendo tu historial desde el backend.</p>
            </div>
        </section>
    }
    else if (!reservations.Any())
    {
        <section class="my-stays-state">
            <div class="my-stays-state__card my-stays-state__card--empty">
                <div class="my-stays-badge my-stays-badge--light">Sin registros</div>
                <h4>Todavía no tienes reservaciones</h4>
                <p>Cuando completes una reserva en la cadena, aparecerá aquí para que puedas revisarla y gestionarla.</p>
                <a class="btn my-stays-btn-primary" href="/search">Ir a buscar habitaciones</a>
            </div>
        </section>
    }
    else
    {
        <section class="my-stays-summary">
            <div class="my-stays-summary__header">
                <div>
                    <div class="my-stays-badge my-stays-badge--light">Panel de reservas</div>
                    <h3>Tus reservaciones</h3>
                    <p>Historial completo de compras, estancias y estados operativos.</p>
                </div>
            </div>

            <div class="my-stays-summary__grid">
                <article class="my-stays-summary-card">
                    <span class="my-stays-summary-card__label">Total</span>
                    <strong class="my-stays-summary-card__value">@reservations.Count</strong>
                </article>
                <article class="my-stays-summary-card">
                    <span class="my-stays-summary-card__label">Próximas</span>
                    <strong class="my-stays-summary-card__value">@reservations.Count(r => GetReservationTypeText(r) == "Próxima")</strong>
                </article>
                <article class="my-stays-summary-card">
                    <span class="my-stays-summary-card__label">Hospedándose</span>
                    <strong class="my-stays-summary-card__value">@reservations.Count(r => r.Status == "CHECKED_IN")</strong>
                </article>
                <article class="my-stays-summary-card">
                    <span class="my-stays-summary-card__label">Finalizadas</span>
                    <strong class="my-stays-summary-card__value">@reservations.Count(r => r.Status == "CHECKED_OUT")</strong>
                </article>
            </div>
        </section>

        <section class="my-stays-list">
            <div class="my-stays-list__grid">
                @foreach (var r in reservations.OrderByDescending(x => x.CreatedAt))
                {
                    <article class="stay-card">
                        <div class="stay-card__header">
                            <div>
                                <div class="stay-card__eyebrow">Código de reservación</div>
                                <h4>@r.Code</h4>
                                <div class="stay-card__hotel">@r.Hotel</div>
                            </div>

                            <div class="stay-card__badges">
                                <span class="@GetReservationTypeBadgeClass(r)">@GetReservationTypeText(r)</span>
                                <span class="@GetStatusBadgeClass(r.Status)">@r.Status</span>
                            </div>
                        </div>

                        <div class="stay-card__tripbar">
                            <div class="stay-card__tripitem">
                                <span>Check-in</span>
                                <strong>@r.CheckIn.ToString("dd/MM/yyyy")</strong>
                            </div>
                            <div class="stay-card__tripitem">
                                <span>Check-out</span>
                                <strong>@r.CheckOut.ToString("dd/MM/yyyy")</strong>
                            </div>
                            <div class="stay-card__tripitem">
                                <span>Noches</span>
                                <strong>@r.Nights</strong>
                            </div>
                            <div class="stay-card__tripitem">
                                <span>Huéspedes</span>
                                <strong>@r.Guests</strong>
                            </div>
                        </div>

                        <div class="stay-card__body">
                            <div class="stay-card__info">
                                <div class="stay-feature">
                                    <span class="stay-feature__label">Estado de pago</span>
                                    <strong>@GetPaymentText(r)</strong>
                                </div>

                                @if (r.IsPaid && !string.IsNullOrWhiteSpace(r.CardLast4))
                                {
                                    <div class="stay-feature">
                                        <span class="stay-feature__label">Última tarjeta</span>
                                        <strong>**** @r.CardLast4</strong>
                                    </div>
                                }

                                <div class="stay-feature stay-feature--wide">
                                    <span class="stay-feature__label">Creada</span>
                                    <strong>@r.CreatedAt.ToString("dd/MM/yyyy HH:mm")</strong>
                                </div>
                            </div>

                            <aside class="stay-card__financials">
                                <div class="stay-card__financials-title">Resumen financiero</div>
                                <div class="stay-financial">
                                    <span>Base</span>
                                    <strong>Q @r.BaseAmount.ToString("0.00")</strong>
                                </div>
                                <div class="stay-financial">
                                    <span>Cargos</span>
                                    <strong>Q @r.ChargesTotal.ToString("0.00")</strong>
                                </div>
                                <div class="stay-financial stay-financial--total">
                                    <span>Total final</span>
                                    <strong>Q @r.GrandTotal.ToString("0.00")</strong>
                                </div>
                            </aside>
                        </div>

                        @if (ShowTimingWarning(r))
                        {
                            <div class="my-stays-warning">
                                Esta reservación ya no cumple la regla de más de 24 horas antes del check-in para cambiar fecha o cancelar.
                            </div>
                        }

                        <div class="stay-card__actions">
                            <a class="btn my-stays-btn-secondary btn-sm" href="/checkout?code=@r.Code">Ver reservación</a>
                            <button class="btn my-stays-btn-outline btn-sm" @onclick="() => GoToHotel(r.HotelId)">Ver hotel</button>
                            <button class="btn my-stays-btn-outline btn-sm" @onclick="() => OpenPdf(r.Code)">Ver PDF</button>

                            @if (CanShowChangeDates(r.Status))
                            {
                                <button class="btn my-stays-btn-info btn-sm"
                                        @onclick="() => OpenChangeDatesModal(r)"
                                        disabled="@(!CanExecuteTimeRestrictedAction(r))"
                                        title="@GetTimeRestrictedActionTitle(r)">
                                    Cambiar fecha
                                </button>
                            }

                            @if (CanShowCancel(r.Status))
                            {
                                <button class="btn my-stays-btn-danger btn-sm"
                                        @onclick="() => OpenCancelModal(r)"
                                        disabled="@(!CanExecuteTimeRestrictedAction(r))"
                                        title="@GetTimeRestrictedActionTitle(r)">
                                    Cancelar
                                </button>
                            }
                        </div>
                    </article>
                }
            </div>
        </section>
    }
</div>

@if (showChangeDatesModal && selectedReservation is not null)
{
    <div class="my-stays-modal-backdrop">
        <div class="my-stays-modal-card">
            <div class="my-stays-modal-card__header">
                <div>
                    <div class="my-stays-badge my-stays-badge--light">Gestión</div>
                    <h4>Cambiar fechas de reservación</h4>
                </div>
                <button type="button" class="my-stays-modal-close" @onclick="CloseChangeDatesModal">×</button>
            </div>

            <div class="my-stays-modal-card__body">
                <p>
                    Estás modificando la reservación <strong>@selectedReservation.Code</strong>.
                </p>

                <div class="my-stays-form-grid">
                    <div>
                        <label class="my-stays-label">Nuevo check-in</label>
                        <input type="date" class="form-control my-stays-input" @bind="changeCheckIn" @bind:format="yyyy-MM-dd" />
                    </div>
                    <div>
                        <label class="my-stays-label">Nuevo check-out</label>
                        <input type="date" class="form-control my-stays-input" @bind="changeCheckOut" @bind:format="yyyy-MM-dd" />
                    </div>
                </div>

                <div class="mt-3">
                    <label class="my-stays-label">Razón</label>
                    <textarea class="form-control my-stays-input" rows="4" @bind="changeReason"></textarea>
                </div>

                <div class="my-stays-help-text">
                    La disponibilidad y las reglas de cambio se validan en el backend al confirmar.
                </div>

                @if (!string.IsNullOrWhiteSpace(changeError))
                {
                    <div class="alert alert-danger my-stays-alert mb-0 mt-3">@changeError</div>
                }
            </div>

            <div class="my-stays-modal-card__footer">
                <button class="btn my-stays-btn-secondary" @onclick="CloseChangeDatesModal">Cerrar</button>
                <button class="btn my-stays-btn-info" @onclick="ConfirmChangeDates">Confirmar cambio</button>
            </div>
        </div>
    </div>
}

@if (showCancelModal && selectedReservation is not null)
{
    <div class="my-stays-modal-backdrop">
        <div class="my-stays-modal-card">
            <div class="my-stays-modal-card__header">
                <div>
                    <div class="my-stays-badge my-stays-badge--light">Acción</div>
                    <h4>Cancelar reservación</h4>
                </div>
                <button type="button" class="my-stays-modal-close" @onclick="CloseCancelModal">×</button>
            </div>

            <div class="my-stays-modal-card__body">
                <p>
                    ¿Seguro que deseas cancelar la reservación <strong>@selectedReservation.Code</strong>?
                </p>

                <div class="mb-3">
                    <label class="my-stays-label">Razón</label>
                    <textarea class="form-control my-stays-input" rows="4" @bind="cancelReason"></textarea>
                </div>

                @if (!string.IsNullOrWhiteSpace(cancelError))
                {
                    <div class="alert alert-danger my-stays-alert mb-0">@cancelError</div>
                }
            </div>

            <div class="my-stays-modal-card__footer">
                <button class="btn my-stays-btn-secondary" @onclick="CloseCancelModal">Cerrar</button>
                <button class="btn my-stays-btn-danger" @onclick="ConfirmCancel">Confirmar cancelación</button>
            </div>
        </div>
    </div>
}

<style>
    .my-stays-page {
        padding: 1.4rem 0 2.25rem;
        color: #0f172a;
    }

    .my-stays-hero {
        position: relative;
        overflow: hidden;
        border-radius: 28px;
        min-height: 320px;
        margin-bottom: 1.5rem;
        box-shadow: 0 22px 56px rgba(15, 23, 42, 0.16);
        background: #0f172a;
    }

    .my-stays-hero__media {
        position: absolute;
        inset: 0;
        background:
            linear-gradient(90deg, rgba(15, 23, 42, 0.88) 0%, rgba(15, 23, 42, 0.56) 38%, rgba(15, 23, 42, 0.24) 100%),
            url('https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&fit=crop&w=1600&q=80') center/cover no-repeat;
        transform: scale(1.02);
    }

    .my-stays-hero__overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0));
    }

    .my-stays-hero__content {
        position: relative;
        z-index: 1;
        padding: 2rem;
        max-width: 760px;
        color: #fff;
    }

    .my-stays-hero__content h1 {
        margin: 0 0 0.8rem;
        font-size: clamp(2.15rem, 4vw, 3.55rem);
        font-weight: 800;
        line-height: 1.02;
        letter-spacing: -0.04em;
    }

    .my-stays-hero__content p {
        margin: 0;
        max-width: 680px;
        color: rgba(255,255,255,0.84);
        line-height: 1.7;
    }

    .my-stays-hero__actions {
        margin-top: 1.4rem;
        display: flex;
        gap: 0.8rem;
        flex-wrap: wrap;
    }

    .my-stays-badge {
        display: inline-flex;
        align-items: center;
        padding: 0.38rem 0.78rem;
        border-radius: 999px;
        background: rgba(255,255,255,0.14);
        color: #dbeafe;
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        margin-bottom: 1rem;
    }

    .my-stays-badge--light {
        background: #edf4ff;
        color: #193b73;
    }

    .my-stays-alert {
        border-radius: 16px;
    }

    .my-stays-state__card,
    .my-stays-modal-card,
    .my-stays-summary,
    .stay-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 24px;
        box-shadow: 0 14px 35px rgba(15, 23, 42, 0.08);
    }

    .my-stays-state__card {
        padding: 2rem;
        text-align: center;
    }

    .my-stays-state__card h4,
    .my-stays-summary__header h3 {
        margin-bottom: 0.4rem;
        font-weight: 800;
    }

    .my-stays-state__card p,
    .my-stays-summary__header p {
        color: #64748b;
    }

    .my-stays-summary {
        padding: 1.2rem;
        margin-bottom: 1.15rem;
    }

    .my-stays-summary__grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 0.9rem;
        margin-top: 1rem;
    }

    .my-stays-summary-card {
        border-radius: 20px;
        border: 1px solid #e2e8f0;
        background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
        padding: 1rem 1.05rem;
    }

    .my-stays-summary-card__label {
        display: block;
        color: #64748b;
        font-size: 0.79rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-weight: 700;
        margin-bottom: 0.35rem;
    }

    .my-stays-summary-card__value {
        font-size: 2rem;
        font-weight: 800;
        color: #0f172a;
    }

    .my-stays-list__grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
    }

    .stay-card {
        padding: 1.2rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .stay-card__header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
    }

    .stay-card__eyebrow {
        font-size: 0.76rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #64748b;
        margin-bottom: 0.2rem;
        font-weight: 700;
    }

    .stay-card__header h4 {
        margin: 0;
        font-size: 1.2rem;
        font-weight: 800;
        color: #0f172a;
    }

    .stay-card__hotel {
        margin-top: 0.35rem;
        color: #1e293b;
        font-weight: 700;
    }

    .stay-card__badges {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .stay-card__tripbar {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 0.8rem;
        padding: 0.85rem;
        border: 1px solid #e2e8f0;
        border-radius: 20px;
        background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
