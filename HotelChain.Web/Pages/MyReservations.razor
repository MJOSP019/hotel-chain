    .my-stays-warning {
        border-radius: 18px;
        background: #fff7ed;
        color: #9a3412;
        border: 1px solid #fed7aa;
        padding: 0.9rem 1rem;
        font-size: 0.95rem;
    }

    .stay-card__actions {
        display: flex;
        gap: 0.65rem;
        flex-wrap: wrap;
        margin-top: auto;
    }

    .status-badge,
    .reservation-type-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.38rem 0.75rem;
        border-radius: 999px;
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.02em;
    }

    .status-badge--pending { background: #fef3c7; color: #92400e; }
    .status-badge--confirmed { background: #dcfce7; color: #166534; }
    .status-badge--cancelled { background: #fee2e2; color: #991b1b; }
    .status-badge--default { background: #e2e8f0; color: #334155; }

    .reservation-type-badge--upcoming { background: #dbeafe; color: #1d4ed8; }
    .reservation-type-badge--past { background: #ede9fe; color: #6d28d9; }
    .reservation-type-badge--cancelled { background: #f1f5f9; color: #475569; }
    .reservation-type-badge--active { background: #dcfce7; color: #166534; }

    .my-stays-btn-primary,
    .my-stays-btn-secondary,
    .my-stays-btn-outline,
    .my-stays-btn-danger,
    .my-stays-btn-info {
        border-radius: 999px;
        font-weight: 700;
    }

    .my-stays-btn-primary {
        background: #fff;
        color: #0f172a;
        border: none;
        box-shadow: 0 10px 24px rgba(15, 23, 42, 0.16);
    }

    .my-stays-btn-secondary {
        background: #fff;
        color: #0f172a;
        border: 1px solid rgba(203, 213, 225, 0.65);
    }

    .my-stays-btn-outline {
        background: transparent;
        color: #1d4ed8;
        border: 1px solid #93c5fd;
    }

    .my-stays-btn-danger {
        background: #fff1f2;
        color: #be123c;
        border: 1px solid #fecdd3;
    }

    .my-stays-btn-info {
        background: #eff6ff;
        color: #1d4ed8;
        border: 1px solid #bfdbfe;
    }

    .my-stays-modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
        z-index: 1050;
    }

    .my-stays-modal-card {
        width: min(680px, 100%);
        overflow: hidden;
    }

    .my-stays-modal-card__header,
    .my-stays-modal-card__body,
    .my-stays-modal-card__footer {
        padding: 1.2rem 1.3rem;
    }

    .my-stays-modal-card__header {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: flex-start;
        border-bottom: 1px solid #e2e8f0;
    }

    .my-stays-modal-card__header h4 {
        margin: 0;
        font-weight: 800;
    }

    .my-stays-modal-card__body {
        color: #334155;
    }

    .my-stays-modal-card__footer {
        display: flex;
        justify-content: flex-end;
        gap: 0.75rem;
        border-top: 1px solid #e2e8f0;
    }

    .my-stays-modal-close {
        border: none;
        background: transparent;
        font-size: 1.5rem;
        line-height: 1;
        color: #64748b;
    }

    .my-stays-form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .my-stays-label {
        display: block;
        margin-bottom: 0.45rem;
        font-size: 0.92rem;
        font-weight: 700;
        color: #334155;
    }

    .my-stays-input {
        min-height: 48px;
        border-radius: 14px;
        border: 1px solid #cbd5e1;
        background: #f8fafc;
        color: #0f172a;
    }

    .my-stays-help-text {
        margin-top: 0.75rem;
        color: #64748b;
        font-size: 0.95rem;
    }

    @@media (max-width: 991.98px) {
        .stay-card__tripbar,
        .stay-card__body,
        .stay-card__info,
        .my-stays-form-grid {
            grid-template-columns: 1fr;
        }

        .stay-card__badges {
            justify-content: flex-start;
        }
    }

    @@media (max-width: 767.98px) {
        .my-stays-hero__content {
            padding: 1.4rem;
        }

        .my-stays-modal-card__footer,
        .stay-card__actions {
            flex-direction: column;
        }
    }
</style>

@code {
    private List<ReservationHistoryDto>? reservations;
    private string? errorMessage;
    private ReservationHistoryDto? selectedReservation;

    private bool showCancelModal = false;
    private string cancelReason = "";
    private string? cancelError;

    private bool showChangeDatesModal = false;
    private DateTime? changeCheckIn;
    private DateTime? changeCheckOut;
    private string changeReason = "";
    private string? changeError;

    protected override async Task OnInitializedAsync()
    {
        await LoadReservations();
    }

    public class ReservationHistoryDto
    {
        public int HotelId { get; set; }
        public string Code { get; set; } = "";
        public string Hotel { get; set; } = "";
        public DateTime CheckIn { get; set; }
        public DateTime CheckOut { get; set; }
        public int Nights { get; set; }
        public int Guests { get; set; }
        public decimal BaseAmount { get; set; }
        public decimal ChargesTotal { get; set; }
        public decimal GrandTotal { get; set; }
        public decimal TotalAmount { get; set; }
        public string Status { get; set; } = "";
        public bool IsPaid { get; set; }
        public string? PaymentStatus { get; set; }
        public string? CardLast4 { get; set; }
        public DateTime CreatedAt { get; set; }
    }

    private void OpenCancelModal(ReservationHistoryDto reservation)
    {
        if (!CanExecuteTimeRestrictedAction(reservation))
            return;

        CloseChangeDatesModal();

        selectedReservation = reservation;
        cancelReason = "";
        cancelError = null;
        showCancelModal = true;
    }

    private void CloseCancelModal()
    {
        showCancelModal = false;
        selectedReservation = null;
        cancelReason = "";
        cancelError = null;
    }

    private void OpenChangeDatesModal(ReservationHistoryDto reservation)
    {
        if (!CanExecuteTimeRestrictedAction(reservation))
            return;

        CloseCancelModal();

        selectedReservation = reservation;
        changeCheckIn = reservation.CheckIn.Date;
        changeCheckOut = reservation.CheckOut.Date;
        changeReason = "";
        changeError = null;
        showChangeDatesModal = true;
    }

    private void CloseChangeDatesModal()
    {
        showChangeDatesModal = false;
        selectedReservation = null;
        changeCheckIn = null;
        changeCheckOut = null;
        changeReason = "";
        changeError = null;
    }

    private async Task ConfirmCancel()
    {
        if (selectedReservation is null)
            return;

        try
        {
            var token = await JS.InvokeAsync<string>("auth.getToken");

            if (string.IsNullOrWhiteSpace(token))
            {
                cancelError = "No se encontró el token. Inicia sesión nuevamente.";
                return;
            }

            Http.DefaultRequestHeaders.Authorization =
                new AuthenticationHeaderValue("Bearer", token);

            var body = new
            {
                reason = cancelReason
            };

            var response = await Http.PostAsJsonAsync(
                $"api/public/reservations/{selectedReservation.Code}/cancel",
                body);

            if (response.IsSuccessStatusCode)
            {
                showCancelModal = false;
                selectedReservation = null;
                cancelReason = "";
                cancelError = null;

                await LoadReservations();
            }
            else
            {
                var errorText = await response.Content.ReadAsStringAsync();
                cancelError = $"No se pudo cancelar: {errorText}";
            }
        }
        catch (Exception ex)
        {
            cancelError = $"Error al cancelar: {ex.Message}";
        }
    }

    private async Task ConfirmChangeDates()
    {
        if (selectedReservation is null)
            return;

        if (!changeCheckIn.HasValue)
        {
            changeError = "Ingresa una fecha válida de check-in.";
            return;
        }

        if (!changeCheckOut.HasValue)
        {
            changeError = "Ingresa una fecha válida de check-out.";
            return;
        }

        var newCheckIn = changeCheckIn.Value.Date;
        var newCheckOut = changeCheckOut.Value.Date;

        if (newCheckOut <= newCheckIn)
        {
            changeError = "El check-out debe ser mayor al check-in.";
            return;
        }

        try
        {
            var token = await JS.InvokeAsync<string>("auth.getToken");

            if (string.IsNullOrWhiteSpace(token))
            {
                changeError = "No se encontró el token. Inicia sesión nuevamente.";
                return;
            }

            Http.DefaultRequestHeaders.Authorization =
                new AuthenticationHeaderValue("Bearer", token);

            var body = new
            {
                checkIn = newCheckIn,
                checkOut = newCheckOut,
                reason = changeReason
            };

            var response = await Http.PostAsJsonAsync(
                $"api/public/reservations/{selectedReservation.Code}/change-dates",
                body);

            if (response.IsSuccessStatusCode)
            {
                showChangeDatesModal = false;
                selectedReservation = null;
                changeCheckIn = null;
                changeCheckOut = null;
                changeReason = "";
                changeError = null;

                await LoadReservations();
            }
            else
            {
                var errorText = await response.Content.ReadAsStringAsync();
                changeError = $"No se pudo cambiar la fecha: {errorText}";
            }
        }
        catch (Exception ex)
        {
            changeError = $"Error al cambiar la fecha: {ex.Message}";
        }
    }

    private async Task LoadReservations()
    {
        try
        {
            var token = await JS.InvokeAsync<string>("auth.getToken");

            if (string.IsNullOrWhiteSpace(token))
            {
                errorMessage = "No se encontró el token. Inicia sesión nuevamente.";
                reservations = new();
                return;
            }

            Http.DefaultRequestHeaders.Authorization =
                new AuthenticationHeaderValue("Bearer", token);

            reservations = await Http.GetFromJsonAsync<List<ReservationHistoryDto>>("api/user/reservations")
                           ?? new List<ReservationHistoryDto>();

            errorMessage = null;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al cargar reservaciones: {ex.Message}";
            reservations = new();
        }
    }

    private async Task OpenPdf(string reservationCode)
    {
        try
        {
            var token = await JS.InvokeAsync<string>("auth.getToken");

            if (string.IsNullOrWhiteSpace(token))
            {
                errorMessage = "No se encontró el token. Inicia sesión nuevamente.";
                return;
            }

            Http.DefaultRequestHeaders.Authorization =
                new AuthenticationHeaderValue("Bearer", token);

            var response = await Http.GetAsync($"api/public/reservations/{reservationCode}/pdf");

            if (!response.IsSuccessStatusCode)
            {
                var errorText = await response.Content.ReadAsStringAsync();
                errorMessage = $"No se pudo abrir el PDF: {errorText}";
                return;
            }

            var bytes = await response.Content.ReadAsByteArrayAsync();
            var base64 = Convert.ToBase64String(bytes);

            await JS.InvokeVoidAsync("openPdfBase64", base64);
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al abrir PDF: {ex.Message}";
        }
    }

    private void GoToHotel(int hotelId)
    {
        Navigation.NavigateTo($"/hotels/{hotelId}");
    }

    private static bool CanShowCancel(string status)
    {
        return status == "PENDING" || status == "CONFIRMED";
    }

    private static bool CanShowChangeDates(string status)
    {
        return status == "PENDING" || status == "CONFIRMED";
    }

    private static bool CanExecuteTimeRestrictedAction(ReservationHistoryDto reservation)
    {
        return DateTime.Now <= reservation.CheckIn.AddHours(-24);
    }

    private static bool ShowTimingWarning(ReservationHistoryDto reservation)
    {
        return (reservation.Status == "PENDING" || reservation.Status == "CONFIRMED")
               && !CanExecuteTimeRestrictedAction(reservation);
    }

    private static string GetTimeRestrictedActionTitle(ReservationHistoryDto reservation)
    {
        if (CanExecuteTimeRestrictedAction(reservation))
            return "";

        return "Esta acción solo está disponible si faltan más de 24 horas para el check-in.";
    }

    private static string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "PENDING" => "status-badge status-badge--pending",
            "CONFIRMED" => "status-badge status-badge--confirmed",
            "CHECKED_IN" => "status-badge status-badge--confirmed",
            "CHECKED_OUT" => "status-badge status-badge--default",
            "NO_SHOW" => "status-badge status-badge--cancelled",
            "CANCELED" => "status-badge status-badge--cancelled",
            "CANCELLED" => "status-badge status-badge--cancelled",
            "EXPIRED" => "status-badge status-badge--cancelled",
            _ => "status-badge status-badge--default"
        };
    }

    private static string GetPaymentText(ReservationHistoryDto reservation)
    {
        if (!reservation.IsPaid)
            return "Pendiente";

        if (!string.IsNullOrWhiteSpace(reservation.PaymentStatus))
            return reservation.PaymentStatus!;

        return "Pagada";
    }

    private static string GetReservationTypeText(ReservationHistoryDto reservation)
    {
        if (reservation.Status == "CANCELED" || reservation.Status == "CANCELLED" || reservation.Status == "EXPIRED")
            return "Cancelada";

        if (reservation.Status == "NO_SHOW")
            return "No se presentó";

        if (reservation.Status == "CHECKED_OUT")
            return "Finalizada";

        if (reservation.Status == "CHECKED_IN")
            return "Hospedándose";

        var now = DateTime.Now.Date;

        if (reservation.CheckIn.Date > now)
            return "Próxima";

        if (reservation.CheckOut.Date <= now)
            return "Pasada";

        return "En curso";
    }

    private static string GetReservationTypeBadgeClass(ReservationHistoryDto reservation)
    {
        if (reservation.Status == "CANCELED" || reservation.Status == "CANCELLED" || reservation.Status == "NO_SHOW" || reservation.Status == "EXPIRED")
            return "reservation-type-badge reservation-type-badge--cancelled";

        if (reservation.Status == "CHECKED_OUT")
            return "reservation-type-badge reservation-type-badge--past";

        if (reservation.Status == "CHECKED_IN")
            return "reservation-type-badge reservation-type-badge--active";

        var now = DateTime.Now.Date;

        if (reservation.CheckIn.Date > now)
            return "reservation-type-badge reservation-type-badge--upcoming";

        if (reservation.CheckOut.Date <= now)
            return "reservation-type-badge reservation-type-badge--past";

        return "reservation-type-badge reservation-type-badge--active";
    }
}
