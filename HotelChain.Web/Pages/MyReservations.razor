        color: #64748b;
        font-weight: 700;
    }

    .stay-card__tripitem strong,
    .stay-feature strong,
    .stay-financial strong {
        color: #0f172a;
        font-size: 1rem;
    }

    .stay-card__body {
        display: grid;
        grid-template-columns: 1.2fr 0.9fr;
        gap: 1rem;
    }

    .stay-card__info {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.8rem;
    }

    .stay-feature {
        background: rgba(255,255,255,0.82);
        border: 1px solid #e2e8f0;
        border-radius: 18px;
        padding: 0.9rem;
    }

    .stay-feature--wide {
        grid-column: 1 / -1;
    }

    .stay-card__financials {
        border-radius: 20px;
        background: linear-gradient(180deg, #0f172a 0%, #162033 100%);
        color: #fff;
        padding: 1rem;
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.06);
    }

    .stay-card__financials-title {
        color: rgba(255,255,255,0.72);
        margin-bottom: 0.9rem;
    }

    .stay-financial {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.85rem 0;
        border-top: 1px solid rgba(255,255,255,0.1);
    }

    .stay-financial:first-of-type {
        border-top: none;
        padding-top: 0;
    }

    .stay-financial span,
    .stay-financial strong {
        color: #fff;
    }

    .stay-financial--total {
        margin-top: 0.25rem;
        padding-top: 1rem;
        border-top: 1px solid rgba(255,255,255,0.18);
    }

    .stay-financial--total strong {
        font-size: 1.2rem;
        font-weight: 800;
