@page "/room-types"

<PageTitle>Tipos de habitación</PageTitle>

<div class="info-page">
    <section class="info-hero info-hero--rooms">
        <div class="info-hero__content">
            <div class="info-badge">Portal informativo</div>
            <h1>Tipos de habitación</h1>
            <p>
                Elige entre habitaciones dobles, junior suites, suites y gran suites según el nivel de comodidad,
                amplitud y experiencia que buscas para tu estadía dentro de HotelChain Collection.
            </p>
        </div>

        <div class="room-hero-stack">
            <div class="room-hero-stack__card room-hero-stack__card--double"><span>Doble</span></div>
            <div class="room-hero-stack__card room-hero-stack__card--junior"><span>Junior suite</span></div>
            <div class="room-hero-stack__card room-hero-stack__card--suite"><span>Suite</span></div>
            <div class="room-hero-stack__card room-hero-stack__card--grand"><span>Gran suite</span></div>
        </div>
    </section>

    <section class="info-section">
        <div class="info-section__header">
            <div>
                <div class="info-badge info-badge--light">Opciones de hospedaje</div>
                <h3>Opciones de hospedaje para cada tipo de viaje</h3>
                <p>
                    Cada categoría ofrece una experiencia distinta. Revisa capacidad, configuración de cama, tamaño aproximado
                    y características generales antes de consultar disponibilidad.
                </p>
            </div>
        </div>

        <div class="room-catalogue">
            @foreach (var room in RoomCategories)
            {
                <article class="room-catalogue-card">
                    <div class="room-catalogue-card__intro">
                        <div>
                            <div class="room-catalogue-card__badge">@room.Badge</div>
                            <h4>@room.Title</h4>
                            <p>@room.Description</p>
                        </div>

                        <div class="room-catalogue-card__specs">
                            <div>
                                <span>Capacidad</span>
                                <strong>@room.Capacity</strong>
                            </div>
                            <div>
                                <span>Configuración de cama</span>
                                <strong>@room.Bed</strong>
                            </div>
                            <div>
                                <span>Área orientativa</span>
                                <strong>@room.Area</strong>
                            </div>
                            <div>
                                <span>Perfil</span>
                                <strong>@room.Profile</strong>
                            </div>
                        </div>
                    </div>

                    <div class="room-gallery-grid">
                        @foreach (var photo in room.Photos)
                        {
                            <div class="room-gallery-grid__item @photo.CssClass">
                                <div class="room-gallery-grid__overlay"></div>
                                <div class="room-gallery-grid__caption">
                                    <span>@photo.Tag</span>
                                    <strong>@photo.Title</strong>
                                </div>
                            </div>
                        }
                    </div>
                </article>
            }
        </div>
    </section>

    <section class="info-section">
        <div class="info-section__header">
            <div>
                <div class="info-badge info-badge--light">Comparación general</div>
                <h3>Diferencias principales entre categorías</h3>
                <p>
                    A medida que sube la categoría, también aumentan la amplitud, privacidad, configuración de descanso y nivel de experiencia.
                </p>
            </div>
        </div>

        <div class="comparison-grid">
            <article class="comparison-card"><span class="comparison-card__label">Doble</span><strong>Practicidad</strong></article>
            <article class="comparison-card"><span class="comparison-card__label">Junior suite</span><strong>Más amplitud</strong></article>
            <article class="comparison-card"><span class="comparison-card__label">Suite</span><strong>Mayor confort</strong></article>
            <article class="comparison-card"><span class="comparison-card__label">Gran suite</span><strong>Experiencia premium</strong></article>
        </div>
    </section>

    <section class="info-highlight">
        <div class="info-highlight__content">
            <div>
                <div class="info-badge info-badge--light">Importante</div>
                <h3>La disponibilidad final depende del hotel, fechas e inventario</h3>
                <p>
                    Las categorías muestran características generales. Para reservar, utiliza la búsqueda de disponibilidad; allí verás precios, fechas, capacidad y opciones realmente disponibles para tu estadía.
                </p>
            </div>
            <div class="info-highlight__box">
                <div class="info-highlight__label">Consulta disponibilidad real</div>
                <p>
                    Las fotografías son representativas de cada categoría. La asignación final puede variar según hotel, inventario, fechas seleccionadas y reglas comerciales activas.
                </p>
                <a class="info-cta" href="/search">Buscar habitaciones disponibles</a>
            </div>
        </div>
    </section>
</div>

@code {
    private List<RoomCategoryVm> RoomCategories { get; } =
    [
        new(
            "Estándar",
            "Habitación doble",
            "Una opción práctica y cómoda para viajes cortos, estancias de negocio o escapadas en pareja. Ofrece lo esencial para descansar con buena relación entre comodidad y precio.",
            "2 huéspedes",
            "1 cama doble o 2 camas",
            "22–28 m²",
            "Estancias prácticas",
            [
                new("Vista general", "Habitación", "room-double-1"),
                new("Zona de cama", "Descanso", "room-double-2"),
                new("Escritorio", "Trabajo", "room-double-3")
            ]),
        new(
            "Mayor amplitud",
            "Junior suite",
            "Una alternativa con mayor amplitud y mejor distribución, pensada para huéspedes que buscan más comodidad sin pasar a una categoría premium.",
            "2 a 3 huéspedes",
            "King o doble amplia",
            "30–38 m²",
            "Comodidad ampliada",
            [
                new("Vista completa", "Suite", "room-junior-1"),
                new("Área lounge", "Confort", "room-junior-2"),
                new("Detalle premium", "Diseño", "room-junior-3")
            ]),
        new(
            "Experiencia superior",
            "Suite",
            "Una categoría superior con espacios más amplios, mayor privacidad y zonas de descanso integradas. Ideal para estadías más largas o viajes especiales.",
            "2 a 4 huéspedes",
            "King size",
            "40–52 m²",
            "Espacio y confort",
            [
                new("Dormitorio principal", "Privacidad", "room-suite-1"),
                new("Sala integrada", "Amplitud", "room-suite-2"),
                new("Baño destacado", "Detalle", "room-suite-3")
            ]),
        new(
            "Categoría premium",
            "Gran suite",
            "La categoría más amplia y exclusiva, diseñada para huéspedes que buscan una experiencia premium, mayor distribución y un ambiente más privado.",
            "4 huéspedes o más",
            "King premium + apoyo",
            "55–80 m²",
            "Premium y amplitud",
            [
                new("Vista principal", "Premium", "room-grand-1"),
                new("Sala y estancia", "Experiencia", "room-grand-2"),
                new("Baño o detalle VIP", "Exclusivo", "room-grand-3")
            ])
    ];

    private sealed record RoomCategoryVm(
        string Badge,
        string Title,
        string Description,
        string Capacity,
        string Bed,
        string Area,
        string Profile,
        List<RoomPhotoVm> Photos);

    private sealed record RoomPhotoVm(string Title, string Tag, string CssClass);
}

<style>
    .info-page { color:#111827; }
    .info-hero {
        display:grid; grid-template-columns: 1.08fr .92fr; gap:1.2rem; align-items:stretch;
        min-height: 420px; border-radius:30px; overflow:hidden; margin-bottom:1.5rem;
        box-shadow:0 24px 60px rgba(15,23,42,.16);
        background: linear-gradient(135deg, #d7c9b0 0%, #ebe4db 35%, #b9c7d4 62%, #7d94a8 100%);
        padding:1.25rem;
    }
    .info-hero__content { padding:1.2rem; color:#fff; display:flex; flex-direction:column; justify-content:flex-end; }
    .info-hero__content h1 { font-size: clamp(2.2rem, 4vw, 3.6rem); line-height:1; margin:0 0 .8rem; font-weight:900; }
    .info-hero__content p { color: rgba(255,255,255,.92); max-width:680px; }
    .info-badge { display:inline-flex; width:max-content; align-items:center; padding:.38rem .78rem; border-radius:999px; background:rgba(255,255,255,.14); color:#fff; font-size:.78rem; font-weight:800; letter-spacing:.05em; text-transform:uppercase; }
    .info-badge--light { background:#fff; color:#475569; border:1px solid #e2e8f0; }
    .room-hero-stack { display:grid; grid-template-columns: 1fr 1fr; gap:.85rem; }
    .room-hero-stack__card, .room-gallery-grid__item {
        position:relative; border-radius:24px; overflow:hidden; min-height:150px;
        box-shadow: 0 18px 35px rgba(15,23,42,.12); border:1px solid rgba(255,255,255,.26);
    }
    .room-hero-stack__card span { position:absolute; left:1rem; bottom:1rem; z-index:2; color:#fff; font-weight:800; }
    .room-hero-stack__card::before, .room-gallery-grid__item::before {
        content:""; position:absolute; inset:0; background-size:cover; background-position:center;
    }
    .room-hero-stack__card::after, .room-gallery-grid__overlay {
        content:""; position:absolute; inset:0; background:linear-gradient(180deg, rgba(15,23,42,.04), rgba(15,23,42,.5));
    }
    .room-hero-stack__card--double::before, .room-double-1::before { background-image: url('https://res.cloudinary.com/ds7fyjtcc/image/upload/f_auto,q_auto,c_fill,g_auto,w_1200,h_800/v1777223027/DOUBLE_wnzkli.jpg'); }
    .room-hero-stack__card--junior::before, .room-junior-1::before { background-image: url('https://res.cloudinary.com/ds7fyjtcc/image/upload/f_auto,q_auto,c_fill,g_auto,w_1200,h_800/v1777223029/JUNIORSUITE_tijbm7.jpg'); }
    .room-hero-stack__card--suite::before, .room-suite-1::before { background-image: url('https://res.cloudinary.com/ds7fyjtcc/image/upload/f_auto,q_auto,c_fill,g_auto,w_1200,h_800/v1777223034/SUITE_clunx9.jpg'); }
    .room-hero-stack__card--grand::before, .room-grand-1::before { background-image: url('https://res.cloudinary.com/ds7fyjtcc/image/upload/f_auto,q_auto,c_fill,g_auto,w_1200,h_800/v1777223028/GRANSUITE_mt0tyt.jpg'); }
    .room-double-2::before { background-image: url('https://res.cloudinary.com/ds7fyjtcc/image/upload/f_auto,q_auto,c_fill,g_auto,w_1200,h_800/v1777223027/DOBLEZONADECAMA_hh1l73.jpg'); }
    .room-double-3::before { background-image: url('https://res.cloudinary.com/ds7fyjtcc/image/upload/f_auto,q_auto,c_fill,g_auto,w_1200,h_800/v1777223025/DOBLEESCRITORIO_tndyqd.jpg'); }
    .room-junior-2::before { background-image: url('https://res.cloudinary.com/ds7fyjtcc/image/upload/f_auto,q_auto,c_fill,g_auto,w_1200,h_800/v1777223032/JUNIORSUITELOUNGE_tbheng.jpg'); }
    .room-junior-3::before { background-image: url('https://res.cloudinary.com/ds7fyjtcc/image/upload/f_auto,q_auto,c_fill,g_auto,w_1200,h_800/v1777223032/JUNIORSUITEDETALLEPREMIUM_g2npab.jpg'); }
    .room-suite-2::before { background-image: url('https://res.cloudinary.com/ds7fyjtcc/image/upload/f_auto,q_auto,c_fill,g_auto,w_1200,h_800/v1777223034/SUITESALAINTEGRADA_flx6ef.jpg'); }
    .room-suite-3::before { background-image: url('https://res.cloudinary.com/ds7fyjtcc/image/upload/f_auto,q_auto,c_fill,g_auto,w_1200,h_800/v1777223033/SUITEBA%C3%91O_tpykpb.jpg'); }
    .room-grand-2::before { background-image: url('https://res.cloudinary.com/ds7fyjtcc/image/upload/f_auto,q_auto,c_fill,g_auto,w_1200,h_800/v1777223027/GRANDSUITESALAESTANCIA_ahjuvk.jpg'); }
    .room-grand-3::before { background-image: url('https://res.cloudinary.com/ds7fyjtcc/image/upload/f_auto,q_auto,c_fill,g_auto,w_1200,h_800/v1777223030/GRANSUITEBA%C3%91O_jweerv.jpg'); }

    .info-section, .info-highlight { margin-top:2rem; }
    .info-section__header h3 { margin:.4rem 0 .35rem; font-size: clamp(1.7rem, 2vw, 2.35rem); font-weight:900; }
    .info-section__header p { max-width: 920px; color:#475569; }
    .room-catalogue { display:grid; gap:1.25rem; margin-top:1rem; }
    .room-catalogue-card { border:1px solid #e5e7eb; border-radius:28px; background:#fff; padding:1.1rem; box-shadow:0 20px 45px rgba(15,23,42,.06); }
    .room-catalogue-card__intro { display:flex; justify-content:space-between; gap:1rem; margin-bottom:1rem; }
    .room-catalogue-card__badge { display:inline-flex; padding:.28rem .65rem; border-radius:999px; background:#111827; color:#fff; font-size:.73rem; font-weight:800; text-transform:uppercase; letter-spacing:.05em; }
    .room-catalogue-card h4 { margin:.55rem 0 .45rem; font-size:1.55rem; font-weight:900; }
    .room-catalogue-card p { margin:0; color:#475569; max-width: 760px; }
    .room-catalogue-card__specs { display:grid; grid-template-columns: 1fr 1fr; gap:.75rem; min-width:340px; }
    .room-catalogue-card__specs div { border:1px solid #e5e7eb; border-radius:18px; padding:.8rem .95rem; background:#f8fafc; }
    .room-catalogue-card__specs span { display:block; font-size:.72rem; text-transform:uppercase; letter-spacing:.05em; color:#64748b; font-weight:800; margin-bottom:.2rem; }
    .room-gallery-grid { display:grid; grid-template-columns: repeat(3, 1fr); gap:.85rem; }
    .room-gallery-grid__item { min-height: 220px; }
    .room-gallery-grid__caption { position:absolute; left:.9rem; right:.9rem; bottom:.85rem; z-index:2; color:#fff; }
    .room-gallery-grid__caption span { display:inline-flex; padding:.22rem .55rem; border-radius:999px; background:rgba(255,255,255,.16); backdrop-filter: blur(8px); font-size:.68rem; font-weight:800; text-transform:uppercase; letter-spacing:.05em; }
    .room-gallery-grid__caption strong { display:block; margin-top:.45rem; font-size:1rem; line-height:1.1; }
    .comparison-grid { display:grid; grid-template-columns: repeat(4, 1fr); gap:.9rem; margin-top:1rem; }
    .comparison-card { border:1px solid #e5e7eb; border-radius:22px; background:#fff; padding:1rem; box-shadow: 0 10px 24px rgba(15,23,42,.05); }
    .comparison-card__label { display:block; font-size:.72rem; text-transform:uppercase; letter-spacing:.05em; color:#64748b; font-weight:800; margin-bottom:.25rem; }
    .info-highlight__content { display:grid; grid-template-columns: 1.2fr .8fr; gap:1rem; border:1px solid #dbeafe; background: linear-gradient(180deg, #fff, #f8fbff); border-radius:26px; padding:1.15rem; }
    .info-highlight__content h3 { margin:.45rem 0; font-size:1.7rem; font-weight:900; }
    .info-highlight__box { border:1px solid #dbeafe; background:#fff; border-radius:20px; padding:1rem; }
    .info-highlight__label { display:inline-flex; padding:.25rem .58rem; border-radius:999px; background:#eff6ff; color:#1d4ed8; font-size:.72rem; font-weight:800; text-transform:uppercase; letter-spacing:.05em; margin-bottom:.45rem; }

    @@media (max-width: 1100px) {
        .info-hero { grid-template-columns:1fr; }
        .room-catalogue-card__intro, .info-highlight__content { display:grid; grid-template-columns:1fr; }
        .comparison-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @@media (max-width: 720px) {
        .room-hero-stack { grid-template-columns:1fr 1fr; }
        .room-gallery-grid, .comparison-grid, .room-catalogue-card__specs { grid-template-columns:1fr; min-width:0; }
    }
</style>
