@page "/login"
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>Login</PageTitle>

<div class="auth-page">
    <section class="auth-hero auth-hero--login">
        <div class="auth-hero__overlay"></div>

        <div class="auth-hero__content">
            <div class="auth-eyebrow">Acceso a huéspedes</div>
            <h1>Inicia sesión en HotelChain Collection</h1>
            <p>
                Accede al portal para gestionar tus reservaciones, completar el checkout,
                consultar tus viajes, descargar PDFs y publicar comentarios en hoteles.
            </p>
        </div>
    </section>

    <section class="auth-layout">
        <div class="auth-main-card">
            <div class="auth-main-card__header">
                <div class="auth-section-badge">Ingreso seguro</div>
                <h2>Bienvenido de nuevo</h2>
                <p>Ingresa tus credenciales para continuar dentro del portal.</p>
            </div>

            @if (!string.IsNullOrEmpty(error))
            {
                <div class="alert alert-danger auth-alert">@error</div>
            }

            <div class="auth-form-grid">
                <div class="auth-field auth-field--full">
                    <label class="auth-label">Email</label>
                    <input class="form-control auth-input" @bind="email" placeholder="correo@ejemplo.com" />
                </div>

                <div class="auth-field auth-field--full">
                    <label class="auth-label">Password</label>
                    <input type="password" class="form-control auth-input" @bind="password" placeholder="Tu contraseña" />
                </div>
            </div>

            <div class="auth-actions">
                <button class="btn auth-btn-primary" @onclick="DoLogin">
                    Iniciar sesión
                </button>

                <a class="btn auth-btn-secondary" href="/register">
                    Crear cuenta
                </a>
            </div>
        </div>

        <aside class="auth-side-panel">
            <div class="auth-side-panel__intro">
                <div class="auth-section-badge">Portal HotelChain</div>
                <h3>Tu cuenta te permite continuar toda la experiencia</h3>
                <p>
                    Una vez dentro del sistema podrás seguir con el flujo de reservación
                    y consultar la información de tus compras dentro del portal.
                </p>
            </div>

            <div class="auth-feature-list">
                <article class="auth-feature-card">
                    <div class="auth-feature-card__icon">⌂</div>
                    <div>
                        <h4>Reservar habitaciones</h4>
                        <p>Confirma disponibilidad y genera tu código de reservación.</p>
                    </div>
                </article>

                <article class="auth-feature-card">
                    <div class="auth-feature-card__icon">✓</div>
                    <div>
                        <h4>Gestionar checkout</h4>
                        <p>Completa el pago demo y revisa el estado actual de tu compra.</p>
                    </div>
                </article>

                <article class="auth-feature-card">
                    <div class="auth-feature-card__icon">★</div>
                    <div>
                        <h4>PDF y comentarios</h4>
                        <p>Abre tu confirmación y comparte tu experiencia en hoteles.</p>
                    </div>
                </article>
            </div>

            <div class="auth-side-panel__footer">
                <span class="auth-side-panel__footer-label">¿Aún no tienes cuenta?</span>
                <a href="/register" class="auth-inline-link">Regístrate aquí</a>
            </div>
        </aside>
    </section>
</div>

<style>
    .auth-page {
        color: #111827;
    }

    .auth-hero {
        position: relative;
        min-height: 320px;
        border-radius: 30px;
        overflow: hidden;
        margin-bottom: 1.5rem;
        box-shadow: 0 24px 60px rgba(15, 23, 42, 0.14);
        display: flex;
        align-items: flex-end;
    }

    .auth-hero--login {
        background:
            linear-gradient(180deg, rgba(17,24,39,0.12), rgba(17,24,39,0.40)),
            radial-gradient(circle at top right, rgba(255,255,255,0.14), transparent 24%),
            linear-gradient(135deg, #b9a68f 0%, #d7c8b8 28%, #aab9c9 58%, #6b8298 100%);
    }

    .auth-hero__overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, rgba(255,255,255,0.03), transparent 25%, rgba(17,24,39,0.10) 100%);
        pointer-events: none;
    }

    .auth-hero__content {
        position: relative;
        z-index: 1;
        max-width: 760px;
        padding: 2rem;
        color: #ffffff;
    }

    .auth-eyebrow,
    .auth-section-badge {
        display: inline-flex;
        align-items: center;
        padding: 0.38rem 0.78rem;
        border-radius: 999px;
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0.05em;
        text-transform: uppercase;
    }

    .auth-eyebrow {
        background: rgba(255,255,255,0.14);
        color: rgba(255,255,255,0.94);
        margin-bottom: 1rem;
        backdrop-filter: blur(8px);
    }

    .auth-section-badge {
        background: #f3f4f6;
        color: #111827;
        margin-bottom: 0.8rem;
    }

    .auth-hero__content h1 {
        margin: 0 0 0.8rem 0;
        font-size: clamp(2.1rem, 5vw, 3.6rem);
        line-height: 1.02;
        font-weight: 800;
        letter-spacing: -0.02em;
    }

    .auth-hero__content p {
        margin: 0;
        max-width: 700px;
        font-size: 1.02rem;
        line-height: 1.7;
        color: rgba(255,255,255,0.88);
    }

    .auth-layout {
        display: grid;
        grid-template-columns: minmax(340px, 1.05fr) minmax(280px, 0.95fr);
        gap: 1rem;
        align-items: stretch;
    }

    .auth-main-card,
    .auth-side-panel {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 24px;
        box-shadow: 0 14px 35px rgba(15, 23, 42, 0.07);
    }

    .auth-main-card {
        padding: 1.5rem;
    }

    .auth-side-panel {
        padding: 1.4rem;
        background: linear-gradient(180deg, #ffffff 0%, #f9fafb 100%);
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .auth-main-card__header h2,
    .auth-side-panel__intro h3 {
        margin: 0 0 0.3rem 0;
        color: #111827;
        font-weight: 800;
    }

    .auth-main-card__header p,
    .auth-side-panel__intro p {
        margin: 0;
        color: #6b7280;
        line-height: 1.6;
    }

    .auth-alert {
        border-radius: 16px;
        margin-bottom: 1rem;
    }

    .auth-form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .auth-field--full {
        grid-column: span 2;
    }

    .auth-label {
        display: block;
        margin-bottom: 0.45rem;
        font-size: 0.92rem;
        font-weight: 700;
        color: #374151;
    }

    .auth-input {
        min-height: 54px;
        border-radius: 16px;
        border: 1px solid #d1d5db;
        background: #ffffff;
        color: #111827;
    }

    .auth-input:focus {
        border-color: #111827;
        box-shadow: 0 0 0 0.15rem rgba(17, 24, 39, 0.10);
    }

    .auth-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-top: 1.25rem;
    }

    .auth-btn-primary {
        background: #111111;
        color: #ffffff;
        border: 1px solid #111111;
        border-radius: 999px;
        padding: 0.82rem 1.35rem;
        font-weight: 700;
        min-height: 50px;
        box-shadow: 0 12px 24px rgba(17, 17, 17, 0.16);
    }

    .auth-btn-primary:hover,
    .auth-btn-primary:focus {
        background: #000000;
        color: #ffffff;
        border-color: #000000;
    }

    .auth-btn-secondary {
        background: #ffffff;
        color: #111827;
        border: 1px solid #d1d5db;
        border-radius: 999px;
        padding: 0.82rem 1.35rem;
        font-weight: 700;
        min-height: 50px;
        text-decoration: none;
    }

    .auth-btn-secondary:hover,
    .auth-btn-secondary:focus {
        background: #f9fafb;
        color: #111827;
        border-color: #9ca3af;
    }

    .auth-feature-list {
        display: grid;
        gap: 0.9rem;
    }

    .auth-feature-card {
        display: grid;
        grid-template-columns: 52px 1fr;
        gap: 0.9rem;
        align-items: start;
        padding: 1rem;
        border-radius: 20px;
        background: rgba(255,255,255,0.9);
        border: 1px solid #e5e7eb;
    }

    .auth-feature-card__icon {
        width: 52px;
        height: 52px;
        border-radius: 18px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #f3f4f6;
        color: #111827;
        border: 1px solid #e5e7eb;
        font-size: 1.05rem;
        font-weight: 800;
    }

    .auth-feature-card h4 {
        margin: 0 0 0.2rem 0;
        font-size: 1rem;
        color: #111827;
        font-weight: 800;
    }

    .auth-feature-card p {
        margin: 0;
        color: #6b7280;
        line-height: 1.55;
        font-size: 0.95rem;
    }

    .auth-side-panel__footer {
        margin-top: auto;
        padding-top: 0.3rem;
    }

    .auth-side-panel__footer-label {
        display: block;
        color: #6b7280;
        margin-bottom: 0.25rem;
        font-size: 0.92rem;
    }

    .auth-inline-link {
        color: #111827;
        font-weight: 700;
        text-decoration: none;
        border-bottom: 1px solid #cbd5e1;
    }

    .auth-inline-link:hover {
        color: #000000;
        border-bottom-color: #111827;
    }

    @@media (max-width: 991.98px) {
        .auth-layout {
            grid-template-columns: 1fr;
        }

        .auth-hero__content {
            padding: 1.5rem 1.2rem;
        }
    }

    @@media (max-width: 767.98px) {
        .auth-form-grid {
            grid-template-columns: 1fr;
        }

        .auth-field--full {
            grid-column: span 1;
        }

        .auth-hero__content h1 {
            font-size: 2.2rem;
        }

        .auth-main-card,
        .auth-side-panel {
            padding: 1.1rem;
        }
    }
</style>

@code {
    string email = "";
    string password = "";
    string? error;

    async Task DoLogin()
    {
        error = null;

        var req = new
        {
            email = email,
            password = password
        };

        var response = await Http.PostAsJsonAsync("/api/auth/login", req);

        if (!response.IsSuccessStatusCode)
        {
            error = "Credenciales inválidas";
            return;
        }

        var result = await response.Content.ReadFromJsonAsync<LoginResponse>();

        if (result == null || string.IsNullOrEmpty(result.token))
        {
            error = "No se recibió token";
            return;
        }

        await JS.InvokeVoidAsync("auth.setToken", result.token);

        Nav.NavigateTo("/");
    }

    class LoginResponse
    {
        public string token { get; set; } = "";
    }
}