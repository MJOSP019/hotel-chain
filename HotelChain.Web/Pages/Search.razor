@page "/search"
@using System.Net.Http.Headers
@using Microsoft.AspNetCore.WebUtilities
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav

@* 
   Componente encargado del flujo público de búsqueda de hoteles.
   Permite filtrar por ciudad, fechas, huéspedes, precio, tipo de habitación
   y rating, además de iniciar el flujo de reservación.
*@

<div class="search-page">
    <section class="search-hero">
        <div class="search-hero__content">
            <div class="search-badge">HotelChain Collection · Explora nuestra cadena</div>
            <h1>Encuentra el hotel ideal para tu próxima estadía</h1>
            <p>
                Consulta disponibilidad en los hoteles de nuestra cadena por ciudad, fechas, huéspedes,
                tipo de habitación, precio y calificación. Compara propiedades, revisa sus opciones
                disponibles y continúa con tu reservación.
            </p>

            <div class="search-hero__meta">
                <div class="hero-stat">
                    <span class="hero-stat__label">Check-in</span>
                    <span class="hero-stat__value">@model.CheckIn.ToString("dd/MM/yyyy")</span>
                </div>
                <div class="hero-stat">
                    <span class="hero-stat__label">Check-out</span>
                    <span class="hero-stat__value">@model.CheckOut.ToString("dd/MM/yyyy")</span>
                </div>
                <div class="hero-stat">
                    <span class="hero-stat__label">Huéspedes</span>
                    <span class="hero-stat__value">@model.Guests</span>
                </div>
            </div>
        </div>
    </section>

    <section class="search-panel">
        <div class="search-card">
            <div class="search-card__header">
                <div>
                    <div class="search-section-badge">Reserva directa</div>
                    <h3>Busca disponibilidad en nuestros hoteles</h3>
                    <p>Completa los filtros y consulta propiedades activas de la cadena hotelera.</p>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-lg-4">
                    <label class="search-label">Ciudad</label>
                    <select class="form-select search-input" @bind="model.CityId">
                        <option value="0">-- Selecciona --</option>
                        @if (cities != null)
                        {
                            @foreach (var c in cities)
                            {
                                <option value="@c.Id">@c.Name (@c.CountryCode)</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-6 col-lg-2">
                    <label class="search-label">Check-in</label>
                    <InputDate class="form-control search-input" @bind-Value="model.CheckIn" />
                </div>

                <div class="col-md-6 col-lg-2">
                    <label class="search-label">Check-out</label>
                    <InputDate class="form-control search-input" @bind-Value="model.CheckOut" />
                </div>

                <div class="col-md-6 col-lg-2">
                    <label class="search-label">Huéspedes</label>
                    <input type="number" class="form-control search-input" min="1" @bind="model.Guests" />
                </div>

                <div class="col-md-6 col-lg-2">
                    <label class="search-label">Tipo</label>
                    <select class="form-select search-input" @bind="model.RoomTypeId">
                        <option value="">-- Todos --</option>
                        @if (roomTypes != null)
                        {
                            @foreach (var rt in roomTypes)
                            {
                                <option value="@rt.Id">@rt.Name</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="search-label">Precio mínimo</label>
                    <input type="number" step="0.01" min="0" class="form-control search-input" @bind="model.MinPrice" />
                </div>

                <div class="col-md-4">
                    <label class="search-label">Precio máximo</label>
                    <input type="number" step="0.01" min="0" class="form-control search-input" @bind="model.MaxPrice" />
                </div>

                <div class="col-md-4">
                    <label class="search-label">Calificación mínima</label>
                    <select class="form-select search-input" @bind="model.MinRating">
                        <option value="">-- Cualquiera --</option>
                        <option value="1">1+ estrellas</option>
                        <option value="2">2+ estrellas</option>
                        <option value="3">3+ estrellas</option>
                        <option value="4">4+ estrellas</option>
                        <option value="5">5 estrellas</option>
                    </select>
                </div>
            </div>

            <div class="search-actions">
                <button class="btn search-btn-primary" @onclick="DoSearch" disabled="@isLoading">
                    @(isLoading ? "Buscando..." : "Buscar hoteles")
                </button>

                <a class="btn search-btn-secondary" href="/login">Iniciar sesión</a>
            </div>

            @if (!string.IsNullOrWhiteSpace(success))
            {
                <div class="alert alert-success search-alert mt-3">@success</div>
            }

            @if (!string.IsNullOrWhiteSpace(error))
            {
                <div class="alert alert-danger search-alert mt-3">@error</div>
            }
        </div>
    </section>

    @if (groupedHotels != null)
    {
        <section class="results-section">
            <div class="results-header">
                <div>
                    <div class="search-section-badge">Resultados</div>
                    <h3>Hoteles disponibles</h3>
                    <p>
                        @if (groupedHotels.Count == 0)
                        {
                            <span>No encontramos hoteles disponibles con los filtros seleccionados.</span>
                        }
                        else
                        {
                            <span>Se encontraron @groupedHotels.Count hotel(es) disponibles dentro de la cadena.</span>
                        }
                    </p>
                </div>

                @if (groupedHotels.Count > 0)
                {
                    <div class="results-summary">
                        <div class="results-summary__item">
                            <span class="results-summary__label">Ciudad</span>
                            <strong>@GetSelectedCityName()</strong>
                        </div>
                        <div class="results-summary__item">
                            <span class="results-summary__label">Fechas</span>
                            <strong>@GetStayRange()</strong>
                        </div>
                    </div>
                }
            </div>

            @if (groupedHotels.Count == 0)
            {
                <div class="empty-state">
                    <h4>Sin resultados disponibles</h4>
                    <p>
                        Prueba otra ciudad, modifica las fechas o ajusta el rango de precio y la calificación mínima para ampliar la búsqueda.
                    </p>
                </div>
            }
            else
            {
                <div class="hotel-results-grid">
                    @foreach (var hotel in groupedHotels)
                    {
                        <article class="hotel-result-card">
                            <div class="hotel-result-card__top">
                                <div>
                                    <div class="hotel-result-card__eyebrow">Propiedad de la cadena</div>
                                    <h4>@hotel.HotelName</h4>

                                    <div class="hotel-result-card__meta">
                                        @if (hotel.ReviewsCount > 0)
                                        {
                                            <div class="rating-block">
                                                <span class="rating-stars">@GetStars(hotel.AverageRating)</span>
                                                <span class="rating-text">@hotel.AverageRating.ToString("0.00") · @GetReviewsText(hotel.ReviewsCount)</span>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="hotel-result-card__meta-text">Sin opiniones publicadas</span>
                                        }
                                    </div>
                                </div>

                                <div class="hotel-result-price">
                                    <span class="hotel-result-price__label">Desde</span>
                                    <span class="hotel-result-price__value">Q @hotel.StartingPrice.ToString("0.00")</span>
                                    <span class="hotel-result-price__suffix">por noche</span>
                                </div>
                            </div>

                            <div class="hotel-result-card__body">
                                <div class="hotel-result-feature">
                                    <span class="hotel-result-feature__label">Opciones encontradas</span>
                                    <strong>@hotel.RoomsCount</strong>
                                </div>

                                <div class="hotel-result-feature">
                                    <span class="hotel-result-feature__label">Capacidad máxima</span>
                                    <strong>@hotel.MaxGuests huésped(es)</strong>
                                </div>

                                <div class="hotel-result-feature hotel-result-feature--wide">
                                    <span class="hotel-result-feature__label">Tipos de habitación disponibles</span>
                                    <strong>@string.Join(", ", hotel.RoomTypes)</strong>
                                </div>
                            </div>

                            <div class="hotel-result-card__rooms">
                                <div class="hotel-result-card__rooms-title">Opciones destacadas</div>

                                <div class="hotel-room-chips">
                                    @foreach (var room in hotel.FeaturedRooms)
                                    {
                                        <div class="hotel-room-chip">
                                            <div class="hotel-room-chip__name">@room.RoomType</div>
                                            <div class="hotel-room-chip__detail">@room.NameOrNumber · Q @room.BasePricePerNight.ToString("0.00")</div>
                                        </div>
                                    }
                                </div>
                            </div>

                            <div class="hotel-result-card__description">
                                <p>
                                    Explora el detalle de este hotel, revisa sus opiniones y conoce las habitaciones disponibles antes de continuar con la reservación.
                                </p>
                            </div>

                            <div class="hotel-result-card__footer">
                                <button class="btn search-btn-secondary btn-sm" @onclick="() => GoToHotel(hotel.HotelId)">
                                    Ver detalle del hotel
                                </button>

                                <button class="btn search-btn-primary btn-sm" @onclick="() => ReserveCheapest(hotel)">
                                    Reservar desde Q @hotel.StartingPrice.ToString("0.00")
                                </button>
                            </div>
                        </article>
                    }
                </div>
            }
        </section>
    }
</div>

