@code {
    /// <summary>
    /// Catálogo de ciudades disponibles para filtrar la búsqueda.
    /// </summary>
    private List<CityDto>? cities;

    /// <summary>
    /// Catálogo de tipos de habitación disponibles.
    /// </summary>
    private List<RoomTypeDto>? roomTypes;

    /// <summary>
    /// Resultados crudos devueltos por la API de búsqueda.
    /// </summary>
    private List<SearchResultDto>? results;

    /// <summary>
    /// Resultados agrupados por hotel para una mejor presentación visual.
    /// </summary>
    private List<GroupedHotelResult>? groupedHotels;

    /// <summary>
    /// Mensaje de error mostrado en pantalla.
    /// </summary>
    private string? error;

    /// <summary>
    /// Indica si hay una búsqueda en ejecución.
    /// </summary>
    private bool isLoading;

    /// <summary>
    /// Mensaje de éxito mostrado en pantalla.
    /// </summary>
    private string? success;

    /// <summary>
    /// Modelo principal de filtros utilizado para realizar búsquedas.
    /// </summary>
    private SearchRequest model = new()
    {
        CityId = 0,
        Guests = 2,
        CheckIn = DateTime.Today.AddDays(1),
        CheckOut = DateTime.Today.AddDays(3),
        RoomTypeId = null,
        MinPrice = null,
        MaxPrice = null,
        MinRating = null
    };

    /// <summary>
    /// Carga catálogos iniciales y parámetros opcionales provenientes del query string.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        cities = await Http.GetFromJsonAsync<List<CityDto>>("/api/public/cities");
        roomTypes = await Http.GetFromJsonAsync<List<RoomTypeDto>>("/api/public/room-types");

        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var qs = QueryHelpers.ParseQuery(uri.Query);

        if (qs.TryGetValue("cityId", out var cityIdStr) && int.TryParse(cityIdStr, out var cityId))
            model.CityId = cityId;

        if (qs.TryGetValue("guests", out var guestsStr) && int.TryParse(guestsStr, out var guests))
            model.Guests = guests;

        if (qs.TryGetValue("checkIn", out var checkInStr) && DateTime.TryParse(checkInStr, out var checkIn))
            model.CheckIn = checkIn;

        if (qs.TryGetValue("checkOut", out var checkOutStr) && DateTime.TryParse(checkOutStr, out var checkOut))
            model.CheckOut = checkOut;

        if (model.CityId > 0)
            await DoSearch();
    }

    /// <summary>
    /// Ejecuta la búsqueda pública de hoteles según los filtros ingresados.
    /// </summary>
    private async Task DoSearch()
    {
        error = null;
        success = null;
        results = null;
        groupedHotels = null;

        if (model.CityId <= 0)
        {
            error = "Selecciona una ciudad.";
            return;
        }

        if (model.CheckOut.Date <= model.CheckIn.Date)
        {
            error = "Check-out debe ser mayor que Check-in.";
            return;
        }

        if (model.MinPrice.HasValue && model.MaxPrice.HasValue && model.MinPrice.Value > model.MaxPrice.Value)
        {
            error = "El precio mínimo no puede ser mayor que el precio máximo.";
            return;
        }

        if (model.MinRating.HasValue && (model.MinRating.Value < 1 || model.MinRating.Value > 5))
        {
            error = "La calificación mínima debe estar entre 1 y 5.";
            return;
        }

        isLoading = true;

        try
        {
            var resp = await Http.PostAsJsonAsync("/api/public/search", model);
            if (!resp.IsSuccessStatusCode)
            {
                error = await resp.Content.ReadAsStringAsync();
                return;
            }

            results = await resp.Content.ReadFromJsonAsync<List<SearchResultDto>>() ?? new();
            groupedHotels = BuildGroupedHotels(results);
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    /// <summary>
    /// Agrupa resultados por hotel para facilitar su renderizado como tarjetas.
    /// </summary>
    /// <param name="items">Resultados individuales devueltos por la API.</param>
    /// <returns>Lista de resultados agrupados por hotel.</returns>
    private List<GroupedHotelResult> BuildGroupedHotels(List<SearchResultDto> items)
    {
        return items
            .GroupBy(x => new
            {
                x.HotelId,
                x.Hotel,
                x.AverageRating,
                x.ReviewsCount
            })
            .Select(g =>
            {
                var orderedRooms = g
                    .OrderBy(x => x.BasePricePerNight)
                    .ThenBy(x => x.RoomType)
                    .ToList();

                return new GroupedHotelResult
                {
                    HotelId = g.Key.HotelId,
                    HotelName = g.Key.Hotel,
                    AverageRating = g.Key.AverageRating,
                    ReviewsCount = g.Key.ReviewsCount,
                    StartingPrice = orderedRooms.Min(x => x.BasePricePerNight),
                    RoomsCount = orderedRooms.Count,
                    MaxGuests = orderedRooms.Max(x => x.MaxGuests),
                    RoomTypes = orderedRooms
                        .Select(x => x.RoomType)
                        .Where(x => !string.IsNullOrWhiteSpace(x))
                        .Distinct()
                        .ToList(),
                    FeaturedRooms = orderedRooms.Take(3).ToList(),
                    CheapestRoom = orderedRooms.First()
                };
            })
            .OrderBy(x => x.StartingPrice)
            .ThenByDescending(x => x.AverageRating)
            .ToList();
    }

    /// <summary>
    /// Inicia una reservación utilizando la habitación seleccionada.
    /// </summary>
    /// <param name="r">Resultado de búsqueda correspondiente a la habitación seleccionada.</param>
    private async Task Reserve(SearchResultDto r)
    {
        success = null;
        error = null;

        try
        {
            var token = await JS.InvokeAsync<string>("auth.getToken");

            if (string.IsNullOrWhiteSpace(token))
            {
                error = "Necesitas iniciar sesión para reservar.";
                return;
            }

            var body = new
            {
                roomId = r.Id,
                checkIn = model.CheckIn,
                checkOut = model.CheckOut,
                guests = model.Guests
            };

            var req = new HttpRequestMessage(HttpMethod.Post, "/api/public/reservations");
            req.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);
            req.Content = JsonContent.Create(body);

            var resp = await Http.SendAsync(req);

            if (!resp.IsSuccessStatusCode)
            {
                error = await resp.Content.ReadAsStringAsync();
                return;
            }

            var data = await resp.Content.ReadFromJsonAsync<ReserveResponse>();
            success = $"✅ Reserva creada: {data!.Code} (Total: {data.TotalAmount})";
            Nav.NavigateTo($"/checkout?code={data.Code}");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    /// <summary>
    /// Inicia una reservación utilizando la habitación más económica del hotel agrupado.
    /// </summary>
    /// <param name="hotel">Hotel agrupado mostrado en la tarjeta de resultados.</param>
    private async Task ReserveCheapest(GroupedHotelResult hotel)
    {
        await Reserve(hotel.CheapestRoom);
    }

    /// <summary>
    /// Navega al detalle de un hotel preservando filtros relevantes en el query string.
    /// </summary>
    /// <param name="hotelId">Identificador del hotel a consultar.</param>
    private void GoToHotel(int hotelId)
    {
        var query = new Dictionary<string, string?>
        {
            ["cityId"] = model.CityId > 0 ? model.CityId.ToString() : null,
            ["checkIn"] = model.CheckIn.ToString("yyyy-MM-dd"),
            ["checkOut"] = model.CheckOut.ToString("yyyy-MM-dd"),
            ["guests"] = model.Guests.ToString()
        };

        var url = QueryHelpers.AddQueryString($"/hotels/{hotelId}", query);
        Nav.NavigateTo(url);
    }

    /// <summary>
    /// Convierte una calificación decimal en una representación visual con estrellas.
    /// </summary>
    private string GetStars(decimal rating)
    {
        var rounded = (int)Math.Round(rating, MidpointRounding.AwayFromZero);
        rounded = Math.Max(0, Math.Min(5, rounded));
        return new string('★', rounded) + new string('☆', 5 - rounded);
    }

    /// <summary>
    /// Obtiene el nombre descriptivo de la ciudad seleccionada.
    /// </summary>
    private string GetSelectedCityName()
    {
        if (cities is null || model.CityId <= 0)
            return "No definida";

        var city = cities.FirstOrDefault(x => x.Id == model.CityId);
        return city is null ? "No definida" : $"{city.Name} ({city.CountryCode})";
    }

    /// <summary>
    /// Devuelve un rango corto de estancia para mostrar en la vista.
    /// </summary>
    private string GetStayRange()
    {
        return $"{model.CheckIn:dd/MM} - {model.CheckOut:dd/MM}";
    }

    /// <summary>
    /// Devuelve un texto amigable para la cantidad de opiniones.
    /// </summary>
    private string GetReviewsText(int count)
    {
        return count == 1 ? "1 opinión" : $"{count} opiniones";
    }

