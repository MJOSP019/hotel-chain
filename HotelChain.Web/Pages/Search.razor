@code {
    private List<CityDto>? cities;
    private List<RoomTypeDto>? roomTypes;
    private List<SearchResultDto>? results;
    private List<GroupedHotelResult>? groupedHotels;
    private List<SearchRestrictionMessageDto> restrictionMessages = new();
    private string? error;
    private bool isLoading;
    private bool isLoggedIn;
    private string? success;
    private string sortOption = "price";

    private SearchRequest model = new()
    {
        CityId = 0,
        Guests = 2,
        CheckIn = DateTime.Today.AddDays(1),
        CheckOut = DateTime.Today.AddDays(3),
        RoomTypeId = null,
        MinPrice = null,
        MaxPrice = null,
        MinRating = null
    };

    protected override async Task OnInitializedAsync()
    {
        cities = await Http.GetFromJsonAsync<List<CityDto>>("/api/public/cities");
        roomTypes = await Http.GetFromJsonAsync<List<RoomTypeDto>>("/api/public/room-types");

        var token = await JS.InvokeAsync<string>("auth.getToken");
        isLoggedIn = !string.IsNullOrWhiteSpace(token);

        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var qs = QueryHelpers.ParseQuery(uri.Query);

        if (qs.TryGetValue("cityId", out var cityIdStr) && int.TryParse(cityIdStr, out var cityId))
            model.CityId = cityId;

        if (qs.TryGetValue("guests", out var guestsStr) && int.TryParse(guestsStr, out var guests))
            model.Guests = guests;

        if (qs.TryGetValue("checkIn", out var checkInStr) && DateTime.TryParse(checkInStr, out var checkIn))
            model.CheckIn = checkIn;

        if (qs.TryGetValue("checkOut", out var checkOutStr) && DateTime.TryParse(checkOutStr, out var checkOut))
            model.CheckOut = checkOut;

        if (qs.TryGetValue("roomTypeId", out var roomTypeStr) && int.TryParse(roomTypeStr, out var roomTypeId))
            model.RoomTypeId = roomTypeId;

        if (qs.TryGetValue("minPrice", out var minPriceStr) && decimal.TryParse(minPriceStr, out var minPrice))
            model.MinPrice = minPrice;

        if (qs.TryGetValue("maxPrice", out var maxPriceStr) && decimal.TryParse(maxPriceStr, out var maxPrice))
            model.MaxPrice = maxPrice;

        if (qs.TryGetValue("minRating", out var minRatingStr) && double.TryParse(minRatingStr, out var minRating))
            model.MinRating = minRating;

        if (qs.TryGetValue("sort", out var sortStr) && IsValidSort(sortStr.ToString()))
            sortOption = sortStr.ToString();

        if (model.CityId > 0)
            await DoSearch();
    }

    private async Task DoSearch()
    {
        error = null;
        success = null;
        results = null;
        groupedHotels = null;
        restrictionMessages = new();

        if (model.CityId <= 0)
        {
            error = "Selecciona una ciudad.";
            return;
        }

        if (model.CheckOut.Date <= model.CheckIn.Date)
        {
            error = "Check-out debe ser mayor que Check-in.";
            return;
        }

        if (model.MinPrice.HasValue && model.MaxPrice.HasValue && model.MinPrice.Value > model.MaxPrice.Value)
        {
            error = "El precio mínimo no puede ser mayor que el precio máximo.";
            return;
        }

        if (model.MinRating.HasValue && (model.MinRating.Value < 1 || model.MinRating.Value > 5))
        {
            error = "La calificación mínima debe estar entre 1 y 5.";
            return;
        }

        isLoading = true;

        try
        {
            var resp = await Http.PostAsJsonAsync("/api/public/search", model);
            if (!resp.IsSuccessStatusCode)
            {
                error = await resp.Content.ReadAsStringAsync();
                return;
            }

            var payload = await resp.Content.ReadFromJsonAsync<SearchResponseDto>() ?? new();
            results = payload.Results ?? new();
            restrictionMessages = payload.RestrictionMessages ?? new();
            groupedHotels = BuildGroupedHotels(results);
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private List<GroupedHotelResult> BuildGroupedHotels(List<SearchResultDto> items)
    {
        return items
            .GroupBy(x => new
            {
                x.HotelId,
                x.Hotel,
                x.AverageRating,
                x.ReviewsCount
            })
            .Select(g =>
            {
                var orderedRooms = g
                    .OrderBy(x => x.BasePricePerNight)
                    .ThenBy(x => x.RoomType)
                    .ToList();

                return new GroupedHotelResult
                {
                    HotelId = g.Key.HotelId,
                    HotelName = g.Key.Hotel,
                    AverageRating = g.Key.AverageRating,
                    ReviewsCount = g.Key.ReviewsCount,
                    StartingPrice = orderedRooms.Min(x => x.BasePricePerNight),
                    RoomOptionsCount = orderedRooms.Count,
                    MaxGuests = orderedRooms.Max(x => x.MaxGuests),
                    AvailableUnits = orderedRooms.Sum(x => x.AvailableUnits),
                    RoomTypes = orderedRooms
                        .Select(x => x.RoomType)
                        .Where(x => !string.IsNullOrWhiteSpace(x))
                        .Distinct()
                        .ToList(),
                    FeaturedRooms = orderedRooms.Take(3).ToList(),
                    CheapestRoom = orderedRooms.First()
                };
            })
            .OrderBy(x => x.StartingPrice)
            .ThenByDescending(x => x.AverageRating)
            .ToList();
    }

    private IEnumerable<GroupedHotelResult> SortedHotels => SortGroupedHotels(groupedHotels ?? new());

    private IEnumerable<GroupedHotelResult> SortGroupedHotels(IEnumerable<GroupedHotelResult> hotels)
    {
        return sortOption switch
        {
            "rating" => hotels.OrderByDescending(x => x.AverageRating).ThenBy(x => x.StartingPrice),
            "availability" => hotels.OrderByDescending(x => x.AvailableUnits).ThenBy(x => x.StartingPrice),
            "capacity" => hotels.OrderByDescending(x => x.MaxGuests).ThenBy(x => x.StartingPrice),
            _ => hotels.OrderBy(x => x.StartingPrice).ThenByDescending(x => x.AverageRating)
        };
    }

    private bool IsValidSort(string? value)
    {
        return value is "price" or "rating" or "availability" or "capacity";
    }

    private int GetNights()
    {
        return Math.Max(1, (model.CheckOut.Date - model.CheckIn.Date).Days);
    }

    private decimal GetStayTotal(decimal pricePerNight)
    {
        return pricePerNight * GetNights();
    }


    private async Task AddToCart(SearchResultDto r)
    {
        success = null;
        error = null;

        if (model.CheckOut.Date <= model.CheckIn.Date)
        {
            error = "Check-out debe ser mayor que check-in.";
            return;
        }

        var item = new ReservationCartItem
        {
            HotelId = r.HotelId,
            HotelName = r.Hotel,
            RoomTypeId = r.RoomTypeId,
            RoomType = r.RoomType,
            CheckIn = model.CheckIn.Date,
            CheckOut = model.CheckOut.Date,
            Guests = model.Guests,
            Quantity = 1,
            PricePerNight = r.BasePricePerNight,
            MaxGuests = r.MaxGuests,
            AvailableUnits = r.AvailableUnits,
            ImageUrl = r.ImageUrl,
            BedType = r.BedType,
            AreaSquareMeters = r.AreaSquareMeters
        };

        await Cart.AddAsync(item);

        success = $"✅ {r.RoomType} en {r.Hotel} agregado al carrito.";
    }

    private async Task AddCheapestToCart(GroupedHotelResult hotel)
    {
        await AddToCart(hotel.CheapestRoom);
    }

    private async Task Reserve(SearchResultDto r)
    {
        success = null;
        error = null;

        try
        {
            var token = await JS.InvokeAsync<string>("auth.getToken");

            if (string.IsNullOrWhiteSpace(token))
            {
                error = "Necesitas iniciar sesión para reservar.";
                return;
            }

            var body = new
            {
                hotelId = r.HotelId,
                roomTypeId = r.RoomTypeId,
                checkIn = model.CheckIn,
                checkOut = model.CheckOut,
                guests = model.Guests
            };

            var req = new HttpRequestMessage(HttpMethod.Post, "/api/public/reservations");
            req.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);
            req.Content = JsonContent.Create(body);

            var resp = await Http.SendAsync(req);

            if (!resp.IsSuccessStatusCode)
            {
                error = await resp.Content.ReadAsStringAsync();
                return;
            }

            var data = await resp.Content.ReadFromJsonAsync<ReserveResponse>();
            success = $"✅ Reserva creada: {data!.Code} (Total: Q {data.TotalAmount:0.00})";
            Nav.NavigateTo($"/checkout?code={data.Code}");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private async Task ReserveCheapest(GroupedHotelResult hotel)
    {
        await Reserve(hotel.CheapestRoom);
    }

    private void GoToHotel(int hotelId)
    {
        var query = new Dictionary<string, string?>
        {
            ["cityId"] = model.CityId > 0 ? model.CityId.ToString() : null,
            ["checkIn"] = model.CheckIn.ToString("yyyy-MM-dd"),
            ["checkOut"] = model.CheckOut.ToString("yyyy-MM-dd"),
            ["guests"] = model.Guests.ToString(),
            ["roomTypeId"] = model.RoomTypeId?.ToString(),
            ["minPrice"] = model.MinPrice?.ToString("0.##"),
            ["maxPrice"] = model.MaxPrice?.ToString("0.##"),
            ["minRating"] = model.MinRating?.ToString("0.##"),
            ["sort"] = sortOption
        };

        var cleanQuery = query
    .Where(x => !string.IsNullOrWhiteSpace(x.Value))
    .ToDictionary(x => x.Key, x => x.Value);

    var url = QueryHelpers.AddQueryString($"/hotels/{hotelId}", cleanQuery);
        Nav.NavigateTo(url);
    }

    private string GetStars(decimal rating)
    {
        var rounded = (int)Math.Round(rating, MidpointRounding.AwayFromZero);
        rounded = Math.Max(0, Math.Min(5, rounded));
        return new string('★', rounded) + new string('☆', 5 - rounded);
    }

    private string GetSelectedCityName()
    {
        if (cities is null || model.CityId <= 0)
            return "No definida";

        var city = cities.FirstOrDefault(x => x.Id == model.CityId);
        return city is null ? "No definida" : $"{city.Name} ({city.CountryCode})";
    }

    private string GetStayRange() => $"{model.CheckIn:dd/MM} - {model.CheckOut:dd/MM}";

    private string GetReviewsText(int count) => count == 1 ? "1 opinión" : $"{count} opiniones";

    private class CityDto
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string CountryCode { get; set; } = "";
    }

    private class RoomTypeDto
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
    }

    private class SearchRequest
    {
        public int CityId { get; set; }
        public DateTime CheckIn { get; set; }
        public DateTime CheckOut { get; set; }
        public int Guests { get; set; }
        public decimal? MinPrice { get; set; }
        public decimal? MaxPrice { get; set; }
        public int? RoomTypeId { get; set; }
        public double? MinRating { get; set; }
    }

    private class SearchResultDto
    {
        public int HotelId { get; set; }
        public int RoomTypeId { get; set; }
        public int MaxGuests { get; set; }
        public int AvailableUnits { get; set; }
        public decimal BasePricePerNight { get; set; }
        public string RoomType { get; set; } = "";
        public string Hotel { get; set; } = "";
        public string? BedType { get; set; }
        public decimal? AreaSquareMeters { get; set; }
        public string? ShortDescription { get; set; }
        public string? ImageUrl { get; set; }
        public decimal AverageRating { get; set; }
        public int ReviewsCount { get; set; }
    }

    private class SearchRestrictionMessageDto
    {
        public string Code { get; set; } = "";
        public string Title { get; set; } = "";
        public string Message { get; set; } = "";
        public int AffectedOptions { get; set; }
    }

    private class SearchResponseDto
    {
        public List<SearchResultDto> Results { get; set; } = new();
        public List<SearchRestrictionMessageDto> RestrictionMessages { get; set; } = new();
    }

    private class GroupedHotelResult
    {
        public int HotelId { get; set; }
        public string HotelName { get; set; } = "";
        public decimal AverageRating { get; set; }
        public int ReviewsCount { get; set; }
        public decimal StartingPrice { get; set; }
        public int RoomOptionsCount { get; set; }
        public int MaxGuests { get; set; }
        public int AvailableUnits { get; set; }
        public List<string> RoomTypes { get; set; } = new();
        public List<SearchResultDto> FeaturedRooms { get; set; } = new();
        public SearchResultDto CheapestRoom { get; set; } = new();
    }

    private class ReserveResponse
    {
        public int Id { get; set; }
        public string Code { get; set; } = "";
        public string Status { get; set; } = "";
        public decimal TotalAmount { get; set; }
    }
}