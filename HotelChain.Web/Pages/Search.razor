@page "/search"
@using System.Net.Http.Headers
@using Microsoft.AspNetCore.WebUtilities
@using HotelChain.Web.Models
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject HotelChain.Web.Services.ReservationCartService Cart

<PageTitle>Buscar y reservar</PageTitle>

<div class="search-page-m">
    <section class="search-hero-m">
        <div class="search-hero-m__overlay"></div>
        <div class="search-hero-m__content">
            <div class="search-hero-m__eyebrow">HotelChain Collection</div>
            <h1>Busca hoteles y elige la habitación ideal para tu estadía.</h1>
            <p>
                Explora propiedades activas de la cadena, compara tarifas desde el listado
                y continúa con tu reserva desde una experiencia más clara y orientada a hotelería.
            </p>

            <div class="search-hero-m__facts">
                <div class="hero-fact-m">
                    <span>Check-in</span>
                    <strong>@model.CheckIn.ToString("dd MMM yyyy")</strong>
                </div>
                <div class="hero-fact-m">
                    <span>Check-out</span>
                    <strong>@model.CheckOut.ToString("dd MMM yyyy")</strong>
                </div>
                <div class="hero-fact-m">
                    <span>Huéspedes</span>
                    <strong>@model.Guests</strong>
                </div>
            </div>
        </div>
    </section>

    <section class="search-bar-m-wrap">
        <div class="search-bar-m card-shadow-m">
            <div class="search-bar-m__header">
                <div>
                    <div class="section-tag-m">Reserva directa</div>
                    <h2>Buscar disponibilidad</h2>
                    <p>Filtra por destino, fechas, huéspedes y preferencias.</p>
                </div>
            </div>

            <div class="row g-3 align-items-end">
                <div class="col-lg-4">
                    <label class="search-label-m">Ciudad</label>
                    <select class="form-select search-input-m" @bind="model.CityId">
                        <option value="0">Selecciona una ciudad</option>
                        @if (cities != null)
                        {
                            @foreach (var c in cities)
                            {
                                <option value="@c.Id">@c.Name (@c.CountryCode)</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-6 col-lg-2">
                    <label class="search-label-m">Check-in</label>
                    <InputDate class="form-control search-input-m" @bind-Value="model.CheckIn" />
                </div>

                <div class="col-md-6 col-lg-2">
                    <label class="search-label-m">Check-out</label>
                    <InputDate class="form-control search-input-m" @bind-Value="model.CheckOut" />
                </div>

                <div class="col-md-6 col-lg-2">
                    <label class="search-label-m">Huéspedes</label>
                    <input type="number" min="1" class="form-control search-input-m" @bind="model.Guests" />
                </div>

                <div class="col-md-6 col-lg-2">
                    <label class="search-label-m">Tipo</label>
                    <select class="form-select search-input-m" @bind="model.RoomTypeId">
                        <option value="">Todos</option>
                        @if (roomTypes != null)
                        {
                            @foreach (var rt in roomTypes)
                            {
                                <option value="@rt.Id">@rt.Name</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="search-label-m">Precio mínimo</label>
                    <input type="number" step="0.01" min="0" class="form-control search-input-m" @bind="model.MinPrice" />
                </div>

                <div class="col-md-4">
                    <label class="search-label-m">Precio máximo</label>
                    <input type="number" step="0.01" min="0" class="form-control search-input-m" @bind="model.MaxPrice" />
                </div>

                <div class="col-md-4">
                    <label class="search-label-m">Calificación mínima</label>
                    <select class="form-select search-input-m" @bind="model.MinRating">
                        <option value="">Cualquiera</option>
                        <option value="1">1+ estrellas</option>
                        <option value="2">2+ estrellas</option>
                        <option value="3">3+ estrellas</option>
                        <option value="4">4+ estrellas</option>
                        <option value="5">5 estrellas</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="search-label-m">Ordenar por</label>
                    <select class="form-select search-input-m" @bind="sortOption">
                        <option value="price">Menor precio</option>
                        <option value="rating">Mejor rating</option>
                        <option value="availability">Más disponibilidad</option>
                        <option value="capacity">Mayor capacidad</option>
                    </select>
                </div>
            </div>

            <div class="search-actions-m">
                <button class="btn btn-dark search-btn-m search-btn-m--primary" @onclick="DoSearch" disabled="@isLoading">
                    @(isLoading ? "Buscando..." : "Buscar hoteles")
                </button>

                @if (isLoggedIn)
                {
                    <a class="btn search-btn-m search-btn-m--secondary" href="/my-reservations">Mis reservaciones</a>
                }
                else
                {
                    <a class="btn search-btn-m search-btn-m--secondary" href="/login">Iniciar sesión</a>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(success))
            {
                <div class="alert alert-success mt-3 search-alert-m">@success</div>
            }

            @if (!string.IsNullOrWhiteSpace(error))
            {
                <div class="alert alert-danger mt-3 search-alert-m">@error</div>
            }
        </div>
    </section>

    @if (groupedHotels != null)
    {
        <section class="results-m">
            <div class="results-m__header">
                <div>
                    <div class="section-tag-m">Resultados</div>
                    <h2>Hoteles disponibles</h2>
                    <p>
                        @if (groupedHotels.Count == 0)
                        {
                            <span>No encontramos hoteles disponibles con los filtros seleccionados.</span>
                        }
                        else
                        {
                            <span>Encontramos @groupedHotels.Count hotel(es) dentro de la cadena para las fechas indicadas.</span>
                        }
                    </p>
                </div>

                @if (groupedHotels.Count > 0)
                {
                    <div class="results-m__summary">
                        <div class="summary-chip-m">
                            <span>Ciudad</span>
                            <strong>@GetSelectedCityName()</strong>
                        </div>
                        <div class="summary-chip-m">
                            <span>Estancia</span>
                            <strong>@GetStayRange()</strong>
                        </div>
                    </div>
                }
            </div>

            @if (restrictionMessages.Any())
            {
                <div class="restriction-panel-m">
                    @foreach (var item in restrictionMessages)
                    {
                        <article class="restriction-card-m">
                            <div class="restriction-card-m__title">@item.Title</div>
                            <p>@item.Message</p>
                            <small>@item.AffectedOptions opción(es) afectada(s)</small>
                        </article>
                    }
                </div>
            }

            @if (groupedHotels.Count == 0)
            {
                <div class="empty-state-m card-shadow-m">
                    <h3>No hay resultados disponibles</h3>
                    <p>Prueba otra ciudad, cambia las fechas o amplía el rango de precio y calificación.</p>
                    @if (restrictionMessages.Any())
                    {
                        <div class="empty-state-m__note">Las reglas comerciales activas también están limitando las opciones visibles para estas fechas.</div>
                    }
                </div>
            }
            else
            {
                <div class="hotel-list-m">
                    @foreach (var hotel in SortedHotels)
                    {
                        var heroRoom = hotel.FeaturedRooms.FirstOrDefault() ?? hotel.CheapestRoom;

                        <article class="hotel-card-m card-shadow-m">
                            <div class="hotel-card-m__media">
                                @if (!string.IsNullOrWhiteSpace(heroRoom.ImageUrl))
                                {
                                    <img src="@heroRoom.ImageUrl" alt="@hotel.HotelName" />
                                }
                                else
                                {
                                    <div class="hotel-card-m__placeholder">
                                        <span>@hotel.HotelName</span>
                                    </div>
                                }
                            </div>

                            <div class="hotel-card-m__body">
                                <div class="hotel-card-m__topline">
                                    <div>
                                        <div class="hotel-card-m__eyebrow">Hotel de la cadena</div>
                                        <h3>@hotel.HotelName</h3>

                                        <div class="hotel-card-m__rating">
                                            @if (hotel.ReviewsCount > 0)
                                            {
                                                <span class="stars-m">@GetStars(hotel.AverageRating)</span>
                                                <span>@hotel.AverageRating.ToString("0.0") · @GetReviewsText(hotel.ReviewsCount)</span>
                                            }
                                            else
                                            {
                                                <span>Sin opiniones publicadas</span>
                                            }
                                        </div>
                                    </div>

                                    <div class="hotel-card-m__pricebox">
                                        <span>Desde</span>
                                        <strong>Q @hotel.StartingPrice.ToString("0.00")</strong>
                                        <small>por noche</small>
                                        <div class="hotel-card-m__total">
                                            @GetNights() noche(s) · Total estimado Q @GetStayTotal(hotel.StartingPrice).ToString("0.00")
                                        </div>
                                    </div>
                                </div>

                                <div class="hotel-card-m__meta-grid">
                                    <div class="meta-box-m">
                                        <span>Opciones</span>
                                        <strong>@hotel.RoomOptionsCount</strong>
                                    </div>
                                    <div class="meta-box-m">
                                        <span>Capacidad máxima</span>
                                        <strong>@hotel.MaxGuests huésped(es)</strong>
                                    </div>
                                    <div class="meta-box-m meta-box-m--wide">
                                        <span>Tipos disponibles</span>
                                        <strong>@string.Join(" · ", hotel.RoomTypes)</strong>
                                    </div>
                                </div>

                                <div class="hotel-card-m__room-strip">
                                    <div class="room-strip-m__title">Opciones destacadas</div>
                                    <div class="room-strip-m__items">
                                        @foreach (var room in hotel.FeaturedRooms)
                                        {
                                            <div class="room-mini-m">
                                                <div class="room-mini-m__name">@room.RoomType</div>
                                                <div class="room-mini-m__detail">@room.AvailableUnits disponible(s) · hasta @room.MaxGuests huésped(es)</div>
                                                <div class="room-mini-m__price">Q @room.BasePricePerNight.ToString("0.00") por noche</div>
                                                <div class="room-mini-m__total">Total estadía Q @GetStayTotal(room.BasePricePerNight).ToString("0.00")</div>
                                                <button class="btn btn-dark search-btn-m search-btn-m--primary search-btn-m--xs" @onclick="() => AddToCart(room)">
                                                    Agregar al carrito
                                                </button>
                                            </div>
                                        }
                                    </div>
                                </div>

                                <div class="hotel-card-m__footer">
                                    <button class="btn search-btn-m search-btn-m--secondary search-btn-m--sm" @onclick="() => GoToHotel(hotel.HotelId)">
                                        Ver habitaciones
                                    </button>
                                    <button class="btn btn-dark search-btn-m search-btn-m--primary search-btn-m--sm" @onclick="() => AddCheapestToCart(hotel)">
                                        Agregar opción más económica
                                    </button>
                                </div>
                            </div>
                        </article>
                    }
                </div>
            }
        </section>
    }
</div>

<style>
    .search-page-m {
        color: #1b1b1b;
        padding: 0 0 2.5rem;
    }

    .card-shadow-m {
        box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
    }

    .search-hero-m {
        position: relative;
        min-height: 360px;
        border-radius: 0 0 28px 28px;
        overflow: hidden;
        background:
            linear-gradient(90deg, rgba(17, 24, 39, 0.78), rgba(17, 24, 39, 0.46)),
            url('https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&fit=crop&w=1600&q=80') center/cover no-repeat;
        margin-bottom: -84px;
    }

    .search-hero-m__overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, rgba(0,0,0,0.12), rgba(0,0,0,0.18));
    }

    .search-hero-m__content {
        position: relative;
        z-index: 1;
        max-width: 1240px;
        margin: 0 auto;
        padding: 4.5rem 1.5rem 7rem;
        color: #fff;
    }

    .search-hero-m__eyebrow,
    .section-tag-m {
        display: inline-flex;
        align-items: center;
        padding: 0.4rem 0.8rem;
        border-radius: 999px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-size: 0.72rem;
        font-weight: 700;
    }

    .search-hero-m__eyebrow {
        background: rgba(255,255,255,0.12);
        color: rgba(255,255,255,0.95);
        margin-bottom: 1rem;
    }

    .section-tag-m {
        background: #f3f4f6;
        color: #374151;
        margin-bottom: 0.85rem;
    }

    .search-hero-m h1 {
        max-width: 720px;
        font-size: clamp(2.2rem, 4.5vw, 4rem);
        line-height: 1.02;
        letter-spacing: -0.02em;
        font-weight: 600;
        margin: 0 0 1rem;
    }

    .search-hero-m p {
        max-width: 720px;
        margin: 0;
        color: rgba(255,255,255,0.86);
        line-height: 1.75;
        font-size: 1rem;
    }

    .search-hero-m__facts {
        display: flex;
        flex-wrap: wrap;
        gap: 0.9rem;
        margin-top: 1.6rem;
    }

    .hero-fact-m {
        min-width: 170px;
        background: rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.14);
        border-radius: 16px;
        padding: 0.9rem 1rem;
        backdrop-filter: blur(6px);
    }

    .hero-fact-m span {
        display: block;
        font-size: 0.74rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: rgba(255,255,255,0.7);
        margin-bottom: 0.2rem;
    }

    .hero-fact-m strong {
        font-size: 1rem;
        font-weight: 700;
        color: #fff;
    }

    .search-bar-m-wrap {
        max-width: 1240px;
        margin: 0 auto;
        padding: 0 1.5rem;
        position: relative;
        z-index: 2;
    }

    .search-bar-m {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 28px;
        padding: 1.5rem;
    }

    .search-bar-m__header h2,
    .results-m__header h2 {
        margin: 0 0 0.3rem;
        font-size: 2rem;
        font-weight: 500;
        letter-spacing: -0.02em;
        color: #111827;
    }

    .search-bar-m__header p,
    .results-m__header p {
        margin: 0;
        color: #6b7280;
    }

    .search-label-m {
        display: block;
        margin-bottom: 0.5rem;
        font-size: 0.83rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: #4b5563;
    }

    .search-input-m {
        min-height: 52px;
        border-radius: 14px;
        border: 1px solid #d1d5db;
        background: #fff;
        color: #111827;
    }

    .search-input-m:focus {
        border-color: #111827;
        box-shadow: 0 0 0 0.12rem rgba(17, 24, 39, 0.12);
    }

    .search-actions-m {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-top: 1.2rem;
    }

    .search-btn-m {
        border-radius: 999px;
        font-weight: 700;
        padding: 0.85rem 1.3rem;
        border: 1px solid transparent;
    }

    .search-btn-m--primary {
        background: #111827;
        color: #fff;
    }

    .search-btn-m--primary:hover,
    .search-btn-m--primary:focus {
        background: #000;
        color: #fff;
    }

    .search-btn-m--secondary {
        background: #fff;
        color: #111827;
        border-color: #d1d5db;
    }

    .search-btn-m--secondary:hover,
    .search-btn-m--secondary:focus {
        background: #f9fafb;
        color: #111827;
        border-color: #9ca3af;
    }

    .search-btn-m--sm {
        padding: 0.75rem 1.1rem;
        font-size: 0.95rem;
    }

    .search-btn-m--xs {
        width: 100%;
        margin-top: 0.75rem;
        padding: 0.62rem 0.85rem;
        font-size: 0.86rem;
    }

    .search-alert-m {
        border-radius: 18px;
    }

    .results-m {
        max-width: 1240px;
        margin: 1.6rem auto 0;
        padding: 0 1.5rem;
    }

    .results-m__header {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: flex-start;
        margin-bottom: 1.2rem;
        flex-wrap: wrap;
    }

    .results-m__summary {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .summary-chip-m {
        min-width: 170px;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 18px;
        padding: 0.9rem 1rem;
    }

    .summary-chip-m span,
    .meta-box-m span,
    .hotel-card-m__pricebox span {
        display: block;
        color: #6b7280;
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-bottom: 0.2rem;
        font-weight: 700;
    }

    .restriction-panel-m {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 0.9rem;
        margin-bottom: 1rem;
    }

    .restriction-card-m {
        background: #fff7ed;
        border: 1px solid #fed7aa;
        border-radius: 18px;
        padding: 1rem;
    }

    .restriction-card-m__title {
        font-size: 0.82rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: #9a3412;
        margin-bottom: 0.4rem;
    }

    .restriction-card-m p,
    .restriction-card-m small,
    .empty-state-m__note {
        color: #7c2d12;
        margin: 0;
    }

    .restriction-card-m small {
        display: block;
        margin-top: 0.55rem;
    }

    .empty-state-m__note {
        margin-top: 0.85rem;
        font-size: 0.95rem;
    }

    .hotel-list-m {
        display: grid;
        gap: 1.25rem;
    }

    .hotel-card-m {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 28px;
        overflow: hidden;
        display: grid;
        grid-template-columns: 38% 62%;
    }

    .hotel-card-m__media {
        min-height: 100%;
        background: #f3f4f6;
    }

    .hotel-card-m__media img,
    .hotel-card-m__placeholder {
        width: 100%;
        height: 100%;
        min-height: 320px;
        object-fit: cover;
        display: block;
    }

    .hotel-card-m__placeholder {
        display: flex;
        align-items: end;
        justify-content: start;
        padding: 1.5rem;
        background: linear-gradient(135deg, #d1d5db 0%, #9ca3af 100%);
        color: #111827;
        font-weight: 700;
        font-size: 1.1rem;
    }

    .hotel-card-m__body {
        padding: 1.4rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .hotel-card-m__topline {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: flex-start;
    }

    .hotel-card-m__eyebrow {
        font-size: 0.74rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: #6b7280;
        font-weight: 700;
        margin-bottom: 0.25rem;
    }

    .hotel-card-m__topline h3 {
        margin: 0;
        font-size: 2rem;
        line-height: 1.02;
        font-weight: 500;
        color: #111827;
    }

    .hotel-card-m__rating {
        margin-top: 0.55rem;
        color: #4b5563;
        font-size: 0.95rem;
        display: flex;
        gap: 0.45rem;
        flex-wrap: wrap;
        align-items: center;
    }

    .stars-m {
        color: #b45309;
        letter-spacing: 0.04em;
    }

    .hotel-card-m__pricebox {
        text-align: right;
        min-width: 150px;
        border-left: 1px solid #e5e7eb;
        padding-left: 1rem;
    }

    .hotel-card-m__pricebox strong {
        display: block;
        font-size: 1.9rem;
        line-height: 1;
        letter-spacing: -0.03em;
        color: #111827;
        font-weight: 600;
    }

    .hotel-card-m__pricebox small {
        color: #6b7280;
    }

    .hotel-card-m__total,
    .room-mini-m__total {
        margin-top: 0.35rem;
        color: #374151;
        font-size: 0.86rem;
        font-weight: 700;
    }

    .hotel-card-m__meta-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.8rem;
    }

    .meta-box-m {
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 18px;
        padding: 0.95rem 1rem;
    }

    .meta-box-m strong {
        font-size: 1rem;
        color: #111827;
    }

    .meta-box-m--wide {
        grid-column: 1 / -1;
    }

    .hotel-card-m__room-strip {
        border-top: 1px solid #eceff3;
        border-bottom: 1px solid #eceff3;
        padding: 1rem 0;
    }

    .room-strip-m__title {
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: #6b7280;
        font-weight: 700;
        margin-bottom: 0.75rem;
    }

    .room-strip-m__items {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 0.7rem;
    }

    .room-mini-m {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 0.9rem;
    }

    .room-mini-m__name {
        font-weight: 700;
        color: #111827;
        margin-bottom: 0.15rem;
    }

    .room-mini-m__detail,
    .room-mini-m__price {
        color: #6b7280;
        font-size: 0.92rem;
    }

    .room-mini-m__price {
        margin-top: 0.2rem;
        color: #111827;
        font-weight: 700;
    }

    .hotel-card-m__footer {
        margin-top: auto;
        display: flex;
        justify-content: flex-end;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .empty-state-m {
        background: #fff;
        border: 1px dashed #d1d5db;
        border-radius: 24px;
        padding: 2.5rem 1.5rem;
        text-align: center;
    }

    .empty-state-m h3 {
        margin-bottom: 0.5rem;
        color: #111827;
        font-weight: 600;
    }

