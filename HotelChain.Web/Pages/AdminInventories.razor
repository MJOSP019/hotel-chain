@page "/admin/inventories"
@using System.Net.Http.Headers
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Forms
@inject HttpClient Http
@inject IJSRuntime JS

<h3>Administración de inventario</h3>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success">@successMessage</div>
}

<div class="row">
    <div class="col-md-5">
        <div class="card p-3">
            <h5>Actualizar disponibilidad por rango</h5>
            <p class="text-muted mb-3">
                Este módulo administra la disponibilidad diaria de una habitación individual.
                Para una habitación física, la cantidad total permitida por fecha es 0 o 1.
            </p>

            <div class="mb-2">
                <label>Hotel</label>
                <select class="form-select" @bind="selectedHotelId" @bind:after="OnHotelChanged">
                    <option value="0">Seleccione un hotel</option>
                    @foreach (var hotel in hotels)
                    {
                        <option value="@hotel.Id">@hotel.Name</option>
                    }
                </select>
            </div>

            <div class="mb-2">
                <label>Habitación</label>
                <select class="form-select" @bind="model.RoomId" @bind:after="OnRoomChanged">
                    <option value="0">Seleccione una habitación</option>
                    @foreach (var room in filteredRooms)
                    {
                        <option value="@room.Id">@($"{room.NameOrNumber} - {room.RoomTypeName}")</option>
                    }
                </select>
                @if (selectedHotelId > 0 && !filteredRooms.Any())
                {
                    <small class="text-muted">Este hotel no tiene habitaciones activas disponibles para administrar inventario.</small>
                }
            </div>

            <div class="mb-2">
                <label>Fecha inicio</label>
                <InputDate @bind-Value="startDateValue" class="form-control" />
            </div>

            <div class="mb-2">
                <label>Fecha fin</label>
                <InputDate @bind-Value="endDateValue" class="form-control" />
            </div>

            <div class="mb-3">
                <label>Disponibilidad total por día</label>
                <input type="number" min="0" max="1" class="form-control" @bind="model.QuantityTotal" />
                <small class="text-muted">Use 1 para disponible y 0 para bloqueada/no disponible.</small>
            </div>

            <div class="d-flex gap-2">
                <button class="btn btn-primary me-2" @onclick="SaveInventory">
                    Guardar
                </button>

                <button class="btn btn-secondary" @onclick="ResetForm">
                    Limpiar
                </button>
            </div>
        </div>

        @if (selectedRoom is not null)
        {
            <div class="card p-3 mt-3">
                <h5>Resumen de habitación</h5>
                <div class="mb-2"><strong>Hotel:</strong> @selectedRoom.HotelName</div>
                <div class="mb-2"><strong>Habitación:</strong> @selectedRoom.NameOrNumber</div>
                <div class="mb-2"><strong>Tipo:</strong> @selectedRoom.RoomTypeName</div>
                <div class="mb-2"><strong>Capacidad:</strong> @selectedRoom.MaxGuests huésped(es)</div>
                <div class="mb-0"><strong>Precio base:</strong> Q @selectedRoom.BasePricePerNight.ToString("0.00")</div>
            </div>
        }
    </div>

    <div class="col-md-7">
        <div class="card p-3">
            <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                <div>
                    <h5 class="mb-1">Disponibilidad de la habitación</h5>
                    @if (selectedRoom is not null)
                    {
                        <div class="text-muted">
                            @selectedRoom.NameOrNumber · @selectedRoom.RoomTypeName
                        </div>
                    }
                </div>

                @if (inventoryItems.Any())
                {
                    <div class="text-muted">
                        Registros: @inventoryItems.Count
                    </div>
                }
            </div>

            @if (model.RoomId <= 0)
            {
                <p>Selecciona una habitación para ver su inventario.</p>
            }
            else if (inventoryItems.Count == 0)
            {
                <p>No hay inventario para mostrar para esta habitación.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped align-middle">
                        <thead>
                            <tr>
                                <th>Fecha</th>
                                <th>Total</th>
                                <th>Reservadas</th>
                                <th>Disponibles</th>
                                <th>Estado</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in inventoryItems)
                            {
                                <tr>
                                    <td>@item.Date.ToString("yyyy-MM-dd")</td>
                                    <td>@item.QuantityTotal</td>
                                    <td>@item.QuantityReserved</td>
                                    <td>@item.QuantityAvailable</td>
                                    <td>
                                        <span class="@GetAvailabilityBadgeClass(item)">
                                            @GetAvailabilityText(item)
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .inventory-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.35rem 0.7rem;
        border-radius: 999px;
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.02em;
    }

    .inventory-badge--available {
        background: #dcfce7;
        color: #166534;
    }

    .inventory-badge--blocked {
        background: #fee2e2;
        color: #991b1b;
    }

    .inventory-badge--partial {
        background: #fef3c7;
        color: #92400e;
    }
</style>

@code {
    private List<HotelOption> hotels = new();
    private List<RoomOption> rooms = new();
    private List<RoomOption> filteredRooms = new();
    private List<AdminRoomInventoryDto> inventoryItems = new();

    private UpsertRoomInventoryRangeRequest model = new();
    private int selectedHotelId = 0;

    private DateTime? startDateValue = DateTime.Today;
    private DateTime? endDateValue = DateTime.Today.AddDays(7);

    private string? errorMessage;
    private string? successMessage;

    private RoomOption? selectedRoom =>
        rooms.FirstOrDefault(x => x.Id == model.RoomId);

    protected override async Task OnInitializedAsync()
    {
        await SetToken();
        await LoadHotels();
        await LoadRooms();
    }

    private async Task SetToken()
    {
        var token = await JS.InvokeAsync<string>("auth.getToken");
        Http.DefaultRequestHeaders.Authorization =
            new AuthenticationHeaderValue("Bearer", token);
    }

    private async Task LoadHotels()
    {
        try
        {
            errorMessage = null;
            hotels = await Http.GetFromJsonAsync<List<HotelOption>>("api/admin/hotels") ?? new();
        }
        catch
        {
            errorMessage = "No se pudieron cargar los hoteles.";
        }
    }

    private async Task LoadRooms()
    {
        try
        {
            errorMessage = null;
            rooms = await Http.GetFromJsonAsync<List<RoomOption>>("api/admin/rooms") ?? new();
        }
        catch
        {
            errorMessage = "No se pudieron cargar las habitaciones.";
        }
    }

    private async Task OnHotelChanged()
    {
        filteredRooms = rooms
            .Where(x => x.HotelId == selectedHotelId && x.IsActive)
            .OrderBy(x => x.NameOrNumber)
            .ToList();

        model.RoomId = 0;
        inventoryItems.Clear();
        successMessage = null;
        await Task.CompletedTask;
    }

    private async Task OnRoomChanged()
    {
        successMessage = null;
        await LoadInventory();
    }

    private async Task LoadInventory()
    {
        try
        {
            errorMessage = null;

            if (model.RoomId <= 0)
            {
                inventoryItems.Clear();
                return;
            }

            inventoryItems = await Http.GetFromJsonAsync<List<AdminRoomInventoryDto>>(
                $"api/admin/room-inventories?roomId={model.RoomId}") ?? new();
        }
        catch
        {
            errorMessage = "No se pudo cargar el inventario.";
        }
    }

    private async Task SaveInventory()
    {
        errorMessage = null;
        successMessage = null;

        if (selectedHotelId <= 0)
        {
            errorMessage = "Debe seleccionar un hotel.";
            return;
        }

        if (model.RoomId <= 0)
        {
            errorMessage = "Debe seleccionar una habitación.";
            return;
        }

        if (!startDateValue.HasValue)
        {
            errorMessage = "Debe ingresar una fecha de inicio válida.";
            return;
        }

        if (!endDateValue.HasValue)
        {
            errorMessage = "Debe ingresar una fecha fin válida.";
            return;
        }

        var startDate = startDateValue.Value.Date;
        var endDate = endDateValue.Value.Date;

        if (endDate < startDate)
        {
            errorMessage = "La fecha fin no puede ser menor que la fecha inicio.";
            return;
        }

        if (model.QuantityTotal < 0)
        {
            errorMessage = "La cantidad total no puede ser negativa.";
            return;
        }

        if (model.QuantityTotal > 1)
        {
            errorMessage = "Para una habitación individual, la disponibilidad total no puede ser mayor que 1.";
            return;
        }

        var request = new UpsertRoomInventoryRangeRequest
        {
            RoomId = model.RoomId,
            StartDate = startDate,
            EndDate = endDate,
            QuantityTotal = model.QuantityTotal
        };

        try
        {
            var response = await Http.PostAsJsonAsync("api/admin/room-inventories/upsert-range", request);

            if (response.IsSuccessStatusCode)
            {
                successMessage = "Inventario actualizado correctamente.";
                await LoadInventory();
                return;
            }

            errorMessage = await response.Content.ReadAsStringAsync();
        }
        catch
        {
            errorMessage = "Ocurrió un error al guardar el inventario.";
        }
    }

    private void ResetForm()
    {
        selectedHotelId = 0;
        model = new UpsertRoomInventoryRangeRequest();
        filteredRooms.Clear();
        inventoryItems.Clear();
        startDateValue = DateTime.Today;
        endDateValue = DateTime.Today.AddDays(7);
        errorMessage = null;
        successMessage = null;
    }

    private static string GetAvailabilityText(AdminRoomInventoryDto item)
    {
        if (item.QuantityTotal <= 0)
            return "Bloqueada";

        if (item.QuantityAvailable <= 0)
            return "Sin cupo";

        if (item.QuantityReserved > 0)
            return "Parcial";

        return "Disponible";
    }

    private static string GetAvailabilityBadgeClass(AdminRoomInventoryDto item)
    {
        if (item.QuantityTotal <= 0 || item.QuantityAvailable <= 0)
            return "inventory-badge inventory-badge--blocked";

        if (item.QuantityReserved > 0)
            return "inventory-badge inventory-badge--partial";

        return "inventory-badge inventory-badge--available";
    }

    public class HotelOption
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
    }

    public class RoomOption
    {
        public int Id { get; set; }
        public int HotelId { get; set; }
        public string HotelName { get; set; } = string.Empty;
        public int RoomTypeId { get; set; }
        public string RoomTypeName { get; set; } = string.Empty;
        public string NameOrNumber { get; set; } = string.Empty;
        public int MaxGuests { get; set; }
        public decimal BasePricePerNight { get; set; }
        public bool IsActive { get; set; }
    }

    public class AdminRoomInventoryDto
    {
        public int Id { get; set; }
        public int RoomId { get; set; }
        public string RoomNameOrNumber { get; set; } = string.Empty;
        public int HotelId { get; set; }
        public string HotelName { get; set; } = string.Empty;
        public DateTime Date { get; set; }
        public int QuantityTotal { get; set; }
        public int QuantityReserved { get; set; }
        public int QuantityAvailable { get; set; }
    }

    public class UpsertRoomInventoryRangeRequest
    {
        public int RoomId { get; set; }
        public DateTime StartDate { get; set; }
        public DateTime EndDate { get; set; }
        public int QuantityTotal { get; set; }
    }
}