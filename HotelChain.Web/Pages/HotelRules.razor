        color: #111827;
        font-weight: 800;
        margin-bottom: 1rem;
    }

    .rule-card h4 {
        margin: 0 0 0.5rem 0;
        color: #111827;
        font-weight: 800;
    }

    .rule-card p {
        margin: 0;
        color: #4b5563;
        line-height: 1.65;
    }

    .rules-summary {
        margin-top: 1.6rem;
        grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .rules-summary__item {
        border-radius: 22px;
        padding: 1rem 1.1rem;
    }

    .rules-summary__label {
        display: block;
        margin-bottom: 0.3rem;
        color: #6b7280;
        font-size: 0.78rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .rules-summary__item strong {
        color: #111827;
        font-size: 1rem;
    }

    .info-highlight {
        margin-top: 1.6rem;
    }

    .info-highlight__content {
        border-radius: 28px;
        padding: 1.4rem;
        display: grid;
        grid-template-columns: 1.4fr 1fr;
        gap: 1rem;
        align-items: stretch;
    }

    .info-highlight__content h3 {
        margin: 0 0 0.45rem 0;
        font-weight: 800;
        color: #111827;
    }

    .info-highlight__content p {
        margin: 0;
        color: #4b5563;
        line-height: 1.65;
    }

    .info-highlight__box {
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 22px;
        padding: 1.1rem;
    }

    .info-highlight__label {
        font-size: 0.78rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #111827;
        margin-bottom: 0.45rem;
    }

    @@media (max-width: 1199.98px) {
        .rules-grid,
        .rules-summary {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 991.98px) {
        .info-hero {
            min-height: 360px;
        }

        .info-hero__content {
            padding: 1.5rem 1.2rem;
        }

        .rule-card--wide,
        .info-highlight__content {
            grid-template-columns: 1fr;
        }

        .rule-card--wide {
            grid-column: span 1;
        }

        .info-highlight__content {
            display: grid;
        }
    }

    @@media (max-width: 767.98px) {
        .rules-grid,
        .rules-summary {
            grid-template-columns: 1fr;
        }

        .info-hero h1 {
            font-size: 2.2rem;
        }
    }
    .info-section {
        margin-top: 1.6rem;
    }

    .info-section__header {
        margin-bottom: 1rem;
    }

    .info-section__header h3 {
        margin: 0;
        color: #111827;
        font-weight: 800;
    }

    .rules-summary-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1rem;
    }

    .rules-summary-card {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 22px;
        padding: 1rem;
        box-shadow: 0 18px 40px rgba(15, 23, 42, 0.07);
    }

    .rules-summary-card span {
        display: block;
        font-size: 0.78rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #6b7280;
        margin-bottom: 0.35rem;
    }

    .rules-summary-card strong {
        color: #111827;
    }

    @@media (max-width: 1199.98px) {
        .rules-summary-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 767.98px) {
        .rules-summary-grid {
            grid-template-columns: 1fr;
        }
    }

</style>