@page "/hotel-rules"

<PageTitle>Reglas del hotel</PageTitle>

<div class="rules-page">
    <section class="rules-hero">
        <div class="rules-hero__overlay"></div>

        <div class="rules-hero__content">
            <div class="rules-badge rules-badge--glass">Guía para huéspedes</div>
            <h1>Reglas del hotel</h1>
            <p>
                Conoce las políticas básicas que ayudan a mantener una experiencia segura, cómoda y respetuosa
                para todos los huéspedes durante su estadía en HotelChain Collection.
            </p>

            <div class="rules-hero__actions">
                <a class="rules-btn rules-btn--light" href="/checkout">Consultar mi reservación</a>
                <a class="rules-btn rules-btn--ghost" href="/check-in-checkout">Ver check-in y checkout</a>
            </div>
        </div>

        <div class="rules-hero__visual">
            <article class="rules-hero-card rules-hero-card--rest">
                <span>01</span>
                <strong>Convivencia y descanso</strong>
            </article>

            <article class="rules-hero-card rules-hero-card--security">
                <span>02</span>
                <strong>Seguridad y orden</strong>
            </article>

            <article class="rules-hero-card rules-hero-card--account">
                <span>03</span>
                <strong>Cuenta de estancia</strong>
            </article>
        </div>
    </section>

    <section class="rules-quick-strip">
        <article>
            <span>Convivencia</span>
            <strong>Respeto a otros huéspedes</strong>
        </article>

        <article>
            <span>Ocupación</span>
            <strong>Capacidad autorizada</strong>
        </article>

        <article>
            <span>Instalaciones</span>
            <strong>Uso responsable</strong>
        </article>

        <article>
            <span>Seguridad</span>
            <strong>Orden y cumplimiento</strong>
        </article>
    </section>

    <section class="rules-section">
        <div class="rules-section__header">
            <div>
                <div class="rules-badge">Normas generales</div>
                <h2>Lineamientos para una estadía segura y ordenada</h2>
                <p>
                    Estas reglas protegen la convivencia, el descanso, las instalaciones y la experiencia de todos
                    los huéspedes dentro del hotel.
                </p>
            </div>
        </div>

        <div class="rules-grid">
            @foreach (var rule in MainRules)
            {
                <article class="rule-card @(rule.IsWide ? "rule-card--wide" : "")">
                    <div class="rule-card__top">
                        <div class="rule-card__icon">@rule.Icon</div>
                        <span>@rule.Tag</span>
                    </div>
                    <h3>@rule.Title</h3>
                    <p>@rule.Description</p>
                </article>
            }
        </div>
    </section>

    <section class="responsibility-panel">
        <div class="responsibility-panel__image">
            <div class="responsibility-panel__caption">
                <span>Operación hotelera</span>
                <strong>Responsabilidades durante la estancia</strong>
            </div>
        </div>

        <div class="responsibility-panel__content">
            <div class="rules-badge">Durante tu visita</div>
            <h2>Responsabilidades que debes tener en cuenta</h2>
            <p>
                Además de las normas generales, algunos servicios o situaciones pueden requerir registro,
                validación o cargos adicionales en la cuenta de estancia.
            </p>

            <div class="responsibility-grid">
                @foreach (var item in Responsibilities)
                {
                    <article>
                        <span>@item.Tag</span>
                        <strong>@item.Title</strong>
                        <p>@item.Description</p>
                    </article>
                }
            </div>
        </div>
    </section>

    <section class="rules-section">
        <div class="rules-section__header">
            <div>
                <div class="rules-badge">Puntos clave</div>
                <h2>Reglas que más suelen impactar la estadía</h2>
                <p>
                    Ten presentes estos puntos para evitar inconvenientes durante el ingreso, la estancia o el cierre de tu hospedaje.
                </p>
            </div>
        </div>

        <div class="rules-summary-grid">
            @foreach (var item in QuickPoints)
            {
                <article class="rules-summary-card">
                    <span>@item.Tag</span>
                    <strong>@item.Title</strong>
                </article>
            }
        </div>
    </section>

    <section class="rules-cta">
        <div>
            <div class="rules-badge">Recomendación</div>
            <h2>Consulta a recepción si tienes dudas</h2>
            <p>
                Si tienes una solicitud especial, duda sobre horarios, visitantes, cargos o uso de instalaciones,
                acércate al personal del hotel para recibir orientación directa.
            </p>
        </div>

        <div class="rules-cta__actions">
            <a class="rules-btn rules-btn--dark" href="/checkout">Consultar mi reservación</a>
            <a class="rules-btn rules-btn--secondary" href="/search">Buscar hoteles</a>
        </div>
    </section>
</div>

@code {
    private List<RuleVm> MainRules { get; } = new()
    {
        new(
            "✓",
            "Llegada y salida",
            "Check-in y check-out",
            "El ingreso y la salida deben realizarse dentro de los horarios establecidos por el hotel. Las solicitudes de ingreso temprano o salida tardía están sujetas a disponibilidad y política vigente.",
            true),
        new(
            "☾",
            "Convivencia",
            "Respeto al descanso",
            "Mantén niveles moderados de ruido, especialmente durante la noche, en habitaciones, pasillos y áreas compartidas.",
            false),
        new(
            "⌂",
            "Instalaciones",
            "Cuidado de habitaciones",
            "Las habitaciones, mobiliario, amenidades y equipos deben utilizarse de forma responsable. Daños o uso inadecuado pueden generar cargos adicionales.",
            false),
        new(
            "◎",
            "Ocupación",
            "Capacidad permitida",
            "La ocupación debe respetar el número de huéspedes autorizado según el tipo de habitación y la reservación confirmada.",
            false),
        new(
            "!",
            "Seguridad",
            "Conducta y seguridad",
            "No se permiten conductas que comprometan la seguridad, el orden interno o la experiencia de otros huéspedes.",
            false),
        new(
            "✦",
            "Áreas comunes",
            "Uso de áreas comunes",
            "Las áreas compartidas deben utilizarse respetando horarios, limpieza, capacidad, normas internas y recomendaciones del personal.",
            true)
    };

    private List<ResponsibilityVm> Responsibilities { get; } = new()
    {
        new("Visitantes", "Registro cuando aplique", "Los visitantes pueden requerir registro en recepción según la política de cada sede."),
        new("Consumos", "Cargos adicionales", "Restaurante, room service, minibar u otros servicios pueden agregarse a la cuenta de estancia."),
        new("Pertenencias", "Objetos personales", "El huésped es responsable de resguardar sus pertenencias durante la estadía."),
        new("Instalaciones", "Uso adecuado", "El mobiliario, equipo y áreas comunes deben utilizarse de forma responsable."),
    };

    private List<QuickPointVm> QuickPoints { get; } = new()
    {
        new("Ocupación", "Respetar capacidad de la habitación"),
        new("Convivencia", "Evitar ruido y molestias a otros huéspedes"),
        new("Seguridad", "Registrar visitantes cuando aplique"),
        new("Consumo", "Cargos adicionales pueden reflejarse al checkout")
    };

    private sealed record RuleVm(string Icon, string Tag, string Title, string Description, bool IsWide);
    private sealed record ResponsibilityVm(string Tag, string Title, string Description);
    private sealed record QuickPointVm(string Tag, string Title);
}

<style>
    .rules-page {
        color: #0f172a;
        padding-bottom: 2.5rem;
    }

    .rules-hero {
        position: relative;
        display: grid;
        grid-template-columns: minmax(0, 1.1fr) minmax(380px, 0.9fr);
        gap: 1.4rem;
        min-height: 430px;
        border-radius: 32px;
        overflow: hidden;
        padding: 2rem;
        margin-bottom: 1.3rem;
        background:
            linear-gradient(110deg, rgba(15, 23, 42, 0.88) 0%, rgba(15, 23, 42, 0.66) 48%, rgba(15, 23, 42, 0.26) 100%),
            url('https://res.cloudinary.com/ds7fyjtcc/image/upload/f_auto,q_auto,c_fill,g_auto,w_1600,h_900/v1777220511/AmenitiesSalaEspera_mymp92.jpg') center/cover no-repeat;
        box-shadow: 0 26px 70px rgba(15, 23, 42, 0.18);
    }

    .rules-hero__overlay {
        position: absolute;
        inset: 0;
        background:
            radial-gradient(circle at 20% 20%, rgba(255,255,255,.16), transparent 32%),
            linear-gradient(180deg, rgba(255,255,255,.03), rgba(15,23,42,.18));
        pointer-events: none;
    }

    .rules-hero__content,
    .rules-hero__visual {
        position: relative;
        z-index: 1;
    }

    .rules-hero__content {
        color: #ffffff;
        display: flex;
        flex-direction: column;
        justify-content: center;
        max-width: 760px;
    }

    .rules-badge {
        display: inline-flex;
        width: max-content;
        align-items: center;
        padding: 0.4rem 0.78rem;
        border-radius: 999px;
        background: #ffffff;
        color: #334155;
        border: 1px solid #e2e8f0;
        font-size: 0.76rem;
        font-weight: 900;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        margin-bottom: 0.9rem;
    }

    .rules-badge--glass {
        background: rgba(255,255,255,.16);
        color: rgba(255,255,255,.96);
        border-color: rgba(255,255,255,.18);
        backdrop-filter: blur(8px);
    }

    .rules-hero h1,
    .rules-section__header h2,
    .responsibility-panel__content h2,
    .rules-cta h2 {
        margin: 0;
        letter-spacing: -0.035em;
        line-height: 1.02;
        font-weight: 950;
    }

    .rules-hero h1 {
        font-size: clamp(2.8rem, 6vw, 5rem);
        max-width: 740px;
    }

    .rules-hero p {
        max-width: 690px;
        margin: 1rem 0 0;
        color: rgba(255,255,255,.92);
        line-height: 1.75;
        font-size: 1.03rem;
    }

    .rules-hero__actions,
    .rules-cta__actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-top: 1.5rem;
    }

    .rules-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 44px;
        padding: 0.8rem 1.15rem;
        border-radius: 999px;
        font-weight: 900;
        text-decoration: none;
        border: 1px solid transparent;
        transition: all .18s ease;
    }

    .rules-btn--light {
        background: #ffffff;
        color: #0f172a;
    }

    .rules-btn--ghost {
        background: rgba(255,255,255,.08);
        color: #ffffff;
        border-color: rgba(255,255,255,.34);
    }

    .rules-btn--dark {
        background: #0f172a;
        color: #ffffff;
    }

    .rules-btn--secondary {
        background: #ffffff;
        color: #0f172a;
        border-color: #cbd5e1;
    }

    .rules-btn:hover {
        transform: translateY(-1px);
    }

    .rules-btn--light:hover,
    .rules-btn--secondary:hover {
        color: #0f172a;
        background: #f8fafc;
    }

    .rules-btn--ghost:hover,
    .rules-btn--dark:hover {
        color: #ffffff;
        opacity: .95;
    }

    .rules-hero__visual {
        display: grid;
        gap: 0.85rem;
        align-content: center;
    }

    .rules-hero-card {
        position: relative;
        overflow: hidden;
        min-height: 116px;
        border-radius: 24px;
        border: 1px solid rgba(255,255,255,.26);
        box-shadow: 0 18px 38px rgba(15,23,42,.20);
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        padding: 1rem;
        color: #ffffff;
    }

    .rules-hero-card::before,
    .responsibility-panel__image::before {
        content: "";
        position: absolute;
        inset: 0;
        background-size: cover;
        background-position: center;
        transition: transform .3s ease;
    }

    .rules-hero-card::after,
    .responsibility-panel__image::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, rgba(15,23,42,.04), rgba(15,23,42,.62));
    }

    .rules-hero-card:hover::before,
    .responsibility-panel__image:hover::before {
        transform: scale(1.04);
    }

    .rules-hero-card--rest::before {
        background-image: url('https://res.cloudinary.com/ds7fyjtcc/image/upload/f_auto,q_auto,c_fill,g_auto,w_900,h_500/v1777220507/AmenitiesAreaSocial_wkmpqq.jpg');
    }

    .rules-hero-card--security::before {
        background-image: url('https://res.cloudinary.com/ds7fyjtcc/image/upload/f_auto,q_auto,c_fill,g_auto,w_900,h_500/v1777220508/AmenitiesMostrador_qflglt.jpg');
    }

    .rules-hero-card--account::before {
        background-image: url('https://res.cloudinary.com/ds7fyjtcc/image/upload/f_auto,q_auto,c_fill,g_auto,w_900,h_500/v1777220512/AmenitiesServicioMesa_lje42y.jpg');
    }

    .rules-hero-card span,
    .rules-hero-card strong,
    .responsibility-panel__caption {
        position: relative;
        z-index: 1;
    }

    .rules-hero-card span {
        width: 34px;
        height: 34px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        background: rgba(255,255,255,.18);
        font-weight: 900;
        margin-bottom: 0.45rem;
        backdrop-filter: blur(8px);
    }

    .rules-hero-card strong {
        font-size: 1.1rem;
        line-height: 1.15;
    }

    .rules-quick-strip {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 0.9rem;
        margin-bottom: 1.8rem;
    }

    .rules-quick-strip article,
    .rule-card,
    .responsibility-panel,
    .responsibility-grid article,
    .rules-summary-card,
    .rules-cta {
        background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
        border: 1px solid #e2e8f0;
        box-shadow: 0 16px 36px rgba(15, 23, 42, 0.07);
    }

    .rules-quick-strip article {
        border-radius: 22px;
        padding: 1rem;
    }

    .rules-quick-strip span,
    .rule-card__top span,
    .responsibility-grid span,
    .rules-summary-card span {
        display: block;
        color: #64748b;
        font-size: 0.75rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-bottom: 0.25rem;
    }

    .rules-quick-strip strong,
    .rules-summary-card strong {
        color: #0f172a;
        font-size: 1rem;
    }

    .rules-section {
        margin-top: 1.8rem;
    }

    .rules-section__header {
        margin-bottom: 1rem;
    }

    .rules-section__header h2,
    .responsibility-panel__content h2,
    .rules-cta h2 {
        font-size: clamp(1.9rem, 3vw, 3.1rem);
        color: #0f172a;
    }

    .rules-section__header p,
    .responsibility-panel__content > p,
    .rules-cta p {
        max-width: 860px;
        color: #475569;
        line-height: 1.7;
        margin: 0.65rem 0 0;
    }

    .rules-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
    }

    .rule-card {
        border-radius: 26px;
        padding: 1.25rem;
        min-height: 210px;
        display: flex;
        flex-direction: column;
    }

    .rule-card--wide {
        grid-column: span 2;
    }

    .rule-card__top {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: flex-start;
        margin-bottom: 1rem;
    }

    .rule-card__icon {
        width: 44px;
        height: 44px;
        border-radius: 15px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #eef2ff;
        color: #1d4ed8;
        font-weight: 950;
        flex: 0 0 auto;
    }

    .rule-card h3 {
        margin: 0 0 0.55rem;
        color: #0f172a;
        font-weight: 950;
        font-size: 1.45rem;
        line-height: 1.1;
    }

    .rule-card p,
    .responsibility-grid p {
        margin: 0;
        color: #475569;
        line-height: 1.68;
    }

    .responsibility-panel {
        display: grid;
        grid-template-columns: 0.9fr 1.1fr;
        gap: 1rem;
        border-radius: 30px;
        padding: 1rem;
        margin-top: 2rem;
        overflow: hidden;
    }

    .responsibility-panel__image {
        position: relative;
        min-height: 390px;
        border-radius: 24px;
        overflow: hidden;
        background: #e2e8f0;
    }

    .responsibility-panel__image::before {
        background-image: url('https://res.cloudinary.com/ds7fyjtcc/image/upload/f_auto,q_auto,c_fill,g_auto,w_1000,h_900/v1777220513/AmenitiesLounge_nescsa.jpg');
    }

    .responsibility-panel__caption {
        position: absolute;
        left: 1rem;
        right: 1rem;
        bottom: 1rem;
        color: #ffffff;
        z-index: 2;
    }

    .responsibility-panel__caption span {
        display: inline-flex;
        padding: .25rem .65rem;
        border-radius: 999px;
        background: rgba(255,255,255,.18);
        font-size: .72rem;
        font-weight: 900;
        letter-spacing: .06em;
        text-transform: uppercase;
        margin-bottom: .45rem;
    }

    .responsibility-panel__caption strong {
        display: block;
        font-size: 1.45rem;
        line-height: 1.1;
    }

    .responsibility-panel__content {
        padding: 1.1rem;
        align-self: center;
    }

    .responsibility-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: .85rem;
        margin-top: 1rem;
    }

    .responsibility-grid article {
        border-radius: 20px;
        padding: 1rem;
    }

    .responsibility-grid strong {
        display: block;
        margin-bottom: .35rem;
        color: #0f172a;
        font-size: 1rem;
    }

    .rules-summary-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1rem;
    }

    .rules-summary-card {
        border-radius: 22px;
        padding: 1rem;
        min-height: 105px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .rules-cta {
        border-radius: 30px;
        padding: 1.35rem;
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 1rem;
        align-items: center;
        margin-top: 2rem;
        border-color: #bfdbfe;
        background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
    }

    .rules-cta__actions {
        margin: 0;
        justify-content: flex-end;
    }

    @@media (max-width: 1100px) {
        .rules-hero,
        .responsibility-panel,
        .rules-cta {
            grid-template-columns: 1fr;
        }

        .rules-quick-strip,
        .rules-summary-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .rules-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .rule-card--wide {
            grid-column: span 1;
        }

        .rules-cta__actions {
            justify-content: flex-start;
        }
    }

    @@media (max-width: 720px) {
        .rules-hero {
            padding: 1.1rem;
            border-radius: 24px;
            min-height: auto;
        }

        .rules-hero h1 {
            font-size: 2.6rem;
        }

        .rules-hero__visual,
        .rules-quick-strip,
        .rules-grid,
        .responsibility-grid,
        .rules-summary-grid {
            grid-template-columns: 1fr;
        }

        .responsibility-panel__image {
            min-height: 280px;
        }
    }
</style>
