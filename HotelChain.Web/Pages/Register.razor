@page "/register"
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Registro</PageTitle>

<div class="auth-page">
    <section class="auth-hero auth-hero--register">
        <div class="auth-hero__overlay"></div>

        <div class="auth-hero__content">
            <div class="auth-eyebrow">Acceso · Registro</div>
            <h1>Crea tu cuenta en HotelChain Collection</h1>
            <p>
                Regístrate para reservar habitaciones, gestionar tu checkout,
                consultar tus compras y dejar comentarios dentro del portal.
            </p>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(success))
    {
        <div class="alert alert-success auth-alert">@success</div>
    }

    @if (!string.IsNullOrWhiteSpace(error))
    {
        <div class="alert alert-danger auth-alert auth-alert--multiline">@error</div>
    }

    <section class="auth-layout auth-layout--register">
        <div class="auth-main-card">
            <div class="auth-main-card__header">
                <div class="auth-section-badge">Registro de huésped</div>
                <h2>Completa tus datos</h2>
                <p>Llena la información requerida por el backend actual para crear tu cuenta.</p>
            </div>

            <div class="auth-form-grid">
                <div class="auth-field">
                    <label class="auth-label">Email</label>
                    <input class="form-control auth-input" @bind="email" placeholder="correo@ejemplo.com" />
                </div>

                <div class="auth-field">
                    <label class="auth-label">Password</label>
                    <input type="password" class="form-control auth-input" @bind="password" placeholder="Tu contraseña" />
                </div>

                <div class="auth-field">
                    <label class="auth-label">Nombre</label>
                    <input class="form-control auth-input" @bind="firstName" />
                </div>

                <div class="auth-field">
                    <label class="auth-label">Apellido</label>
                    <input class="form-control auth-input" @bind="lastName" />
                </div>

                <div class="auth-field">
                    <label class="auth-label">Edad</label>
                    <input type="number" class="form-control auth-input" min="1" @bind="age" />
                </div>

                <div class="auth-field">
                    <label class="auth-label">País</label>
                    <input class="form-control auth-input" @bind="country" />
                </div>

                <div class="auth-field auth-field--full">
                    <label class="auth-label">No. Pasaporte</label>
                    <input class="form-control auth-input" @bind="passportNumber" />
                </div>
            </div>

            <div class="captcha-card">
                <div class="captcha-card__header">
                    <div>
                        <div class="auth-section-badge">Captcha</div>
                        <h3>Verificación simple</h3>
                        <p>Genera y responde el captcha antes de registrar tu cuenta.</p>
                    </div>

                    <button class="btn auth-btn-secondary" @onclick="LoadCaptcha" type="button">
                        Generar captcha
                    </button>
                </div>

                @if (!string.IsNullOrWhiteSpace(captchaQuestion))
                {
                    <div class="captcha-question">
                        @captchaQuestion
                    </div>

                    <div class="captcha-answer">
                        <label class="auth-label">Respuesta</label>
                        <input class="form-control auth-input" @bind="captchaAnswer" />
                    </div>
                }
            </div>

            <div class="auth-actions">
                <button class="btn auth-btn-primary" @onclick="DoRegister" disabled="@isLoading">
                    @(isLoading ? "Registrando..." : "Registrar")
                </button>

                <a class="btn auth-btn-secondary" href="/login">
                    Ya tengo cuenta
                </a>
            </div>
        </div>

        <aside class="auth-side-panel">
            <div class="auth-side-panel__intro">
                <div class="auth-section-badge">Beneficios</div>
                <h3>Tu cuenta unifica toda tu experiencia en la cadena</h3>
                <p>
                    Al registrarte podrás asociar reservaciones a tu usuario
                    y continuar el flujo dentro del mismo portal.
                </p>
            </div>

            <div class="auth-feature-list">
                <article class="auth-feature-card">
                    <div class="auth-feature-card__icon">⌕</div>
                    <div>
                        <h4>Reservaciones vinculadas</h4>
                        <p>Tu cuenta permite consultar el historial y gestionar tus compras.</p>
                    </div>
                </article>

                <article class="auth-feature-card">
                    <div class="auth-feature-card__icon">✓</div>
                    <div>
                        <h4>Checkout y PDF</h4>
                        <p>Podrás confirmar reservas y abrir la confirmación generada por el sistema.</p>
                    </div>
                </article>

                <article class="auth-feature-card">
                    <div class="auth-feature-card__icon">★</div>
                    <div>
                        <h4>Comentarios y calificaciones</h4>
                        <p>Después de iniciar sesión podrás publicar opiniones en hoteles.</p>
                    </div>
                </article>
            </div>

            <div class="auth-side-panel__footer">
                <span class="auth-side-panel__footer-label">¿Ya tienes cuenta?</span>
                <a href="/login" class="auth-inline-link">Inicia sesión aquí</a>
            </div>
        </aside>
    </section>
</div>

<style>
    .auth-page {
        color: #111827;
    }

    .auth-hero {
        position: relative;
        min-height: 320px;
        border-radius: 30px;
        overflow: hidden;
        margin-bottom: 1.5rem;
        box-shadow: 0 24px 60px rgba(15, 23, 42, 0.14);
        display: flex;
        align-items: flex-end;
    }

    .auth-hero--register {
        background:
            linear-gradient(180deg, rgba(17,24,39,0.12), rgba(17,24,39,0.40)),
            radial-gradient(circle at top right, rgba(255,255,255,0.14), transparent 24%),
            linear-gradient(135deg, #b9c8b2 0%, #d9dfcb 26%, #d8c7ae 54%, #718c86 100%);
    }

    .auth-hero__overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, rgba(255,255,255,0.03), transparent 25%, rgba(17,24,39,0.10) 100%);
        pointer-events: none;
    }

    .auth-hero__content {
        position: relative;
        z-index: 1;
        max-width: 760px;
        padding: 2rem;
        color: #ffffff;
    }

    .auth-eyebrow,
    .auth-section-badge {
        display: inline-flex;
        align-items: center;
        padding: 0.38rem 0.78rem;
        border-radius: 999px;
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0.05em;
        text-transform: uppercase;
    }

    .auth-eyebrow {
        background: rgba(255,255,255,0.14);
        color: rgba(255,255,255,0.94);
        margin-bottom: 1rem;
        backdrop-filter: blur(8px);
    }

    .auth-section-badge {
        background: #f3f4f6;
        color: #111827;
        margin-bottom: 0.8rem;
    }

    .auth-hero__content h1 {
        margin: 0 0 0.8rem 0;
        font-size: clamp(2.1rem, 5vw, 3.6rem);
        line-height: 1.02;
        font-weight: 800;
        letter-spacing: -0.02em;
    }

    .auth-hero__content p {
        margin: 0;
        max-width: 700px;
        font-size: 1.02rem;
        line-height: 1.7;
        color: rgba(255,255,255,0.88);
    }

    .auth-alert {
        border-radius: 16px;
        margin-bottom: 1rem;
    }

    .auth-alert--multiline {
        white-space: pre-line;
    }

    .auth-layout {
        display: grid;
        grid-template-columns: minmax(340px, 1.05fr) minmax(280px, 0.95fr);
        gap: 1rem;
        align-items: start;
    }

    .auth-layout--register {
        align-items: stretch;
    }

    .auth-main-card,
    .auth-side-panel {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 24px;
        box-shadow: 0 14px 35px rgba(15, 23, 42, 0.07);
    }

    .auth-main-card {
        padding: 1.5rem;
    }

    .auth-side-panel {
        padding: 1.4rem;
        background: linear-gradient(180deg, #ffffff 0%, #f9fafb 100%);
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .auth-main-card__header h2,
    .auth-side-panel__intro h3,
    .captcha-card__header h3 {
        margin: 0 0 0.3rem 0;
        color: #111827;
        font-weight: 800;
    }

    .auth-main-card__header p,
    .auth-side-panel__intro p,
    .captcha-card__header p {
        margin: 0;
        color: #6b7280;
        line-height: 1.6;
    }

    .auth-form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .auth-field--full {
        grid-column: span 2;
    }

    .auth-label {
        display: block;
        margin-bottom: 0.45rem;
        font-size: 0.92rem;
        font-weight: 700;
        color: #374151;
    }

    .auth-input {
        min-height: 54px;
        border-radius: 16px;
        border: 1px solid #d1d5db;
        background: #ffffff;
        color: #111827;
    }

    .auth-input:focus {
        border-color: #111827;
        box-shadow: 0 0 0 0.15rem rgba(17, 24, 39, 0.10);
    }

    .captcha-card {
        margin-top: 1.25rem;
        padding: 1.1rem;
        border-radius: 22px;
        border: 1px solid #e5e7eb;
        background: linear-gradient(180deg, #ffffff 0%, #f9fafb 100%);
    }

    .captcha-card__header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .captcha-question {
        margin-top: 0.85rem;
        padding: 1rem;
        border-radius: 18px;
        background: #f8fbff;
        border: 1px solid #dbeafe;
        color: #1f2937;
        font-weight: 700;
    }

    .captcha-answer {
        margin-top: 1rem;
    }

    .auth-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-top: 1.25rem;
    }

    .auth-btn-primary {
        background: #111111;
        color: #ffffff;
        border: 1px solid #111111;
        border-radius: 999px;
        padding: 0.82rem 1.35rem;
        font-weight: 700;
        min-height: 50px;
        box-shadow: 0 12px 24px rgba(17, 17, 17, 0.16);
    }

    .auth-btn-primary:hover,
    .auth-btn-primary:focus {
        background: #000000;
        color: #ffffff;
        border-color: #000000;
    }

    .auth-btn-secondary {
        background: #ffffff;
        color: #111827;
        border: 1px solid #d1d5db;
        border-radius: 999px;
        padding: 0.82rem 1.35rem;
        font-weight: 700;
        min-height: 50px;
        text-decoration: none;
    }

    .auth-btn-secondary:hover,
    .auth-btn-secondary:focus {
        background: #f9fafb;
        color: #111827;
        border-color: #9ca3af;
    }

    .auth-feature-list {
        display: grid;
        gap: 0.9rem;
    }

    .auth-feature-card {
        display: grid;
        grid-template-columns: 52px 1fr;
        gap: 0.9rem;
        align-items: start;
        padding: 1rem;
        border-radius: 20px;
        background: rgba(255,255,255,0.9);
        border: 1px solid #e5e7eb;
    }

    .auth-feature-card__icon {
        width: 52px;
        height: 52px;
        border-radius: 18px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #f3f4f6;
        color: #111827;
        border: 1px solid #e5e7eb;
        font-size: 1.05rem;
        font-weight: 800;
    }

    .auth-feature-card h4 {
        margin: 0 0 0.2rem 0;
        font-size: 1rem;
        color: #111827;
        font-weight: 800;
    }

    .auth-feature-card p {
        margin: 0;
        color: #6b7280;
        line-height: 1.55;
        font-size: 0.95rem;
    }

    .auth-side-panel__footer {
        margin-top: auto;
        padding-top: 0.3rem;
    }

    .auth-side-panel__footer-label {
        display: block;
        color: #6b7280;
        margin-bottom: 0.25rem;
        font-size: 0.92rem;
    }

    .auth-inline-link {
        color: #111827;
        font-weight: 700;
        text-decoration: none;
        border-bottom: 1px solid #cbd5e1;
    }

    .auth-inline-link:hover {
        color: #000000;
        border-bottom-color: #111827;
    }

    @@media (max-width: 991.98px) {
        .auth-layout {
            grid-template-columns: 1fr;
        }

        .auth-hero__content {
            padding: 1.5rem 1.2rem;
        }
    }

    @@media (max-width: 767.98px) {
        .auth-form-grid {
            grid-template-columns: 1fr;
        }

        .auth-field--full {
            grid-column: span 1;
        }

        .auth-hero__content h1 {
            font-size: 2.2rem;
        }

        .auth-main-card,
        .auth-side-panel {
            padding: 1.1rem;
        }

        .captcha-card {
            padding: 1rem;
        }
    }
</style>

@code {
    string email = "";
    string password = "";

    string firstName = "";
    string lastName = "";
    int age = 18;
    string country = "GT";
    string passportNumber = "";

    string captchaId = "";
    string captchaQuestion = "";
    string captchaAnswer = "";

    string? error;
    string? success;

    bool isLoading;

    protected override async Task OnInitializedAsync()
    {
        await LoadCaptcha();
    }

    async Task LoadCaptcha()
    {
        error = null;

        try
        {
            var data = await Http.GetFromJsonAsync<CaptchaResponse>("/api/auth/captcha");
            captchaId = data!.captchaId;
            captchaQuestion = data.question;
            captchaAnswer = "";
        }
        catch (Exception ex)
        {
            error = "No se pudo cargar captcha: " + ex.Message;
        }
    }

    async Task DoRegister()
    {
        error = null;
        success = null;

        if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
        {
            error = "Email y password son requeridos.";
            return;
        }

        if (string.IsNullOrWhiteSpace(firstName) || string.IsNullOrWhiteSpace(lastName))
        {
            error = "Nombre y apellido son requeridos.";
            return;
        }

        if (age <= 0)
        {
            error = "Edad inválida.";
            return;
        }

        if (string.IsNullOrWhiteSpace(country))
        {
            error = "País es requerido.";
            return;
        }

        if (string.IsNullOrWhiteSpace(passportNumber))
        {
            error = "No. Pasaporte es requerido.";
            return;
        }

        if (string.IsNullOrWhiteSpace(captchaAnswer))
        {
            error = "Resuelve el captcha.";
            return;
        }

        isLoading = true;

        try
        {
            var body = new
            {
                email,
                password,
                firstName,
                lastName,
                age,
                country,
                passportNumber,
                captchaId,
                captchaAnswer
            };

            var resp = await Http.PostAsJsonAsync("/api/auth/register", body);

            if (!resp.IsSuccessStatusCode)
            {
                var raw = await resp.Content.ReadAsStringAsync();
                error = raw;

                try
                {
                    var details = System.Text.Json.JsonSerializer.Deserialize<ValidationProblem>(
                        raw,
                        new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });

                    if (details?.errors != null && details.errors.Count > 0)
                    {
                        error = string.Join("\n", details.errors.SelectMany(e => e.Value));
                    }
                }
                catch
                {
                }

                await LoadCaptcha();
                return;
            }

            success = "Usuario creado correctamente.";
            Nav.NavigateTo("/login");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    class CaptchaResponse
    {
        public string captchaId { get; set; } = "";
        public string question { get; set; } = "";
    }

    class ValidationProblem
    {
        public Dictionary<string, string[]> errors { get; set; } = new();
    }
}