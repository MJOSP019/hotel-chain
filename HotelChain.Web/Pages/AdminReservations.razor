    .admin-res-room-option { border:1px solid #e2e8f0; border-radius:16px; padding:1rem 1rem 1rem 2.4rem; background:#f8fafc; }
</style>

@code {
    private List<AdminReservationDto>? reservations;
    private string? errorMessage;
    private string? successMessage;
    private int? cancelingReservationId;

    private string? selectedStatusFilter;
    private string? selectedHotelFilter;
    private string quickFilter = "";
    private string? searchFilter;
    private DateTime? fromDate;
    private DateTime? toDate;
    private int currentPage = 1;
    private int pageSize = 25;

    private AdminReservationDto? selectedReservation;

    private bool showDetailModal;
    private List<AdminReservationAuditDto> audits = new();
    private bool auditsLoading;

    private bool showCheckInModal;
    private List<AdminAvailableRoomDto> availableRooms = new();
    private bool availableRoomsLoading;
    private int? selectedCheckInRoomId;
    private string? checkInError;
    private bool isCheckingIn;

    private bool showChangeDatesModal;
    private DateTime? changeCheckIn;
    private DateTime? changeCheckOut;
    private string changeReason = "";
    private string? changeError;

    private bool showChargesModal;
    private List<ReservationChargeDto> charges = new();
    private decimal chargesBaseAmount;
    private decimal chargesTotal;
    private decimal chargesSettledTotal;
    private decimal chargesOutstandingTotal;
    private decimal chargesGrandTotal;
    private bool isStayAccountSettled;
    private string newChargeCategory = "ROOM_SERVICE";
    private string newChargeDescription = "";
    private decimal? newChargeAmount;
    private string? chargesError;
    private string? chargesSuccess;
    private bool isSavingCharge;
    private int? isVoidingChargeId;
    private bool isSettlingCharges;
    private string settlementCardNumber = "";
    private string settlementCvv = "";
    private string settlementCardHolderName = "";
    private string settlementBillingAddress = "";

    private List<string> HotelOptions =>
        (reservations ?? new())
            .Select(r => r.Hotel)
            .Where(h => !string.IsNullOrWhiteSpace(h))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(h => h)
            .ToList();

    private List<AdminReservationDto> FilteredReservations =>
        (reservations ?? new())
            .Where(MatchesFilters)
            .OrderByDescending(r => r.CheckIn)
            .ThenByDescending(r => r.CreatedAt)
            .ToList();

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(FilteredReservations.Count / (double)Math.Max(1, pageSize)));
    private int CurrentPage => Math.Min(Math.Max(1, currentPage), TotalPages);

    private List<AdminReservationDto> PagedReservations =>
        FilteredReservations
            .Skip((CurrentPage - 1) * pageSize)
            .Take(pageSize)
            .ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadReservations();
    }

    private async Task LoadReservations()
    {
        try
        {
            errorMessage = null;
            var token = await JS.InvokeAsync<string>("auth.getToken");
            if (string.IsNullOrWhiteSpace(token))
            {
                errorMessage = "No hay token. Inicia sesión como admin.";
                return;
            }

            Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
            reservations = await Http.GetFromJsonAsync<List<AdminReservationDto>>("/api/admin/reservations") ?? new();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error cargando reservaciones: {ex.Message}";
        }
    }

    private bool MatchesFilters(AdminReservationDto r)
    {
        if (!string.IsNullOrWhiteSpace(selectedHotelFilter) &&
            !string.Equals(r.Hotel, selectedHotelFilter, StringComparison.OrdinalIgnoreCase))
            return false;

        if (!string.IsNullOrWhiteSpace(selectedStatusFilter) && r.Status != selectedStatusFilter)
            return false;

        if (fromDate.HasValue && r.CheckIn.Date < fromDate.Value.Date)
            return false;

        if (toDate.HasValue && r.CheckIn.Date > toDate.Value.Date)
            return false;

        if (!string.IsNullOrWhiteSpace(quickFilter))
        {
            var matchesQuick = quickFilter switch
            {
                "ARRIVALS_TODAY" => IsArrivalToday(r),
                "DEPARTURES_TODAY" => IsDepartureToday(r),
                "IN_HOUSE" => r.Status == "CHECKED_IN",
                "PENDING_ACCOUNT" => r.OutstandingChargesTotal > 0,
                "PENDING_PAYMENT" => !r.IsPaid,
                "NO_ROOM" => r.Status == "CONFIRMED" && !HasAssignedRoom(r),
                _ => true
            };

            if (!matchesQuick)
                return false;
        }

        if (!string.IsNullOrWhiteSpace(searchFilter))
        {
            var text = $"{r.Code} {r.Hotel} {r.RoomType} {r.AssignedRoomName} {GetGuestName(r)} {r.GuestEmail} {r.GuestPassportNumber} {r.GuestCountry}";
            if (!text.Contains(searchFilter, StringComparison.OrdinalIgnoreCase))
                return false;
        }

        return true;
    }

    private void ShowAllReservations() => SetQuickFilter("");
    private void ShowArrivalsToday() => SetQuickFilter("ARRIVALS_TODAY");
    private void ShowDeparturesToday() => SetQuickFilter("DEPARTURES_TODAY");
    private void ShowInHouse() => SetQuickFilter("IN_HOUSE");
    private void ShowPendingAccount() => SetQuickFilter("PENDING_ACCOUNT");

    private void SetQuickFilter(string value)
    {
        quickFilter = value;
        currentPage = 1;
    }

    private void ClearFilters()
    {
        selectedHotelFilter = null;
        selectedStatusFilter = null;
        quickFilter = "";
        searchFilter = null;
        fromDate = null;
        toDate = null;
        currentPage = 1;
    }

    private void PreviousPage()
    {
        if (CurrentPage > 1)
            currentPage = CurrentPage - 1;
    }

    private void NextPage()
    {
        if (CurrentPage < TotalPages)
            currentPage = CurrentPage + 1;
    }

    private async Task OpenDetailModal(AdminReservationDto reservation)
    {
        selectedReservation = reservation;
        showDetailModal = true;
        await LoadAudits(reservation.Id);
    }

    private void CloseDetailModal()
    {
        showDetailModal = false;
        audits = new();
        selectedReservation = null;
    }

    private async Task LoadAudits(int reservationId)
    {
        try
        {
            auditsLoading = true;
            var token = await JS.InvokeAsync<string>("auth.getToken");
            Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
            audits = await Http.GetFromJsonAsync<List<AdminReservationAuditDto>>($"/api/admin/reservations/{reservationId}/audits") ?? new();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error cargando historial: {ex.Message}";
        }
        finally
        {
            auditsLoading = false;
        }
    }

    private async Task OpenCheckInModal(AdminReservationDto reservation)
    {
        selectedReservation = reservation;
        selectedCheckInRoomId = null;
        checkInError = null;
        showCheckInModal = true;
        await LoadAvailableRooms(reservation.Id);
    }

    private void CloseCheckInModal()
    {
        showCheckInModal = false;
        availableRooms = new();
        selectedCheckInRoomId = null;
        checkInError = null;
        selectedReservation = null;
    }

    private async Task LoadAvailableRooms(int reservationId)
    {
        try
        {
            availableRoomsLoading = true;
            var token = await JS.InvokeAsync<string>("auth.getToken");
            Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
            availableRooms = await Http.GetFromJsonAsync<List<AdminAvailableRoomDto>>($"/api/admin/reservations/{reservationId}/available-rooms") ?? new();
        }
        catch (Exception ex)
        {
            checkInError = $"Error cargando habitaciones disponibles: {ex.Message}";
        }
        finally
        {
            availableRoomsLoading = false;
        }
    }

    private async Task ConfirmCheckIn()
    {
        if (selectedReservation is null)
            return;

        try
        {
            isCheckingIn = true;
            checkInError = null;
            errorMessage = null;
            successMessage = null;

            var token = await JS.InvokeAsync<string>("auth.getToken");
            Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
            var response = await Http.PostAsJsonAsync($"/api/admin/reservations/{selectedReservation.Id}/check-in", new AdminCheckInRequest
            {
                RoomId = selectedCheckInRoomId
            });

            if (!response.IsSuccessStatusCode)
            {
                checkInError = await response.Content.ReadAsStringAsync();
                return;
            }

            var code = selectedReservation.Code;
            CloseCheckInModal();
            successMessage = $"Check-in registrado correctamente ({code}).";
            await LoadReservations();
        }
        catch (Exception ex)
        {
            checkInError = $"Error registrando check-in: {ex.Message}";
        }
        finally
        {
            isCheckingIn = false;
        }
    }

    private async Task CancelReservation(AdminReservationDto reservation)
    {
        try
        {
            errorMessage = null;
            successMessage = null;

            var reason = await JS.InvokeAsync<string?>("prompt", $"Motivo de cancelación para la reserva {reservation.Code}:", "Cancelación administrativa");
            if (reason is null)
                return;

            if (string.IsNullOrWhiteSpace(reason))
            {
                errorMessage = "Debes ingresar un motivo de cancelación.";
                return;
            }

            cancelingReservationId = reservation.Id;

            var token = await JS.InvokeAsync<string>("auth.getToken");
            if (string.IsNullOrWhiteSpace(token))
            {
                errorMessage = "No hay token. Inicia sesión como admin.";
                return;
            }

            Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
            var response = await Http.PostAsJsonAsync($"/api/admin/reservations/{reservation.Id}/cancel", new AdminCancelReservationRequest { Reason = reason });

            if (!response.IsSuccessStatusCode)
            {
                errorMessage = await response.Content.ReadAsStringAsync();
                return;
            }

            successMessage = $"Reserva {reservation.Code} cancelada correctamente.";
            await LoadReservations();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error cancelando reservación: {ex.Message}";
        }
        finally
        {
            cancelingReservationId = null;
        }
    }

    private void OpenChangeDatesModal(AdminReservationDto reservation)
    {
        selectedReservation = reservation;
        changeCheckIn = reservation.CheckIn.Date;
        changeCheckOut = reservation.CheckOut.Date;
        changeReason = "";
        changeError = null;
        showChangeDatesModal = true;
    }

    private void CloseChangeDatesModal()
    {
        showChangeDatesModal = false;
        selectedReservation = null;
        changeCheckIn = null;
        changeCheckOut = null;
        changeReason = "";
        changeError = null;
    }

    private async Task ConfirmChangeDates()
    {
        if (!changeCheckIn.HasValue)
        {
            changeError = "Ingresa un check-in válido.";
            return;
        }

        if (!changeCheckOut.HasValue)
        {
            changeError = "Ingresa un check-out válido.";
            return;
        }

        var checkIn = changeCheckIn.Value.Date;
        var checkOut = changeCheckOut.Value.Date;

        if (checkOut <= checkIn)
        {
            changeError = "El check-out debe ser mayor al check-in.";
            return;
        }

        if (string.IsNullOrWhiteSpace(changeReason))
        {
            changeError = "Debes ingresar un motivo.";
            return;
        }

        try
        {
            changeError = null;
            errorMessage = null;
            successMessage = null;

            var token = await JS.InvokeAsync<string>("auth.getToken");
            if (string.IsNullOrWhiteSpace(token))
            {
                changeError = "No hay token. Inicia sesión como admin.";
                return;
            }

            Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
            var response = await Http.PostAsJsonAsync($"/api/admin/reservations/{selectedReservation!.Id}/change-dates", new AdminChangeReservationDatesRequest
            {
                CheckIn = checkIn,
                CheckOut = checkOut,
                Reason = changeReason
            });

            if (!response.IsSuccessStatusCode)
            {
                changeError = await response.Content.ReadAsStringAsync();
                return;
            }

            var code = selectedReservation.Code;
            CloseChangeDatesModal();
            successMessage = $"Fechas actualizadas correctamente para la reserva {code}.";
            await LoadReservations();
        }
        catch (Exception ex)
        {
            changeError = $"Error cambiando fechas: {ex.Message}";
        }
    }

    private async Task CheckOutReservation(AdminReservationDto reservation)
        => await PostAdminAction($"/api/admin/reservations/{reservation.Id}/check-out", reservation.Code, "Check-out registrado correctamente");

    private async Task MarkNoShow(AdminReservationDto reservation)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"¿Marcar la reserva {reservation.Code} como NO-SHOW?");
        if (!confirmed)
            return;

        await PostAdminAction($"/api/admin/reservations/{reservation.Id}/no-show", reservation.Code, "Reserva marcada como no-show");
    }

    private async Task PostAdminAction(string url, string code, string successText)
    {
        try
        {
            errorMessage = null;
            successMessage = null;

            var token = await JS.InvokeAsync<string>("auth.getToken");
            if (string.IsNullOrWhiteSpace(token))
            {
                errorMessage = "No hay token. Inicia sesión como admin.";
                return;
            }

            Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
            var response = await Http.PostAsync(url, null);
            if (!response.IsSuccessStatusCode)
            {
                errorMessage = await response.Content.ReadAsStringAsync();
                return;
            }

            successMessage = $"{successText} ({code}).";
            await LoadReservations();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error ejecutando acción administrativa: {ex.Message}";
        }
    }

    private async Task OpenChargesModal(AdminReservationDto reservation)
    {
        selectedReservation = reservation;
        showChargesModal = true;
        chargesError = null;
        chargesSuccess = null;
        newChargeCategory = "ROOM_SERVICE";
        newChargeDescription = "";
        newChargeAmount = null;
        ResetSettlementForm();
        await LoadCharges();
    }

    private void CloseChargesModal()
    {
        showChargesModal = false;
        charges = new();
        chargesError = null;
        chargesSuccess = null;
        newChargeDescription = "";
        newChargeAmount = null;
        ResetSettlementForm();
        selectedReservation = null;
    }

    private async Task LoadCharges()
    {
        if (selectedReservation is null)
            return;

        try
        {
            var token = await JS.InvokeAsync<string>("auth.getToken");
            if (string.IsNullOrWhiteSpace(token))
            {
                chargesError = "No hay token. Inicia sesión como admin.";
                return;
            }

            Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
            var response = await Http.GetFromJsonAsync<ReservationChargesResponse>($"/api/admin/reservations/{selectedReservation.Id}/charges");
            if (response is null)
            {
                chargesError = "No se pudo cargar la cuenta de estancia.";
                return;
            }

            charges = response.Charges ?? new();
            chargesBaseAmount = response.BaseAmount;
            chargesTotal = response.ChargesTotal;
            chargesSettledTotal = response.SettledChargesTotal;
            chargesOutstandingTotal = response.OutstandingChargesTotal;
            chargesGrandTotal = response.GrandTotal;
            isStayAccountSettled = response.IsStayAccountSettled;
        }
        catch (Exception ex)
        {
            chargesError = $"Error cargando cargos: {ex.Message}";
        }
    }

    private async Task AddCharge()
    {
        if (selectedReservation is null)
            return;

        if (!newChargeAmount.HasValue || newChargeAmount.Value <= 0 || string.IsNullOrWhiteSpace(newChargeDescription))
        {
            chargesError = "Ingresa categoría, descripción y monto válidos.";
            return;
        }

        try
        {
            isSavingCharge = true;
            chargesError = null;
            chargesSuccess = null;

            var token = await JS.InvokeAsync<string>("auth.getToken");
            Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
            var response = await Http.PostAsJsonAsync($"/api/admin/reservations/{selectedReservation.Id}/charges", new
            {
                category = newChargeCategory,
                description = newChargeDescription,
                amount = newChargeAmount.Value
            });

            if (!response.IsSuccessStatusCode)
            {
                chargesError = await response.Content.ReadAsStringAsync();
                return;
            }

            chargesSuccess = "Cargo agregado correctamente.";
            newChargeDescription = "";
            newChargeAmount = null;
            await LoadCharges();
            await LoadReservations();
        }
        catch (Exception ex)
        {
            chargesError = $"Error agregando cargo: {ex.Message}";
        }
        finally
        {
            isSavingCharge = false;
        }
    }

    private async Task VoidCharge(int chargeId)
    {
        try
        {
            isVoidingChargeId = chargeId;
            chargesError = null;
            chargesSuccess = null;

            var token = await JS.InvokeAsync<string>("auth.getToken");
            Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
            var response = await Http.PostAsync($"/api/admin/reservations/charges/{chargeId}/void", null);
            if (!response.IsSuccessStatusCode)
            {
                chargesError = await response.Content.ReadAsStringAsync();
                return;
            }

            chargesSuccess = "Cargo anulado correctamente.";
            await LoadCharges();
            await LoadReservations();
        }
        catch (Exception ex)
        {
            chargesError = $"Error anulando cargo: {ex.Message}";
        }
        finally
        {
            isVoidingChargeId = null;
        }
    }

    private async Task SettleCharges()
    {
        if (selectedReservation is null)
            return;

        if (chargesOutstandingTotal <= 0)
        {
            chargesError = "La cuenta no tiene cargos pendientes de liquidar.";
            return;
        }

        if (string.IsNullOrWhiteSpace(settlementCardNumber) || string.IsNullOrWhiteSpace(settlementCvv) ||
            string.IsNullOrWhiteSpace(settlementCardHolderName) || string.IsNullOrWhiteSpace(settlementBillingAddress))
        {
            chargesError = "Completa número de tarjeta, CVV, nombre y dirección de cobro.";
            return;
        }

        var cardDigits = new string(settlementCardNumber.Where(char.IsDigit).ToArray());
        var cvvDigits = new string(settlementCvv.Where(char.IsDigit).ToArray());

        if (cardDigits.Length < 13 || cardDigits.Length > 19)
        {
            chargesError = "El número de tarjeta debe tener entre 13 y 19 dígitos.";
            return;
        }

        if (cvvDigits.Length < 3 || cvvDigits.Length > 4)
        {
            chargesError = "El CVV debe tener 3 o 4 dígitos.";
            return;
        }

        try
        {
            isSettlingCharges = true;
            chargesError = null;
            chargesSuccess = null;

            var token = await JS.InvokeAsync<string>("auth.getToken");
            Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
            var response = await Http.PostAsJsonAsync($"/api/admin/reservations/{selectedReservation.Id}/charges/settle", new SettleChargesRequest
            {
                CardNumber = cardDigits,
                Cvv = cvvDigits,
                CardHolderName = settlementCardHolderName.Trim(),
                BillingAddress = settlementBillingAddress.Trim(),
                Amount = chargesOutstandingTotal
            });

            if (!response.IsSuccessStatusCode)
            {
                chargesError = await response.Content.ReadAsStringAsync();
                return;
            }

            chargesSuccess = "Pago procesado y cuenta liquidada correctamente.";
            ResetSettlementForm();
            await LoadCharges();
            await LoadReservations();
        }
        catch (Exception ex)
        {
            chargesError = $"Error liquidando cuenta: {ex.Message}";
        }
        finally
        {
            isSettlingCharges = false;
        }
    }

    private void ResetSettlementForm()
    {
        settlementCardNumber = "";
        settlementCvv = "";
        settlementCardHolderName = "";
        settlementBillingAddress = "";
    }

    private void GoToHotel(int hotelId) => Navigation.NavigateTo($"/hotels/{hotelId}");
    private void GoToCheckout(string code) => Navigation.NavigateTo($"/checkout?code={code}");

    private static bool CanAddCharges(AdminReservationDto reservation) => reservation.Status == "CHECKED_IN";
    private static bool CanVoidCharges(AdminReservationDto reservation) => reservation.Status != "CHECKED_OUT" && reservation.Status != "CANCELED" && reservation.Status != "NO_SHOW" && reservation.Status != "EXPIRED";
    private static bool CanCheckOut(AdminReservationDto reservation) => reservation.Status == "CHECKED_IN" && reservation.OutstandingChargesTotal <= 0;
    private static bool CanSettleCharges(AdminReservationDto reservation) => reservation.Status == "CHECKED_IN";
    private static bool CanChangeDates(AdminReservationDto reservation) => reservation.Status == "PENDING" || reservation.Status == "CONFIRMED";
    private static bool CanCancel(AdminReservationDto reservation) => reservation.Status == "PENDING" || reservation.Status == "CONFIRMED";

    private static bool CanCheckIn(AdminReservationDto reservation)
    {
        var today = DateTime.Now.Date;
        return reservation.Status == "CONFIRMED"
               && today >= reservation.CheckIn.Date
               && today < reservation.CheckOut.Date;
    }

    private static bool CanMarkNoShow(AdminReservationDto reservation)
    {
        var today = DateTime.Now.Date;
        return reservation.Status == "CONFIRMED"
               && today >= reservation.CheckIn.Date
               && today < reservation.CheckOut.Date;
    }

    private static bool IsArrivalToday(AdminReservationDto reservation)
    {
        var today = DateTime.Now.Date;
        return reservation.CheckIn.Date == today && reservation.Status == "CONFIRMED";
    }

    private static bool IsDepartureToday(AdminReservationDto reservation)
    {
        var today = DateTime.Now.Date;
        return reservation.CheckOut.Date == today && reservation.Status == "CHECKED_IN";
    }

    private static bool HasAssignedRoom(AdminReservationDto reservation)
        => !string.IsNullOrWhiteSpace(reservation.AssignedRoomName)
           && reservation.AssignedRoomName != "-"
           && !reservation.AssignedRoomName.Equals("Sin asignar", StringComparison.OrdinalIgnoreCase);

    private static string GetGuestName(AdminReservationDto reservation)
    {
        var fullName = $"{reservation.GuestFirstName} {reservation.GuestLastName}".Trim();
        return string.IsNullOrWhiteSpace(fullName) ? "Huésped sin nombre" : fullName;
    }

    private static string GetGuestDetails(AdminReservationDto reservation)
    {
        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(reservation.GuestCountry))
            parts.Add(reservation.GuestCountry);

        if (!string.IsNullOrWhiteSpace(reservation.GuestPassportNumber))
            parts.Add($"Pasaporte: {reservation.GuestPassportNumber}");

        if (parts.Count == 0 && reservation.UserId.HasValue)
            parts.Add($"Usuario: {reservation.UserId}");

        return parts.Count == 0 ? "-" : string.Join(" · ", parts);
    }

    private static string GetStatusBadgeClass(string status) => status switch
    {
        "PENDING" => "status-badge status-badge--pending",
        "CONFIRMED" => "status-badge status-badge--confirmed",
        "CHECKED_IN" => "status-badge status-badge--inhouse",
        "CHECKED_OUT" => "status-badge status-badge--default",
        "NO_SHOW" => "status-badge status-badge--cancelled",
        "CANCELED" => "status-badge status-badge--cancelled",
        "CANCELLED" => "status-badge status-badge--cancelled",
        "EXPIRED" => "status-badge status-badge--cancelled",
        _ => "status-badge status-badge--default"
    };

    private static string GetPaymentText(AdminReservationDto reservation)
    {
        if (!reservation.IsPaid)
            return reservation.PaymentStatus ?? "Pendiente";

        if (!string.IsNullOrWhiteSpace(reservation.PaymentStatus))
            return reservation.PaymentStatus!;

        return "Pagada";
    }

