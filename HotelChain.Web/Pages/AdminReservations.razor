@page "/admin/reservations"
@using System.Net.Http.Headers
@using System.Net.Http.Json
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Navigation

<h3>Administración de reservaciones</h3>
<p class="text-muted admin-res-intro">
    Panel operativo tipo hotel/PMS: llegadas, salidas, huéspedes en casa, cuenta de estancia, historial y asignación física de habitación.
</p>

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success admin-res-alert">@successMessage</div>
}

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger admin-res-alert">@errorMessage</div>
}

@if (reservations is null)
{
    <div class="admin-res-loading">
        <div class="admin-res-loading__card">
            <h4>Cargando reservaciones...</h4>
            <p>Estamos obteniendo el historial administrativo desde el backend.</p>
        </div>
    </div>
}
else
{
    <div class="admin-res-summary-grid mb-4">
        <button type="button" class="admin-res-summary-card admin-res-summary-card--button" @onclick="ShowAllReservations">
            <span class="admin-res-summary-card__label">Total</span>
            <strong class="admin-res-summary-card__value">@reservations.Count</strong>
        </button>

        <button type="button" class="admin-res-summary-card admin-res-summary-card--button" @onclick="ShowArrivalsToday">
            <span class="admin-res-summary-card__label">Llegadas hoy</span>
            <strong class="admin-res-summary-card__value">@reservations.Count(IsArrivalToday)</strong>
        </button>

        <button type="button" class="admin-res-summary-card admin-res-summary-card--button" @onclick="ShowDeparturesToday">
            <span class="admin-res-summary-card__label">Salidas hoy</span>
            <strong class="admin-res-summary-card__value">@reservations.Count(IsDepartureToday)</strong>
        </button>

        <button type="button" class="admin-res-summary-card admin-res-summary-card--button" @onclick="ShowInHouse">
            <span class="admin-res-summary-card__label">En casa</span>
            <strong class="admin-res-summary-card__value">@reservations.Count(x => x.Status == "CHECKED_IN")</strong>
        </button>

        <button type="button" class="admin-res-summary-card admin-res-summary-card--button" @onclick="ShowPendingAccount">
            <span class="admin-res-summary-card__label">Cuenta pendiente</span>
            <strong class="admin-res-summary-card__value">@reservations.Count(x => x.OutstandingChargesTotal > 0)</strong>
        </button>
    </div>

    <div class="admin-res-panel mb-3">
        <div class="admin-res-panel__header">
            <div>
                <h5>Filtros operativos</h5>
                <p>Usa vistas rápidas para recepción: llegadas, salidas, huéspedes alojados y cuentas pendientes.</p>
            </div>
            <button class="btn admin-res-btn-secondary btn-sm" @onclick="LoadReservations">Actualizar</button>
        </div>

        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Hotel</label>
                <select class="form-select" @bind="selectedHotelFilter">
                    <option value="">Todos los hoteles</option>
                    @foreach (var hotel in HotelOptions)
                    {
                        <option value="@hotel">@hotel</option>
                    }
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label">Estado</label>
                <select class="form-select" @bind="selectedStatusFilter">
                    <option value="">Todos</option>
                    <option value="PENDING">PENDING</option>
                    <option value="CONFIRMED">CONFIRMED</option>
                    <option value="CHECKED_IN">CHECKED_IN</option>
                    <option value="CHECKED_OUT">CHECKED_OUT</option>
                    <option value="NO_SHOW">NO_SHOW</option>
                    <option value="CANCELED">CANCELED</option>
                    <option value="CANCELLED">CANCELLED</option>
                    <option value="EXPIRED">EXPIRED</option>
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label">Vista rápida</label>
                <select class="form-select" @bind="quickFilter">
                    <option value="">Todas</option>
                    <option value="ARRIVALS_TODAY">Llegadas de hoy</option>
                    <option value="DEPARTURES_TODAY">Salidas de hoy</option>
                    <option value="IN_HOUSE">Huéspedes en casa</option>
                    <option value="PENDING_ACCOUNT">Cuenta pendiente</option>
                    <option value="PENDING_PAYMENT">Pendientes de pago</option>
                    <option value="NO_ROOM">Confirmadas sin habitación asignada</option>
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label">Desde check-in</label>
                <InputDate @bind-Value="fromDate" class="form-control" />
            </div>

            <div class="col-md-2">
                <label class="form-label">Hasta check-in</label>
                <InputDate @bind-Value="toDate" class="form-control" />
            </div>

            <div class="col-md-6">
                <label class="form-label">Buscar</label>
                <input class="form-control" @bind="searchFilter" placeholder="Código, huésped, correo, pasaporte, hotel, habitación..." />
            </div>

            <div class="col-md-2">
                <label class="form-label">Registros por página</label>
                <select class="form-select" @bind="pageSize">
                    <option value="10">10</option>
                    <option value="25">25</option>
                    <option value="50">50</option>
                </select>
            </div>

            <div class="col-md-4 d-flex gap-2">
                <button class="btn admin-res-btn-info" @onclick="() => currentPage = 1">Aplicar filtros</button>
                <button class="btn admin-res-btn-secondary" @onclick="ClearFilters">Limpiar filtros</button>
            </div>
        </div>

        <div class="admin-res-filter-footer">
            Mostrando <strong>@PagedReservations.Count</strong> de <strong>@FilteredReservations.Count</strong> reservación(es).
            Página <strong>@CurrentPage</strong> de <strong>@TotalPages</strong>.
        </div>
    </div>

    @if (FilteredReservations.Count == 0)
    {
        <div class="admin-res-empty">No hay reservaciones que coincidan con los filtros actuales.</div>
    }
    else
    {
        <div class="admin-res-table-card">
            <div class="table-responsive">
                <table class="table align-middle admin-res-table">
                    <thead>
                        <tr>
                            <th>Reserva</th>
                            <th>Huésped</th>
                            <th>Estancia</th>
                            <th>Habitación</th>
                            <th>Cuenta</th>
                            <th>Estado</th>
                            <th class="admin-res-actions-col">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in PagedReservations)
                        {
                            <tr>
                                <td>
                                    <strong>@r.Code</strong>
                                    <div class="text-muted small">@r.Hotel</div>
                                    <div class="text-muted small">Creada: @r.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                                </td>
                                <td>
                                    <strong>@GetGuestName(r)</strong>
                                    <div class="text-muted small">@GetGuestDetails(r)</div>
                                    @if (!string.IsNullOrWhiteSpace(r.GuestEmail))
                                    {
                                        <div class="text-muted small">@r.GuestEmail</div>
                                    }
                                </td>
                                <td>
                                    <strong>@r.CheckIn.ToString("dd/MM/yyyy") → @r.CheckOut.ToString("dd/MM/yyyy")</strong>
                                    <div class="text-muted small">@r.Nights noche(s), @r.Guests huésped(es)</div>
                                </td>
                                <td>
                                    <strong>@(string.IsNullOrWhiteSpace(r.RoomType) ? "-" : r.RoomType)</strong>
                                    <div class="text-muted small">Física: @(HasAssignedRoom(r) ? r.AssignedRoomName : "Pendiente de check-in")</div>
                                </td>
                                <td>
                                    <strong>Q @r.GrandTotal.ToString("0.00")</strong>
                                    <div class="text-muted small">Base Q @r.BaseAmount.ToString("0.00") · Cargos Q @r.ChargesTotal.ToString("0.00")</div>
                                    @if (r.OutstandingChargesTotal > 0)
                                    {
                                        <span class="badge bg-warning text-dark">Pendiente Q @r.OutstandingChargesTotal.ToString("0.00")</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Cuenta liquidada</span>
                                    }
                                </td>
                                <td>
                                    <span class="@GetStatusBadgeClass(r.Status)">@r.Status</span>
                                    <div class="text-muted small mt-1">Pago: @GetPaymentText(r)</div>
                                </td>
                                <td>
                                    <div class="admin-res-actions">
                                        <button class="btn btn-sm admin-res-btn-secondary" @onclick="() => OpenDetailModal(r)">Detalle</button>
                                        <button class="btn btn-sm admin-res-btn-secondary" @onclick="() => GoToCheckout(r.Code)">Comprobante</button>
                                        <button class="btn btn-sm admin-res-btn-secondary" @onclick="() => OpenChargesModal(r)">Cuenta</button>
                                        <button class="btn btn-sm admin-res-btn-success" disabled="@(!CanCheckIn(r))" @onclick="() => OpenCheckInModal(r)">Check-in</button>
                                        <button class="btn btn-sm admin-res-btn-success" disabled="@(!CanCheckOut(r))" @onclick="() => CheckOutReservation(r)">Check-out</button>
                                        <button class="btn btn-sm admin-res-btn-warning" disabled="@(!CanMarkNoShow(r))" @onclick="() => MarkNoShow(r)">No-show</button>
                                        <button class="btn btn-sm admin-res-btn-info" disabled="@(!CanChangeDates(r))" @onclick="() => OpenChangeDatesModal(r)">Fechas</button>
                                        <button class="btn btn-sm admin-res-btn-danger" disabled="@(!CanCancel(r) || cancelingReservationId == r.Id)" @onclick="() => CancelReservation(r)">
                                            @(cancelingReservationId == r.Id ? "Cancelando..." : "Cancelar")
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="admin-res-pagination">
                <button class="btn admin-res-btn-secondary btn-sm" disabled="@(CurrentPage <= 1)" @onclick="PreviousPage">Anterior</button>
                <span>Página @CurrentPage de @TotalPages</span>
                <button class="btn admin-res-btn-secondary btn-sm" disabled="@(CurrentPage >= TotalPages)" @onclick="NextPage">Siguiente</button>
            </div>
        </div>
    }
}

@if (showDetailModal && selectedReservation is not null)
{
    <div class="admin-res-modal-backdrop">
        <div class="admin-res-modal-card admin-res-modal-card--wide">
            <div class="admin-res-modal-card__header">
                <div>
                    <h4>Detalle de reservación</h4>
                    <div class="text-muted">@selectedReservation.Code · @selectedReservation.Hotel</div>
                </div>
                <button type="button" class="admin-res-modal-close" @onclick="CloseDetailModal">×</button>
            </div>

            <div class="admin-res-modal-card__body">
                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <div class="admin-res-feature">
                            <span class="admin-res-feature__label">Huésped</span>
                            <strong>@GetGuestName(selectedReservation)</strong>
                            <div class="text-muted small">@GetGuestDetails(selectedReservation)</div>
                            <div class="text-muted small">@selectedReservation.GuestEmail</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="admin-res-feature">
                            <span class="admin-res-feature__label">Estancia</span>
                            <strong>@selectedReservation.CheckIn.ToString("dd/MM/yyyy") → @selectedReservation.CheckOut.ToString("dd/MM/yyyy")</strong>
                            <div class="text-muted small">@selectedReservation.Nights noche(s), @selectedReservation.Guests huésped(es)</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="admin-res-feature">
                            <span class="admin-res-feature__label">Habitación</span>
                            <strong>@selectedReservation.RoomType</strong>
                            <div class="text-muted small">Física: @(HasAssignedRoom(selectedReservation) ? selectedReservation.AssignedRoomName : "Pendiente")</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="admin-res-feature">
                            <span class="admin-res-feature__label">Pago inicial</span>
                            <strong>@GetPaymentText(selectedReservation)</strong>
                            @if (selectedReservation.IsPaid && !string.IsNullOrWhiteSpace(selectedReservation.CardLast4))
                            {
                                <div class="text-muted small">Tarjeta **** @selectedReservation.CardLast4</div>
                            }
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="admin-res-feature">
                            <span class="admin-res-feature__label">Cuenta estancia</span>
                            <strong>@(selectedReservation.IsStayAccountSettled ? "Liquidada" : "Pendiente")</strong>
                            <div class="text-muted small">Pendiente Q @selectedReservation.OutstandingChargesTotal.ToString("0.00")</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="admin-res-feature">
                            <span class="admin-res-feature__label">Total final</span>
                            <strong>Q @selectedReservation.GrandTotal.ToString("0.00")</strong>
                            <div class="text-muted small">Base + cargos no anulados</div>
                        </div>
                    </div>
                </div>

                <div class="admin-res-panel admin-res-panel--inner">
                    <div class="admin-res-panel__header">
                        <div>
                            <h5>Historial operativo</h5>
                            <p>Auditoría de cambios, cancelaciones, check-in, cargos, liquidación y check-out.</p>
                        </div>
                    </div>

                    @if (auditsLoading)
                    {
                        <p class="text-muted">Cargando historial...</p>
                    }
                    else if (audits.Count == 0)
                    {
                        <p class="text-muted mb-0">Aún no hay eventos de auditoría para esta reserva.</p>
                    }
                    else
                    {
                        <div class="admin-res-timeline">
                            @foreach (var audit in audits)
                            {
                                <div class="admin-res-timeline__item">
                                    <div class="admin-res-timeline__dot"></div>
                                    <div>
                                        <strong>@audit.Action</strong>
                                        <span class="text-muted small"> · @audit.CreatedAt.ToString("dd/MM/yyyy HH:mm") · @audit.Actor</span>
                                        <div class="text-muted small">
                                            @if (!string.IsNullOrWhiteSpace(audit.OldStatus) || !string.IsNullOrWhiteSpace(audit.NewStatus))
                                            {
                                                <span>@audit.OldStatus → @audit.NewStatus</span>
                                            }
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(audit.Reason))
                                        {
                                            <div>@audit.Reason</div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <div class="admin-res-modal-card__footer">
                <button class="btn admin-res-btn-secondary" @onclick="CloseDetailModal">Cerrar</button>
                <button class="btn admin-res-btn-secondary" @onclick="() => GoToCheckout(selectedReservation.Code)">Ver comprobante</button>
            </div>
        </div>
    </div>
}

@if (showCheckInModal && selectedReservation is not null)
{
    <div class="admin-res-modal-backdrop">
        <div class="admin-res-modal-card admin-res-modal-card--wide">
            <div class="admin-res-modal-card__header">
                <div>
                    <h4>Check-in y asignación de habitación</h4>
                    <div class="text-muted">@selectedReservation.Code · @selectedReservation.Hotel</div>
                </div>
                <button type="button" class="admin-res-modal-close" @onclick="CloseCheckInModal">×</button>
            </div>

            <div class="admin-res-modal-card__body">
                @if (!string.IsNullOrWhiteSpace(checkInError))
                {
                    <div class="alert alert-danger">@checkInError</div>
                }

                <p class="text-muted">
                    Selecciona una habitación física disponible para esta estancia. También puedes dejar asignación automática.
                </p>

                <div class="form-check admin-res-room-option">
                    <input class="form-check-input" type="radio" name="roomOption" checked="@(!selectedCheckInRoomId.HasValue)" @onchange="() => selectedCheckInRoomId = null" />
                    <label class="form-check-label">
                        <strong>Asignación automática</strong>
                        <span class="text-muted d-block">El sistema elegirá una habitación física disponible del tipo reservado.</span>
                    </label>
                </div>

                @if (availableRoomsLoading)
                {
                    <p class="text-muted">Cargando habitaciones disponibles...</p>
                }
                else if (availableRooms.Count == 0)
                {
                    <div class="alert alert-warning">No hay habitaciones físicas disponibles para seleccionar manualmente. Revisa inventario físico/comercial.</div>
                }
                else
                {
                    <div class="table-responsive mt-3">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th></th>
                                    <th>Habitación</th>
                                    <th>Tipo</th>
                                    <th>Capacidad</th>
                                    <th>Cama</th>
                                    <th>Área</th>
                                    <th>Tarifa ref.</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var room in availableRooms)
                                {
                                    <tr>
                                        <td>
                                            <input class="form-check-input" type="radio" name="roomOption" checked="@(selectedCheckInRoomId == room.Id)" @onchange="() => selectedCheckInRoomId = room.Id" />
                                        </td>
                                        <td><strong>@room.NameOrNumber</strong></td>
                                        <td>@room.RoomType</td>
                                        <td>@room.MaxGuests</td>
                                        <td>@(string.IsNullOrWhiteSpace(room.BedType) ? "-" : room.BedType)</td>
                                        <td>@(room.AreaSquareMeters.HasValue ? $"{room.AreaSquareMeters:0.##} m²" : "-")</td>
                                        <td>Q @room.BasePricePerNight.ToString("0.00")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            <div class="admin-res-modal-card__footer">
                <button class="btn admin-res-btn-secondary" @onclick="CloseCheckInModal">Cerrar</button>
                <button class="btn admin-res-btn-success" @onclick="ConfirmCheckIn" disabled="@isCheckingIn">
                    @(isCheckingIn ? "Registrando..." : "Confirmar check-in")
                </button>
            </div>
        </div>
    </div>
}

@if (showChangeDatesModal && selectedReservation is not null)
{
    <div class="admin-res-modal-backdrop">
        <div class="admin-res-modal-card">
            <div class="admin-res-modal-card__header">
                <div>
                    <h4>Cambiar fechas de reservación</h4>
                    <div class="text-muted">@selectedReservation.Code</div>
                </div>
                <button type="button" class="admin-res-modal-close" @onclick="CloseChangeDatesModal">×</button>
            </div>

            <div class="admin-res-modal-card__body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Nuevo check-in</label>
                        <InputDate @bind-Value="changeCheckIn" class="form-control" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Nuevo check-out</label>
                        <InputDate @bind-Value="changeCheckOut" class="form-control" />
                    </div>

                    <div class="col-12">
                        <label class="form-label">Motivo</label>
                        <textarea class="form-control" rows="4" @bind="changeReason"></textarea>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(changeError))
                {
                    <div class="alert alert-danger mt-3 mb-0">@changeError</div>
                }
            </div>

            <div class="admin-res-modal-card__footer">
                <button class="btn admin-res-btn-secondary" @onclick="CloseChangeDatesModal">Cerrar</button>
                <button class="btn admin-res-btn-info" @onclick="ConfirmChangeDates">Confirmar cambio</button>
            </div>
        </div>
    </div>
}

@if (showChargesModal && selectedReservation is not null)
{
    <div class="admin-res-modal-backdrop">
        <div class="admin-res-modal-card admin-res-modal-card--wide">
            <div class="admin-res-modal-card__header">
                <div>
                    <h4>Cuenta de estancia</h4>
                    <div class="text-muted">@selectedReservation.Code · @GetGuestName(selectedReservation)</div>
                </div>
                <button type="button" class="admin-res-modal-close" @onclick="CloseChargesModal">×</button>
            </div>

            <div class="admin-res-modal-card__body">
                @if (!string.IsNullOrWhiteSpace(chargesError))
                {
                    <div class="alert alert-danger">@chargesError</div>
                }

                @if (!string.IsNullOrWhiteSpace(chargesSuccess))
                {
                    <div class="alert alert-success">@chargesSuccess</div>
                }

                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <label class="form-label">Base</label>
                        <input class="form-control" value=@($"Q {chargesBaseAmount:0.00}") disabled />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Cargos</label>
                        <input class="form-control" value=@($"Q {chargesTotal:0.00}") disabled />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Total final</label>
                        <input class="form-control" value=@($"Q {chargesGrandTotal:0.00}") disabled />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Liquidado</label>
                        <input class="form-control" value=@($"Q {chargesSettledTotal:0.00}") disabled />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Pendiente por liquidar</label>
                        <input class="form-control" value=@($"Q {chargesOutstandingTotal:0.00}") disabled />
                    </div>
                    <div class="col-md-4 d-flex align-items-end">
                        @if (isStayAccountSettled)
                        {
                            <div class="alert alert-success mb-0 w-100">Cuenta liquidada.</div>
                        }
                        else
                        {
                            <div class="alert alert-warning mb-0 w-100">Cuenta pendiente.</div>
                        }
                    </div>
                </div>

                <div class="admin-res-panel admin-res-panel--inner mb-3">
                    <h5 class="mb-3">Agregar cargo</h5>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Categoría</label>
                            <select class="form-select" @bind="newChargeCategory" disabled="@(!CanAddCharges(selectedReservation))">
                                <option value="ROOM_SERVICE">ROOM_SERVICE</option>
                                <option value="RESTAURANT">RESTAURANT</option>
                                <option value="LAUNDRY">LAUNDRY</option>
                                <option value="MINIBAR">MINIBAR</option>
                                <option value="OTHER">OTHER</option>
                            </select>
                        </div>
                        <div class="col-md-5">
                            <label class="form-label">Descripción</label>
                            <input class="form-control" @bind="newChargeDescription" disabled="@(!CanAddCharges(selectedReservation))" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Monto</label>
                            <input type="number" step="0.01" class="form-control" @bind="newChargeAmount" disabled="@(!CanAddCharges(selectedReservation))" />
                        </div>
                        <div class="col-12">
                            <button class="btn admin-res-btn-success btn-sm" @onclick="AddCharge" disabled="@(!CanAddCharges(selectedReservation) || isSavingCharge)">
                                @(isSavingCharge ? "Guardando..." : "Agregar cargo")
                            </button>
                        </div>
                    </div>
                    @if (!CanAddCharges(selectedReservation))
                    {
                        <div class="text-muted mt-2">Solo se pueden agregar cargos a reservas en estado CHECKED_IN.</div>
                    }
                </div>

                <h5>Cargos registrados</h5>
                @if (charges is null || charges.Count == 0)
                {
                    <p class="text-muted mb-0">No hay cargos activos para esta reservación.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Categoría</th>
                                    <th>Descripción</th>
                                    <th>Monto</th>
                                    <th>Estado</th>
                                    <th>Creado</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var charge in charges)
                                {
                                    <tr>
                                        <td>@charge.Category</td>
                                        <td>@charge.Description</td>
                                        <td>Q @charge.Amount.ToString("0.00")</td>
                                        <td>
                                            @if (charge.IsSettled)
                                            {
                                                <span class="badge bg-success">Liquidado</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning text-dark">Pendiente</span>
                                            }
                                        </td>
                                        <td>@charge.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-danger"
                                                    @onclick="() => VoidCharge(charge.Id)"
                                                    disabled="@(isVoidingChargeId == charge.Id || charge.IsSettled || !CanVoidCharges(selectedReservation))">
                                                @(isVoidingChargeId == charge.Id ? "Anulando..." : "Anular")
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                @if (CanSettleCharges(selectedReservation) && chargesOutstandingTotal > 0)
                {
                    <div class="admin-res-panel admin-res-panel--inner mt-3">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                            <div>
                                <h5 class="mb-1">Pago de cuenta de estancia</h5>
                                <p class="text-muted mb-0">Ingresa los datos de cobro para liquidar los cargos pendientes antes del check-out.</p>
                            </div>
                            <div class="text-end">
                                <span class="admin-res-feature__label">Monto a cobrar</span>
                                <strong>Q @chargesOutstandingTotal.ToString("0.00")</strong>
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Número de tarjeta</label>
                                <input class="form-control" @bind="settlementCardNumber" placeholder="4111111111111111" maxlength="19" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">CVV</label>
                                <input class="form-control" @bind="settlementCvv" placeholder="123" maxlength="4" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Monto</label>
                                <input class="form-control" value="@($"Q {chargesOutstandingTotal:0.00}")" disabled />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Nombre en tarjeta</label>
                                <input class="form-control" @bind="settlementCardHolderName" placeholder="Nombre del huésped" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Dirección de cobro</label>
                                <input class="form-control" @bind="settlementBillingAddress" placeholder="Dirección de facturación" />
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="admin-res-modal-card__footer">
                <button class="btn admin-res-btn-secondary" @onclick="CloseChargesModal">Cerrar</button>
                <button class="btn admin-res-btn-success"
                        @onclick="SettleCharges"
                        disabled="@(!CanSettleCharges(selectedReservation) || chargesOutstandingTotal <= 0 || isSettlingCharges)">
                    @(isSettlingCharges ? "Procesando pago..." : "Confirmar pago y liquidar")
                </button>
            </div>
        </div>
    </div>
}

<style>
