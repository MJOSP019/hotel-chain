@page "/checkout"
@using System.Net.Http.Headers
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Forms
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>@GetPageTitle()</PageTitle>

<div class="checkout-premium-page">
    <section class="checkout-premium-hero">
        <div class="checkout-premium-hero__overlay"></div>
        <div class="checkout-premium-hero__content">
            <div class="checkout-premium-hero__eyebrow">@GetPageEyebrow()</div>
            <h1>@GetPageTitle()</h1>
            <p>@GetPageSubtitle()</p>

            <div class="checkout-premium-hero__actions">
                <a class="btn checkout-premium-btn checkout-premium-btn--light" href="/my-reservations">Mis reservaciones</a>
                <a class="btn checkout-premium-btn checkout-premium-btn--ghost" href="/search">Buscar habitaciones</a>
            </div>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(error))
    {
        <div class="alert alert-danger checkout-premium-alert">@error</div>
    }

    @if (!string.IsNullOrWhiteSpace(success))
    {
        <div class="alert alert-success checkout-premium-alert">@success</div>
    }

    <div class="checkout-premium-shell">
        <section class="checkout-premium-main">
            <article class="checkout-panel">
                <div class="checkout-panel__header">
                    <div>
                        <div class="checkout-panel__eyebrow">Consulta de reservación</div>
                        <h2>Encuentra tu reserva</h2>
                        <p>Ingresa el código generado al momento de reservar para ver el estado actualizado.</p>
                    </div>
                </div>

                <div class="checkout-lookup-grid">
                    <div class="checkout-field checkout-field--wide">
                        <label class="checkout-label">Código de reservación</label>
                        <input class="form-control checkout-input" @bind="code" placeholder="R-20260305-XXXXXX" />
                        <small class="text-muted">Este código se genera automáticamente al confirmar la reserva.</small>
                    </div>
                </div>

                <div class="checkout-inline-actions">
                    <button type="button" class="btn checkout-premium-btn checkout-premium-btn--primary" @onclick="LoadReservation">
                        @(isLoadingStatus ? "Cargando..." : "Cargar estado")
                    </button>

                    <button type="button" class="btn checkout-premium-btn checkout-premium-btn--secondary" @onclick="OpenPdf" disabled="@isDownloadingPdf">
                        @(isDownloadingPdf ? "Abriendo..." : "Ver PDF")
                    </button>
                </div>
            </article>

            @if (reservation is not null)
            {
                <article class="checkout-panel reservation-overview-panel">
                    <div class="reservation-overview__top">
                        <div>
                            <div class="checkout-panel__eyebrow">Resumen actual</div>
                            <h2>@reservation.Code</h2>
                            <p>
                                Consulta estado, hotel, fechas, habitación asignada, pago inicial y cuenta acumulada de estancia.
                            </p>
                        </div>
                        <div class="@GetStatusBadgeClass(reservation.Status)">@reservation.Status</div>
                    </div>

                    <div class="reservation-overview__grid">
                        <div class="reservation-kpi">
                            <span>Hotel</span>
                            <strong>@(reservation.Hotel ?? "-")</strong>
                        </div>

                        <div class="reservation-kpi">
                            <span>Estancia</span>
                            <strong>@reservation.CheckIn.ToString("dd/MM/yyyy") - @reservation.CheckOut.ToString("dd/MM/yyyy")</strong>
                        </div>

                        <div class="reservation-kpi">
                            <span>Noches / huéspedes</span>
                            <strong>@GetReservationNights(reservation) noche(s) · @reservation.Guests huésped(es)</strong>
                        </div>

                        <div class="reservation-kpi">
                            <span>Tipo reservado</span>
                            <strong>@GetPrimaryRoomType(reservation)</strong>
                        </div>

                        <div class="reservation-kpi">
                            <span>Habitación asignada</span>
                            <strong>@GetAssignedRoomName(reservation)</strong>
                        </div>

                        <div class="reservation-kpi">
                            <span>Pago inicial</span>
                            <strong>@GetPaymentSummary(reservation)</strong>
                        </div>

                        <div class="reservation-kpi">
                            <span>Base</span>
                            <strong>Q @reservation.BaseAmount.ToString("0.00")</strong>
                        </div>

                        <div class="reservation-kpi">
                            <span>Cargos registrados</span>
                            <strong>Q @reservation.ChargesTotal.ToString("0.00")</strong>
                        </div>

                        <div class="reservation-kpi">
                            <span>Cargos liquidados</span>
                            <strong>Q @reservation.SettledChargesTotal.ToString("0.00")</strong>
                        </div>

                        <div class="reservation-kpi">
                            <span>Pendiente de cuenta</span>
                            <strong>Q @reservation.OutstandingChargesTotal.ToString("0.00")</strong>
                        </div>

                        <div class="reservation-kpi reservation-kpi--accent">
                            <span>Total final</span>
                            <strong>Q @reservation.GrandTotal.ToString("0.00")</strong>
                        </div>
                    </div>

                    @if (ShowTimingWarning(reservation))
                    {
                        <div class="alert alert-warning mt-3 mb-0">
                            Esta reservación ya no cumple la regla de más de 24 horas antes del check-in para cancelar o cambiar fechas.
                        </div>
                    }

                    @if (reservation.Charges is not null && reservation.Charges.Count > 0)
                    {
                        <div class="stay-account mt-4">
                            <div class="stay-account__header">
                                <div>
                                    <div class="checkout-panel__eyebrow">Cuenta de estancia</div>
                                    <h3>Cargos registrados</h3>
                                </div>
                                <div class="stay-account__total">Q @reservation.ChargesTotal.ToString("0.00")</div>
                            </div>

                            <div class="table-responsive">
                                <table class="table checkout-premium-table">
                                    <thead>
                                        <tr>
                                            <th>Categoría</th>
                                            <th>Descripción</th>
                                            <th>Monto</th>
                                            <th>Estado</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var charge in reservation.Charges)
                                        {
                                            <tr>
                                                <td>@charge.Category</td>
                                                <td>@charge.Description</td>
                                                <td>Q @charge.Amount.ToString("0.00")</td>
                                                <td>
                                                    @if (charge.IsSettled)
                                                    {
                                                        <span class="mini-status mini-status--ok">Liquidado</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="mini-status mini-status--pending">Pendiente</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                </article>
            }

            @if (showChangeDatesSection)
            {
                <article class="checkout-panel change-dates-panel">
                    <div class="checkout-panel__header">
                        <div>
                            <div class="checkout-panel__eyebrow">Cambio de fechas</div>
                            <h2>Modificar estadía</h2>
                            <p>Disponible solo para reservas PENDING o CONFIRMED con más de 24 horas antes del check-in.</p>
                        </div>
                    </div>

                    <div class="checkout-payment-grid">
                        <div class="checkout-field">
                            <label class="checkout-label">Nuevo check-in</label>
                            <InputDate class="form-control checkout-input" @bind-Value="newCheckIn" />
                        </div>

                        <div class="checkout-field">
                            <label class="checkout-label">Nuevo check-out</label>
                            <InputDate class="form-control checkout-input" @bind-Value="newCheckOut" />
                        </div>

                        <div class="checkout-field checkout-field--wide">
                            <label class="checkout-label">Motivo del cambio</label>
                            <textarea class="form-control checkout-input"
                                      rows="3"
                                      @bind="changeDatesReason"
                                      placeholder="Ej. cambio solicitado por el huésped"></textarea>

                            <small class="text-muted">
                                Si la reserva ya está pagada, el sistema mantiene la validación de inventario y reglas comerciales.
                            </small>
                        </div>
                    </div>

                    <div class="checkout-inline-actions mt-4">
                        <button type="button"
                                class="btn checkout-premium-btn checkout-premium-btn--primary"
                                @onclick="ChangeDates"
                                disabled="@isChangingDates">
                            @(isChangingDates ? "Actualizando..." : "Confirmar cambio de fechas")
                        </button>

                        <button type="button"
                                class="btn checkout-premium-btn checkout-premium-btn--secondary"
                                @onclick="CloseChangeDatesSection"
                                disabled="@isChangingDates">
                            Cerrar
                        </button>
                    </div>
                </article>
            }

            @if (showCancelSection)
            {
                <article class="checkout-panel cancel-panel">
                    <div class="checkout-panel__header">
                        <div>
                            <div class="checkout-panel__eyebrow">Cancelación</div>
                            <h2>Cancelar reservación</h2>
                            <p>Ingresa un motivo para registrar correctamente la solicitud.</p>
                        </div>
                    </div>

                    <div class="checkout-field">
                        <label class="checkout-label">Motivo</label>
                        <textarea class="form-control checkout-input" rows="4" @bind="cancelReason"></textarea>
                    </div>

                    <div class="checkout-inline-actions mt-4">
                        <button type="button"
                                class="btn checkout-premium-btn checkout-premium-btn--danger"
                                @onclick="CancelReservation"
                                disabled="@isCancelling">
                            @(isCancelling ? "Cancelando..." : "Confirmar cancelación")
                        </button>

                        <button type="button"
                                class="btn checkout-premium-btn checkout-premium-btn--secondary"
                                @onclick="CloseCancelSection"
                                disabled="@isCancelling">
                            Cerrar
                        </button>
                    </div>
                </article>
            }
        </section>

        <aside class="checkout-premium-sidebar">
            <article class="checkout-sidebar-card checkout-sidebar-card--summary">
                <div class="checkout-panel__eyebrow">Estado de la reserva</div>
                <h3>@(string.IsNullOrWhiteSpace(code) ? "Sin código cargado" : code)</h3>

                <div class="sidebar-summary-grid">
                    <div>
                        <span>Base</span>
                        <strong>Q @(reservation?.BaseAmount.ToString("0.00") ?? "0.00")</strong>
                    </div>
                    <div>
                        <span>Cargos</span>
                        <strong>Q @(reservation?.ChargesTotal.ToString("0.00") ?? "0.00")</strong>
                    </div>
                    <div>
                        <span>Pendiente</span>
                        <strong>Q @(reservation?.OutstandingChargesTotal.ToString("0.00") ?? "0.00")</strong>
                    </div>
                    <div class="sidebar-summary-grid__wide">
                        <span>Total final</span>
                        <strong>Q @(reservation?.GrandTotal.ToString("0.00") ?? "0.00")</strong>
                    </div>
                </div>

                <div class="checkout-sidebar-card__status">
                    Estado actual: <strong>@(reservation?.Status ?? "Sin consultar")</strong>
                </div>
            </article>

            <article class="checkout-sidebar-card">
                <div class="checkout-panel__eyebrow">Pago demo</div>
                <h3>Información de pago</h3>

                @if (CanShowPaymentSection(reservation))
                {
                    <p>Completa los datos simulados para confirmar una reserva PENDING.</p>

                    <div class="checkout-payment-grid">
                        <div class="checkout-field checkout-field--wide">
                            <label class="checkout-label">Número de tarjeta</label>
                            <input class="form-control checkout-input" @bind="cardNumber" placeholder="4111111111111111" />
                        </div>

                        <div class="checkout-field">
                            <label class="checkout-label">CVV</label>
                            <input class="form-control checkout-input" @bind="cvv" placeholder="123" />
                        </div>

                        <div class="checkout-field checkout-field--wide">
                            <label class="checkout-label">Nombre en tarjeta</label>
                            <input class="form-control checkout-input" @bind="cardHolder" placeholder="Josue Pineda" />
                        </div>

                        <div class="checkout-field checkout-field--wide">
                            <label class="checkout-label">Dirección de cobro</label>
                            <input class="form-control checkout-input" @bind="billingAddress" placeholder="Ciudad de Guatemala" />
                        </div>
                    </div>

                    <div class="checkout-sidebar-actions">
                        <button type="button"
                                class="btn checkout-premium-btn checkout-premium-btn--primary"
                                @onclick="DoCheckout"
                                disabled="@(isPaying || !CanPayReservation(reservation) || isPaid)">
                            @(isPaying ? "Procesando..." : (isPaid ? "Pagado" : "Pagar y confirmar"))
                        </button>

                        @if (isPaid)
                        {
                            <button class="btn checkout-premium-btn checkout-premium-btn--secondary" @onclick="OpenPdf" disabled="@isDownloadingPdf">
                                @(isDownloadingPdf ? "Abriendo..." : "Descargar PDF")
                            </button>
                        }
                    </div>
                }
                else if (reservation is not null && reservation.IsPaid)
                {
                    <div class="payment-summary-box">
                        <div>
                            <span>Pago inicial</span>
                            <strong>@(reservation.PaymentStatus ?? "APPROVED")</strong>
                        </div>
                        <div>
                            <span>Tarjeta</span>
                            <strong>@(string.IsNullOrWhiteSpace(reservation.CardLast4) ? "No registrada" : reservation.CardLast4)</strong>
                        </div>
                    </div>

                    <p class="checkout-state-message">
                        El pago inicial ya fue aprobado; desde este punto solo se gestionan cargos de estancia y comprobante.
                    </p>
                }
                else if (reservation is not null && IsExpired(reservation.Status))
                {
                    <p class="checkout-state-message">Esta reservación expiró por inactividad y ya no puede pagarse. Debes crear una nueva reservación.</p>
                }
                else if (reservation is not null && IsCanceled(reservation.Status))
                {
                    <p class="checkout-state-message">Esta reservación fue cancelada y ya no admite pago.</p>
                }
                else if (reservation is not null)
                {
                    <p class="checkout-state-message">El pago ya no está disponible para el estado actual de esta reservación.</p>
                }
                else
                {
                    <p class="checkout-state-message">Carga una reservación para ver si el pago está disponible.</p>
                }
            </article>

            <article class="checkout-sidebar-card">
                <div class="checkout-panel__eyebrow">Política operativa</div>
                <h3>Notas importantes</h3>
                <ul class="checkout-notes-list">
                    <li>Las reservas pendientes se confirman mediante el flujo demo de pago existente.</li>
                    <li>La cancelación pública y el cambio de fechas solo aplican si faltan más de 24 horas para el check-in.</li>
                    <li>Los cargos de estancia reflejan consumos registrados durante la operación hotelera.</li>
                    <li>Después del check-out, el PDF sigue disponible como comprobante de la reservación.</li>
                </ul>

                @if (reservation is not null && IsPendingOrConfirmed(reservation.Status))
                {
                    <button type="button"
                            class="btn checkout-premium-btn checkout-premium-btn--secondary checkout-sidebar-card__danger"
                            @onclick="ToggleChangeDatesSection"
                            disabled="@(!CanExecuteTimeRestrictedAction(reservation) || isChangingDates)"
                            title="@GetTimeRestrictedActionTitle(reservation)">
                        Cambiar fechas
                    </button>

                    <button type="button"
                            class="btn checkout-premium-btn checkout-premium-btn--danger checkout-sidebar-card__danger"
                            @onclick="ToggleCancelSection"
                            disabled="@(!CanExecuteTimeRestrictedAction(reservation) || isCancelling)"
                            title="@GetTimeRestrictedActionTitle(reservation)">
                        @(isCancelling ? "Cancelando..." : "Cancelar reservación")
                    </button>
                }
            </article>
        </aside>
    </div>
</div>

<style>
    .checkout-premium-page {
        max-width: 1320px;
        margin: 0 auto;
        padding: 1.5rem 1rem 3rem;
    }

    .checkout-premium-hero {
        position: relative;
        overflow: hidden;
        border-radius: 30px;
        min-height: 320px;
        background:
            linear-gradient(110deg, rgba(9, 18, 36, 0.92) 0%, rgba(9, 18, 36, 0.76) 42%, rgba(9, 18, 36, 0.35) 100%),
            url('https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&fit=crop&w=1600&q=80') center/cover no-repeat;
        box-shadow: 0 24px 60px rgba(15, 23, 42, 0.16);
        margin-bottom: 1.5rem;
    }

    .checkout-premium-hero__content {
        position: relative;
        z-index: 1;
        max-width: 720px;
        padding: 2.6rem 2.4rem 2.8rem;
        color: #fff;
    }

    .checkout-premium-hero__eyebrow,
    .checkout-panel__eyebrow {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        background: rgba(255,255,255,0.16);
        color: #fff;
        padding: 0.35rem 0.7rem;
        font-size: 0.76rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        margin-bottom: 0.85rem;
    }

    .checkout-panel__eyebrow {
        background: #eef2ff;
        color: #1e3a8a;
    }

    .checkout-premium-hero h1 {
        font-size: clamp(2.3rem, 5vw, 4rem);
        line-height: 0.98;
        font-weight: 900;
        margin: 0 0 1rem;
        letter-spacing: -0.03em;
    }

    .checkout-premium-hero p {
        font-size: 1.04rem;
        line-height: 1.8;
        max-width: 650px;
        color: rgba(255,255,255,0.92);
        margin-bottom: 1.5rem;
    }

    .checkout-premium-hero__actions,
    .checkout-inline-actions,
    .checkout-sidebar-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
    }

    .checkout-premium-btn {
        border-radius: 999px;
        padding: 0.82rem 1.2rem;
        font-weight: 700;
        border: none;
        box-shadow: none;
    }

    .checkout-premium-btn--primary {
        background: #0f172a;
        color: #fff;
    }

    .checkout-premium-btn--primary:hover,
    .checkout-premium-btn--danger:hover {
        color: #fff;
        opacity: .96;
    }

    .checkout-premium-btn--secondary {
        background: #fff;
        color: #0f172a;
        border: 1px solid #cbd5e1;
    }

    .checkout-premium-btn--light {
        background: #fff;
        color: #0f172a;
        border: 1px solid transparent;
    }

    .checkout-premium-btn--ghost {
        background: transparent;
        color: #fff;
        border: 1px solid rgba(255,255,255,0.36);
    }

    .checkout-premium-btn--danger {
        background: #b91c1c;
        color: #fff;
    }

    .checkout-premium-alert {
        border-radius: 18px;
        margin-bottom: 1rem;
    }

    .checkout-premium-shell {
        display: grid;
        grid-template-columns: minmax(0, 1.6fr) minmax(320px, 0.95fr);
        gap: 1.25rem;
        align-items: start;
    }

    .checkout-premium-main,
    .checkout-premium-sidebar {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .checkout-panel,
    .checkout-sidebar-card {
        background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
        border: 1px solid #e2e8f0;
        border-radius: 28px;
        padding: 1.5rem;
        box-shadow: 0 18px 36px rgba(15, 23, 42, 0.06);
    }

    .checkout-panel__header {
        margin-bottom: 1.1rem;
    }

    .checkout-panel__header h2,
    .reservation-overview__top h2,
    .checkout-sidebar-card h3 {
        margin: 0;
        color: #0f172a;
        font-weight: 800;
    }

    .checkout-panel__header p,
    .reservation-overview__top p,
    .checkout-sidebar-card p {
        margin: 0.45rem 0 0;
        color: #64748b;
        line-height: 1.7;
    }

    .checkout-lookup-grid,
    .checkout-payment-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
    }

    .checkout-state-message {
        margin: 0;
        padding: 1rem 1.1rem;
        border-radius: 16px;
        background: rgba(15, 23, 42, 0.05);
        color: #334155;
        line-height: 1.6;
    }

    .checkout-field--wide {
        grid-column: 1 / -1;
    }

    .checkout-label {
        display: block;
        font-size: 0.78rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #475569;
        margin-bottom: 0.45rem;
    }

    .checkout-input {
        min-height: 52px;
        border-radius: 16px;
        border: 1px solid #cbd5e1;
        background: rgba(255,255,255,0.96);
    }

    .reservation-overview__top {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: flex-start;
    }

    .reservation-overview__grid,
    .sidebar-summary-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.9rem;
        margin-top: 1.15rem;
    }

    .reservation-kpi,
    .sidebar-summary-grid > div {
        background: rgba(255,255,255,0.88);
        border: 1px solid #e2e8f0;
        border-radius: 20px;
        padding: 0.95rem 1rem;
    }

    .reservation-kpi span,
    .sidebar-summary-grid span,
    .checkout-sidebar-card__status {
        display: block;
        color: #64748b;
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-weight: 700;
        margin-bottom: 0.28rem;
    }

    .reservation-kpi strong,
    .sidebar-summary-grid strong {
        font-size: 1.1rem;
        color: #0f172a;
    }

    .reservation-kpi--accent,
    .sidebar-summary-grid__wide {
        grid-column: 1 / -1;
        background: linear-gradient(180deg, #eff6ff 0%, #e0ecff 100%);
        border-color: #bfdbfe;
    }

    .stay-account__header {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: center;
        margin-bottom: 0.9rem;
    }

    .stay-account__header h3 {
        margin: 0;
        color: #0f172a;
        font-weight: 800;
    }

    .stay-account__total {
        font-size: 1.25rem;
        font-weight: 900;
        color: #0f172a;
    }

    .checkout-premium-table {
        margin-bottom: 0;
    }

    .checkout-premium-table thead th {
        border-bottom: 1px solid #cbd5e1;
        color: #475569;
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .checkout-premium-table tbody td {
        vertical-align: middle;
    }

    .mini-status {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        padding: 0.25rem 0.55rem;
        font-size: 0.74rem;
        font-weight: 800;
    }

    .mini-status--ok {
        background: #dcfce7;
        color: #166534;
    }

    .mini-status--pending {
        background: #fef3c7;
        color: #92400e;
    }

    .payment-summary-box {
        display: grid;
        gap: 0.75rem;
        margin: 1rem 0;
    }

    .payment-summary-box > div {
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        background: #f8fafc;
        padding: 0.9rem 1rem;
    }

    .payment-summary-box span {
        display: block;
        color: #6b7280;
        font-size: 0.74rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.06em;
