@code {
    bool isPaid;
    bool isLoadingStatus;
    bool isPaying;
    bool isDownloadingPdf;
    string code = "";
    string cardNumber = "4111111111111111";
    string cvv = "123";
    string cardHolder = "";
    string billingAddress = "";
    string? error;
    string? success;

    bool showCancelSection;
    string cancelReason = "";
    bool isCancelling;

    bool showChangeDatesSection;
    DateTime newCheckIn = DateTime.Today.AddDays(1);
    DateTime newCheckOut = DateTime.Today.AddDays(3);
    string changeDatesReason = "";
    bool isChangingDates;

    ReservationDto? reservation;

    protected override async Task OnInitializedAsync()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var qs = ParseQuery(uri.Query);

        if (qs.TryGetValue("code", out var c))
            code = c;

        if (!string.IsNullOrWhiteSpace(code))
            await LoadReservation();
    }

    async Task LoadReservation()
    {
        error = null;
        success = null;
        reservation = null;
        showCancelSection = false;
        showChangeDatesSection = false;
        cancelReason = "";
        changeDatesReason = "";

        if (string.IsNullOrWhiteSpace(code))
        {
            error = "Ingresa el código de reservación.";
            return;
        }

        isLoadingStatus = true;

        try
        {
            var resp = await Http.GetAsync($"/api/public/reservations/{code}");

            if (!resp.IsSuccessStatusCode)
            {
                error = await resp.Content.ReadAsStringAsync();
                return;
            }

            reservation = await resp.Content.ReadFromJsonAsync<ReservationDto>();

            if (reservation != null)
            {
                newCheckIn = reservation.CheckIn.Date;
                newCheckOut = reservation.CheckOut.Date;

                var status = (reservation.Status ?? "").ToUpperInvariant();

                if (status == "CONFIRMED")
                {
                    isPaid = true;
                    success = "✅ Esta reservación ya está confirmada.";
                }
                else if (status == "CHECKED_IN")
                {
                    isPaid = true;
                    success = "🏨 El huésped ya realizó check-in.";
                }
                else if (status == "CHECKED_OUT")
                {
                    isPaid = true;
                    success = "✅ La estancia ya fue cerrada con check-out.";
                }
                else if (status == "NO_SHOW")
                {
                    isPaid = true;
                    success = "ℹ️ Esta reservación fue marcada como no-show.";
                }
                else if (status == "CANCELED" || status == "CANCELLED")
                {
                    isPaid = false;
                    success = "ℹ️ Esta reservación está cancelada.";
                }
                else
                {
                    isPaid = false;
                }
            }
            else
            {
                isPaid = false;
            }
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isLoadingStatus = false;
        }
    }

    async Task DoCheckout()
    {
        error = null;
        success = null;

        if (string.IsNullOrWhiteSpace(code))
        {
            error = "Ingresa el código de reservación.";
            return;
        }

        if (string.IsNullOrWhiteSpace(cardNumber) ||
            string.IsNullOrWhiteSpace(cvv) ||
            string.IsNullOrWhiteSpace(cardHolder) ||
            string.IsNullOrWhiteSpace(billingAddress))
        {
            error = "Completa los datos de pago (demo).";
            return;
        }

        isPaying = true;

        try
        {
            var token = await JS.InvokeAsync<string>("auth.getToken");
            if (string.IsNullOrWhiteSpace(token))
            {
                error = "Necesitas iniciar sesión para hacer checkout.";
                return;
            }

            var body = new
            {
                cardNumber,
                cvv,
                cardHolderName = cardHolder,
                billingAddress
            };

            var req = new HttpRequestMessage(HttpMethod.Post, $"/api/public/reservations/{code}/checkout");
            req.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);
            req.Content = JsonContent.Create(body);

            var resp = await Http.SendAsync(req);

            if (!resp.IsSuccessStatusCode)
            {
                var txt = await resp.Content.ReadAsStringAsync();
                error = string.IsNullOrWhiteSpace(txt) ? $"Error HTTP {(int)resp.StatusCode}" : txt;
                return;
            }

            success = "✅ Pago aprobado. Reservación confirmada.";
            isPaid = true;

            await LoadReservation();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isPaying = false;
        }
    }

    async Task OpenPdf()
    {
        error = null;

        if (string.IsNullOrWhiteSpace(code))
        {
            error = "Ingresa el código de reservación.";
            return;
        }

        isDownloadingPdf = true;

        try
        {
            var token = await JS.InvokeAsync<string>("auth.getToken");
            if (string.IsNullOrWhiteSpace(token))
            {
                error = "Necesitas iniciar sesión para ver el PDF.";
                return;
            }

            var req = new HttpRequestMessage(HttpMethod.Get, $"/api/public/reservations/{code}/pdf");
            req.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);

            var resp = await Http.SendAsync(req);

            if (!resp.IsSuccessStatusCode)
            {
                var txt = await resp.Content.ReadAsStringAsync();
                error = string.IsNullOrWhiteSpace(txt) ? $"Error HTTP {(int)resp.StatusCode}" : txt;
                return;
            }

            var bytes = await resp.Content.ReadAsByteArrayAsync();
            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("openPdfBase64", base64);
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isDownloadingPdf = false;
        }
    }

    void ToggleChangeDatesSection()
    {
        if (reservation is null || !CanExecuteTimeRestrictedAction(reservation))
            return;

        showChangeDatesSection = !showChangeDatesSection;

        if (showChangeDatesSection)
        {
            showCancelSection = false;
            newCheckIn = reservation.CheckIn.Date;
            newCheckOut = reservation.CheckOut.Date;
        }
    }

    void CloseChangeDatesSection()
    {
        showChangeDatesSection = false;
        changeDatesReason = "";
    }

    async Task ChangeDates()
    {
        error = null;
        success = null;

        if (string.IsNullOrWhiteSpace(code))
        {
            error = "Ingresa el código de reservación.";
            return;
        }

        if (reservation is null || !CanExecuteTimeRestrictedAction(reservation))
        {
            error = "Esta reservación ya no cumple la regla de más de 24 horas antes del check-in para cambiar fechas.";
            return;
        }

        if (newCheckOut.Date <= newCheckIn.Date)
        {
            error = "El nuevo check-out debe ser mayor que el nuevo check-in.";
            return;
        }

        isChangingDates = true;

        try
        {
            var token = await JS.InvokeAsync<string>("auth.getToken");
            if (string.IsNullOrWhiteSpace(token))
            {
                error = "Necesitas iniciar sesión para cambiar fechas.";
                return;
            }

            var body = new
            {
                checkIn = newCheckIn,
                checkOut = newCheckOut,
                reason = changeDatesReason
            };

            var req = new HttpRequestMessage(HttpMethod.Post, $"/api/public/reservations/{code}/change-dates");
            req.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);
            req.Content = JsonContent.Create(body);

            var resp = await Http.SendAsync(req);

            if (!resp.IsSuccessStatusCode)
            {
                var txt = await resp.Content.ReadAsStringAsync();
                error = string.IsNullOrWhiteSpace(txt) ? $"Error HTTP {(int)resp.StatusCode}" : txt;
                return;
            }

            success = "✅ Fechas actualizadas correctamente.";
            showChangeDatesSection = false;
            changeDatesReason = "";

            await LoadReservation();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isChangingDates = false;
        }
    }

    void ToggleCancelSection()
    {
        if (reservation is null || !CanExecuteTimeRestrictedAction(reservation))
            return;

        showCancelSection = !showCancelSection;

        if (showCancelSection)
            showChangeDatesSection = false;

        if (!showCancelSection)
            cancelReason = "";
    }

    void CloseCancelSection()
    {
        showCancelSection = false;
        cancelReason = "";
    }

    async Task CancelReservation()
    {
        error = null;
        success = null;

        if (string.IsNullOrWhiteSpace(code))
        {
            error = "Ingresa el código de reservación.";
            return;
        }

        if (reservation is null || !CanExecuteTimeRestrictedAction(reservation))
        {
            error = "Esta reservación ya no cumple la regla de más de 24 horas antes del check-in para cancelar.";
            return;
        }

        isCancelling = true;

        try
        {
            var token = await JS.InvokeAsync<string>("auth.getToken");
            if (string.IsNullOrWhiteSpace(token))
            {
                error = "Necesitas iniciar sesión para cancelar.";
                return;
            }

            var body = new { reason = cancelReason };

            var req = new HttpRequestMessage(HttpMethod.Post, $"/api/public/reservations/{code}/cancel");
            req.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);
            req.Content = JsonContent.Create(body);

            var resp = await Http.SendAsync(req);

            if (!resp.IsSuccessStatusCode)
            {
                var txt = await resp.Content.ReadAsStringAsync();
                error = string.IsNullOrWhiteSpace(txt) ? $"Error HTTP {(int)resp.StatusCode}" : txt;
                return;
            }

            success = "✅ Reservación cancelada correctamente.";
            showCancelSection = false;
            cancelReason = "";
            isPaid = false;

            await LoadReservation();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isCancelling = false;
        }
    }

    private string GetPageEyebrow()
    {
        if (reservation is null)
            return "Consulta · Reservación";

        return (reservation.Status ?? "").ToUpperInvariant() == "PENDING"
            ? "Checkout · Pago inicial"
            : "Mi reservación · Gestión de estancia";
    }

    private string GetPageTitle()
    {
        if (reservation is null)
            return "Consulta y gestiona tu reservación";

        return (reservation.Status ?? "").ToUpperInvariant() == "PENDING"
            ? "Completa el pago de tu reservación"
            : "Consulta y gestiona tu estancia";
    }

    private string GetPageSubtitle()
    {
        if (reservation is null)
            return "Ingresa tu código para consultar el estado, revisar tu cuenta y descargar tu comprobante.";

        return (reservation.Status ?? "").ToUpperInvariant() == "PENDING"
            ? "Confirma el pago demo para dejar la reserva en estado CONFIRMED y generar el comprobante."
            : "Revisa hotel, fechas, habitación asignada, pago inicial, cargos de estancia y comprobante de tu reserva.";
    }

    private static int GetReservationNights(ReservationDto reservation)
    {
        var nights = (reservation.CheckOut.Date - reservation.CheckIn.Date).Days;
        return Math.Max(1, nights);
    }

    private static string GetPrimaryRoomType(ReservationDto reservation)
    {
        return reservation.Rooms.FirstOrDefault()?.RoomType ?? "-";
    }

    private static string GetAssignedRoomName(ReservationDto reservation)
    {
        return reservation.Rooms.FirstOrDefault()?.RoomName ?? "Pendiente de check-in";
    }

    private static string GetPaymentSummary(ReservationDto reservation)
    {
        if (!reservation.IsPaid)
            return reservation.PaymentStatus ?? "PENDING";

        var last4 = string.IsNullOrWhiteSpace(reservation.CardLast4) ? "" : $" · {reservation.CardLast4}";
        return $"{reservation.PaymentStatus ?? "APPROVED"}{last4}";
    }

    private static bool IsPendingOrConfirmed(string? status)
    {
        var normalized = (status ?? "").ToUpperInvariant();
        return normalized == "PENDING" || normalized == "CONFIRMED";
    }

    private static bool IsCanceled(string? status)
    {
        var normalized = (status ?? "").ToUpperInvariant();
        return normalized == "CANCELED" || normalized == "CANCELLED";
    }

    private static bool IsExpired(string? status)
    {
        return (status ?? "").ToUpperInvariant() == "EXPIRED";
    }

    private static bool CanPayReservation(ReservationDto? reservation)
    {
        return reservation is not null && (reservation.Status ?? "").ToUpperInvariant() == "PENDING";
    }

    private static bool CanShowPaymentSection(ReservationDto? reservation)
    {
        return reservation is null || CanPayReservation(reservation);
    }

    private static bool CanExecuteTimeRestrictedAction(ReservationDto reservation)
    {
        return DateTime.Now <= reservation.CheckIn.AddHours(-24);
    }

    private static bool ShowTimingWarning(ReservationDto reservation)
    {
        return IsPendingOrConfirmed(reservation.Status)
               && !CanExecuteTimeRestrictedAction(reservation);
    }

    private static string GetTimeRestrictedActionTitle(ReservationDto reservation)
    {
        if (CanExecuteTimeRestrictedAction(reservation))
            return "";

        return "Esta acción solo está disponible si faltan más de 24 horas para el check-in.";
    }

    private static string GetStatusBadgeClass(string? status)
    {
        return (status ?? "").ToUpperInvariant() switch
        {
            "PENDING" => "status-badge status-badge--pending",
            "CONFIRMED" => "status-badge status-badge--confirmed",
            "CHECKED_IN" => "status-badge status-badge--confirmed",
            "CHECKED_OUT" => "status-badge status-badge--default",
            "NO_SHOW" => "status-badge status-badge--cancelled",
            "EXPIRED" => "status-badge status-badge--cancelled",
            "CANCELED" => "status-badge status-badge--cancelled",
            "CANCELLED" => "status-badge status-badge--cancelled",
            _ => "status-badge status-badge--default"
        };
    }

    private static Dictionary<string, string> ParseQuery(string query)
    {
        var dict = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

        if (string.IsNullOrWhiteSpace(query))
            return dict;

        if (query.StartsWith("?"))
            query = query[1..];

        foreach (var part in query.Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var kv = part.Split('=', 2);
            var key = Uri.UnescapeDataString(kv[0]);
            var val = kv.Length > 1 ? Uri.UnescapeDataString(kv[1]) : "";
            dict[key] = val;
        }

        return dict;
    }

    private class ReservationDto
    {
        public string? Code { get; set; }
        public string? Status { get; set; }
        public string? Hotel { get; set; }
        public DateTime CheckIn { get; set; }
        public DateTime CheckOut { get; set; }
        public int Guests { get; set; }

        public decimal BaseAmount { get; set; }
        public decimal ChargesTotal { get; set; }
        public decimal SettledChargesTotal { get; set; }
        public decimal OutstandingChargesTotal { get; set; }
        public decimal GrandTotal { get; set; }
        public decimal TotalAmount { get; set; }

        public bool IsPaid { get; set; }
        public string? PaymentStatus { get; set; }
        public string? CardLast4 { get; set; }
        public bool IsStayAccountSettled { get; set; }

        public List<ReservationRoomDto> Rooms { get; set; } = new();
        public List<ReservationChargeDto> Charges { get; set; } = new();
    }

    private class ReservationRoomDto
    {
        public int RoomTypeId { get; set; }
        public string RoomType { get; set; } = "";
        public int? RoomId { get; set; }
        public string RoomName { get; set; } = "Pendiente de check-in";
        public decimal PricePerNight { get; set; }
        public int Nights { get; set; }
        public decimal Subtotal { get; set; }
    }

    private class ReservationChargeDto
    {
        public int Id { get; set; }
        public string Category { get; set; } = "";
        public string Description { get; set; } = "";
        public decimal Amount { get; set; }
        public DateTime CreatedAt { get; set; }
        public string? CreatedBy { get; set; }
        public bool IsSettled { get; set; }
        public DateTime? SettledAt { get; set; }
        public string? SettledBy { get; set; }
    }
}