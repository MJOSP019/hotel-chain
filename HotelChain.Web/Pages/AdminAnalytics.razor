@page "/admin/analytics"
@using System.Globalization
@using System.Net.Http.Json
@inject HttpClient Http
@inject IJSRuntime JS

<h3>Analytics de demanda hotelera</h3>
<p class="text-muted">
    Dashboard gerencial de búsquedas: demanda por destino, fechas de estadía, anticipación, duración, precios, canal y conversión estimada.
</p>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success">@successMessage</div>
}

<div class="hc-analytics-card mb-3">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
        <div>
            <h5 class="mb-1">Filtros de análisis</h5>
            <p class="text-muted mb-0">Separa fecha de búsqueda y fecha de estadía para analizar demanda real futura.</p>
        </div>
        <button class="btn btn-outline-primary btn-sm" @onclick="Refresh" disabled="@isLoading">Actualizar</button>
    </div>

    <div class="row g-2">
        <div class="col-md-2">
            <label class="form-label">Canal</label>
            <select class="form-select" @bind="filters.Source">
                <option value="">Todos</option>
                <option value="WEB">WEB</option>
                <option value="INTEGRATION">INTEGRATION</option>
            </select>
        </div>

        <div class="col-md-3">
            <label class="form-label">Ciudad / destino</label>
            <select class="form-select" @bind="filters.CityId">
                <option value="">Todas</option>
                @foreach (var city in cities)
                {
                    <option value="@city.Id">@city.Name</option>
                }
            </select>
        </div>

        <div class="col-md-2">
            <label class="form-label">Búsqueda desde</label>
            <InputDate class="form-control" @bind-Value="filters.From" />
        </div>

        <div class="col-md-2">
            <label class="form-label">Búsqueda hasta</label>
            <InputDate class="form-control" @bind-Value="filters.To" />
        </div>

        <div class="col-md-3">
            <label class="form-label">Tipo habitación</label>
            <select class="form-select" @bind="filters.RoomTypeId">
                <option value="">Todos</option>
                @foreach (var roomType in roomTypes)
                {
                    <option value="@roomType.Id">@roomType.Name</option>
                }
            </select>
        </div>

        <div class="col-md-2">
            <label class="form-label">Check-in desde</label>
            <InputDate class="form-control" @bind-Value="filters.CheckInFrom" />
        </div>

        <div class="col-md-2">
            <label class="form-label">Check-in hasta</label>
            <InputDate class="form-control" @bind-Value="filters.CheckInTo" />
        </div>

        <div class="col-md-2">
            <label class="form-label">Huéspedes</label>
            <input type="number" min="1" class="form-control" @bind="filters.Guests" />
        </div>

        <div class="col-md-2">
            <label class="form-label">Rating mín.</label>
            <input type="number" min="0" max="5" step="0.1" class="form-control" @bind="filters.MinRating" />
        </div>

        <div class="col-md-2">
            <label class="form-label">Precio mín.</label>
            <input type="number" min="0" step="0.01" class="form-control" @bind="filters.MinPrice" />
        </div>

        <div class="col-md-2">
            <label class="form-label">Precio máx.</label>
            <input type="number" min="0" step="0.01" class="form-control" @bind="filters.MaxPrice" />
        </div>
    </div>

    <div class="row g-2 mt-2 align-items-end">
        <div class="col-md-4">
            <label class="form-label">Correo para reporte</label>
            <input class="form-control" placeholder="correo@ejemplo.com" @bind="filters.ReportEmail" />
        </div>

        <div class="col-md-8 d-flex flex-wrap gap-2">
            <button class="btn btn-primary" @onclick="SearchFromFirstPage" disabled="@isLoading">
                @(isLoading ? "Buscando..." : "Aplicar filtros")
            </button>

            <button class="btn btn-outline-secondary" @onclick="ClearFilters" disabled="@isLoading">
                Limpiar
            </button>

            <button type="button" class="btn btn-outline-success" @onclick="ExportCsv" disabled="@(isLoading || isExporting)">
                @(isExporting ? "Exportando..." : "Descargar CSV")
            </button>

            <button type="button" class="btn btn-success" @onclick="SendCsvByEmail" disabled="@(isLoading || isSendingEmail)">
                @(isSendingEmail ? "Enviando..." : "Enviar CSV por correo")
            </button>
        </div>
    </div>
</div>

<div class="hc-kpi-grid mb-3">
    @KpiCard("Total búsquedas", dashboard.TotalSearches.ToString("N0"), "Búsquedas filtradas")
    @KpiCard("WEB", dashboard.WebSearches.ToString("N0"), "Portal propio")
    @KpiCard("REST", dashboard.IntegrationSearches.ToString("N0"), "Integración B2B")
    @KpiCard("Destino líder", dashboard.TopCity, "Mayor demanda")
    @KpiCard("Tipo líder", dashboard.TopRoomType, "Preferencia comercial")
    @KpiCard("Noches prom.", dashboard.AverageNights.ToString("0.0"), "Duración buscada")
    @KpiCard("Anticipación", $"{dashboard.AverageLeadTimeDays:0.0} días", "Lead time promedio")
    @KpiCard("Conversión est.", $"{dashboard.EstimatedConversionRate:0.0}%", $"{dashboard.EstimatedReservations} reservas")
</div>

<div class="row g-3 mb-3">
    <div class="col-lg-4">
        @AnalyticsChart("Demanda por destino", dashboard.TopCities, "Sin destinos para mostrar.")
    </div>

    <div class="col-lg-4">
        @AnalyticsDateChart("Fechas de check-in más buscadas", dashboard.ByCheckInDate, "Sin fechas de check-in.")
    </div>

    <div class="col-lg-4">
        @AnalyticsChart("Preferencia por tipo de habitación", dashboard.ByRoomType, "Sin tipos de habitación.")
    </div>

    <div class="col-lg-4">
        @AnalyticsChart("Anticipación de búsqueda", dashboard.LeadTimeBuckets, "Sin datos de anticipación.")
    </div>

    <div class="col-lg-4">
        @AnalyticsChart("Duración de estadía buscada", dashboard.ByLengthOfStay, "Sin duración de estadía.")
    </div>

    <div class="col-lg-4">
        @AnalyticsChart("Sensibilidad por rango de precio", dashboard.PriceDemand, "Sin filtros de precio.")
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-lg-6">
        @AnalyticsDateChart("Búsquedas por día", dashboard.BySearchDay, "Sin búsquedas por día.")
    </div>

    <div class="col-lg-6">
        <div class="hc-analytics-card h-100">
            <h5 class="mb-1">Embudo comercial por destino</h5>
            <p class="text-muted small">Conversión estimada = reservas / búsquedas para los filtros activos.</p>

            @if (dashboard.ConversionByCity.Count == 0)
            {
                <p class="text-muted mb-0">Sin datos para calcular conversión.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Destino</th>
                                <th class="text-end">Búsquedas</th>
                                <th class="text-end">Reservas</th>
                                <th class="text-end">Conv.</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in dashboard.ConversionByCity)
                            {
                                <tr>
                                    <td>@item.Label</td>
                                    <td class="text-end">@item.Searches</td>
                                    <td class="text-end">@item.Reservations</td>
                                    <td class="text-end"><strong>@item.ConversionRate.ToString("0.0")%</strong></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<div class="hc-analytics-card">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-2">
        <div>
            <h5 class="mb-1">Búsquedas registradas</h5>
            <p class="text-muted mb-0">Listado operativo paginado de 25 registros por defecto.</p>
        </div>
        <div class="d-flex align-items-center gap-2">
            <span class="text-muted">Total: @totalItems registro@(totalItems == 1 ? "" : "s")</span>
            <select class="form-select form-select-sm hc-page-size" @bind="pageSize" @bind:after="SearchFromFirstPage">
                <option value="25">25</option>
                <option value="50">50</option>
                <option value="100">100</option>
            </select>
        </div>
    </div>

    @if (isLoading && searches.Count == 0)
    {
        <p>Cargando búsquedas...</p>
    }
    else if (searches.Count == 0)
    {
        <p>No hay búsquedas registradas para esos filtros.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-bordered align-middle">
                <thead>
                    <tr>
                        <th>Fecha búsqueda</th>
                        <th>Canal</th>
                        <th>Usuario / agencia</th>
                        <th>Destino</th>
                        <th>Check-in</th>
                        <th>Check-out</th>
                        <th>Noches</th>
                        <th>Anticipación</th>
                        <th>Huéspedes</th>
                        <th>Precio buscado</th>
                        <th>Tipo</th>
                        <th>Rating</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in searches)
                    {
                        <tr>
                            <td>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <span class="hc-badge">@item.Source</span>
                            </td>
                            <td>
                                <strong>@item.UserDisplay</strong>
                                @if (!string.IsNullOrWhiteSpace(item.UserEmail))
                                {
                                    <br />
                                    <span class="text-muted small">@item.UserEmail</span>
                                }
                            </td>
                            <td>@item.City</td>
                            <td>@item.CheckIn.ToString("dd/MM/yyyy")</td>
                            <td>@item.CheckOut.ToString("dd/MM/yyyy")</td>
                            <td>@item.Nights</td>
                            <td>@item.LeadTimeDays día@(item.LeadTimeDays == 1 ? "" : "s")</td>
                            <td>@item.Guests</td>
                            <td>@item.PriceRangeLabel</td>
                            <td>@(string.IsNullOrWhiteSpace(item.RoomType) ? "-" : item.RoomType)</td>
                            <td>@(item.MinRating.HasValue ? item.MinRating.Value.ToString("0.0") : "-")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-3">
            <div class="text-muted">
                Página @currentPage de @(totalPages == 0 ? 1 : totalPages)
            </div>

            <div class="d-flex gap-2">
                <button class="btn btn-outline-primary"
                        @onclick="PreviousPage"
                        disabled="@(isLoading || currentPage <= 1)">
                    Anterior
                </button>

                <button class="btn btn-outline-primary"
                        @onclick="NextPage"
                        disabled="@(isLoading || currentPage >= totalPages || totalPages == 0)">
                    Siguiente
                </button>
            </div>
        </div>
    }
</div>

<style>
    .hc-analytics-card {
        background: #fff;
        border: 1px solid #d7dde5;
        border-radius: 14px;
        padding: 1rem;
        box-shadow: 0 2px 10px rgba(15, 23, 42, 0.04);
    }

    .hc-kpi-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(155px, 1fr));
        gap: .75rem;
    }

    .hc-kpi {
        background: #fff;
        border: 1px solid #d7dde5;
        border-radius: 14px;
        padding: .85rem;
        min-height: 92px;
        box-shadow: 0 2px 10px rgba(15, 23, 42, 0.04);
    }

    .hc-kpi-label {
        font-size: .72rem;
        text-transform: uppercase;
        letter-spacing: .04em;
        color: #64748b;
        font-weight: 700;
    }

    .hc-kpi-value {
        font-size: 1.35rem;
        font-weight: 800;
        line-height: 1.15;
        margin-top: .3rem;
        color: #0f172a;
    }

    .hc-kpi-hint {
        font-size: .76rem;
        color: #64748b;
        margin-top: .25rem;
    }

    .hc-chart-row {
        margin-bottom: .9rem;
    }

    .hc-chart-label {
        display: flex;
        justify-content: space-between;
        gap: .5rem;
        margin-bottom: .2rem;
        font-size: .9rem;
    }

    .hc-chart-track {
        width: 100%;
        height: 10px;
        background: #e9eef5;
        border-radius: 999px;
        overflow: hidden;
    }

    .hc-chart-bar {
        height: 100%;
        background: #0d6efd;
        border-radius: 999px;
        min-width: 6px;
    }

    .hc-badge {
        display: inline-block;
        border-radius: 999px;
        padding: .2rem .55rem;
        background: #e7f0ff;
        color: #0d47a1;
        font-size: .74rem;
        font-weight: 700;
    }

    .hc-page-size {
        width: 88px;
    }
</style>

@code {
    private const string SearchesEndpoint = "api/admin/analytics/searches";
    private const string DashboardEndpoint = "api/admin/analytics/searches/dashboard";
    private const string ExportEndpoint = "api/admin/analytics/searches/export";
    private const string ExportEmailEndpoint = "api/admin/analytics/searches/export-email";
    private const string AdminCitiesEndpoint = "api/admin/cities";
    private const string PublicCitiesEndpoint = "api/public/cities";
    private const string RoomTypesEndpoint = "api/public/room-types";
    private const int DefaultPageSize = 25;

    private List<SearchAuditDto> searches = new();
    private List<CityDto> cities = new();
    private List<RoomTypeDto> roomTypes = new();

    private DashboardDto dashboard = new();

    private string? errorMessage;
    private string? successMessage;
    private bool isLoading;
    private bool isExporting;
    private bool isSendingEmail;

    private FilterModel filters = new();

    private int currentPage = 1;
    private int pageSize = DefaultPageSize;
    private int totalItems;
    private int totalPages;

    protected override async Task OnInitializedAsync()
    {
        await LoadCities();
        await LoadRoomTypes();
        await LoadAllAnalyticsData();
    }

    private async Task LoadCities()
    {
        try
        {
            cities = await Http.GetFromJsonAsync<List<CityDto>>(AdminCitiesEndpoint) ?? new();
        }
        catch
        {
            try
            {
                cities = await Http.GetFromJsonAsync<List<CityDto>>(PublicCitiesEndpoint) ?? new();
            }
            catch (Exception ex)
            {
                errorMessage = $"No se pudieron cargar las ciudades: {ex.Message}";
            }
        }
    }

    private async Task LoadRoomTypes()
    {
        try
        {
            roomTypes = await Http.GetFromJsonAsync<List<RoomTypeDto>>(RoomTypesEndpoint) ?? new();
        }
        catch (Exception ex)
        {
            errorMessage = $"No se pudieron cargar los tipos de habitación: {ex.Message}";
        }
    }

    private async Task Refresh()
    {
        await LoadAllAnalyticsData();
    }

    private async Task SearchFromFirstPage()
    {
        currentPage = 1;
        await LoadAllAnalyticsData();
    }

    private async Task LoadAllAnalyticsData()
    {
        await LoadDashboard();
        await LoadSearches();
    }

    private async Task LoadDashboard()
    {
        try
        {
            var url = BuildUrl(DashboardEndpoint, includePaging: false);
            dashboard = await Http.GetFromJsonAsync<DashboardDto>(url) ?? new();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error cargando dashboard: {ex.Message}";
            dashboard = new DashboardDto();
        }
    }

    private async Task LoadSearches()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            successMessage = null;

            var url = BuildUrl(SearchesEndpoint, includePaging: true);
            var result = await Http.GetFromJsonAsync<PagedResult<SearchAuditDto>>(url);

            searches = result?.Items ?? new();
            currentPage = result?.Page ?? 1;
            pageSize = result?.PageSize ?? DefaultPageSize;
            totalItems = result?.TotalItems ?? 0;
            totalPages = result?.TotalPages ?? 0;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error cargando analytics: {ex.Message}";
            searches = new();
            totalItems = 0;
            totalPages = 0;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ExportCsv()
    {
        try
        {
            isExporting = true;
            errorMessage = null;
            successMessage = null;

            var url = BuildUrl(ExportEndpoint, includePaging: false);
            var response = await Http.GetAsync(url);

            if (!response.IsSuccessStatusCode)
            {
                var errorText = await response.Content.ReadAsStringAsync();
                errorMessage = $"No se pudo exportar el CSV: {errorText}";
                return;
            }

            var bytes = await response.Content.ReadAsByteArrayAsync();

            if (bytes.Length == 0)
            {
                errorMessage = "El archivo CSV llegó vacío.";
                return;
            }

            var base64 = Convert.ToBase64String(bytes);

            await JS.InvokeVoidAsync("downloadFileFromBase64", new
            {
                fileName = $"searches-report-{DateTime.Now:yyyyMMdd-HHmmss}.csv",
                contentType = "text/csv",
                base64
            });

            successMessage = "CSV descargado correctamente.";
        }
        catch (Exception ex)
        {
            errorMessage = $"Error exportando CSV: {ex.Message}";
        }
        finally
        {
            isExporting = false;
        }
    }

    private async Task SendCsvByEmail()
    {
        if (string.IsNullOrWhiteSpace(filters.ReportEmail))
        {
            errorMessage = "Ingresa un correo para enviar el reporte.";
            successMessage = null;
            return;
        }

        try
        {
            isSendingEmail = true;
            errorMessage = null;
            successMessage = null;

            var url = BuildUrl(ExportEmailEndpoint, includePaging: false);
            var response = await Http.PostAsJsonAsync(url, new EmailExportRequest
            {
                Email = filters.ReportEmail
            });

            var responseText = await response.Content.ReadAsStringAsync();

            if (!response.IsSuccessStatusCode)
            {
                errorMessage = string.IsNullOrWhiteSpace(responseText)
                    ? "No se pudo enviar el reporte por correo."
                    : responseText;
                return;
            }

            successMessage = "Reporte enviado por correo correctamente.";
        }
        catch (Exception ex)
        {
            errorMessage = $"Error enviando reporte por correo: {ex.Message}";
        }
        finally
        {
            isSendingEmail = false;
        }
    }

    private async Task ClearFilters()
    {
        var currentEmail = filters.ReportEmail;
        filters = new FilterModel { ReportEmail = currentEmail };
        currentPage = 1;
        pageSize = DefaultPageSize;
        successMessage = null;
        errorMessage = null;
        await LoadAllAnalyticsData();
    }

    private async Task PreviousPage()
    {
        if (currentPage <= 1)
            return;

        currentPage--;
        await LoadSearches();
    }

    private async Task NextPage()
    {
        if (totalPages == 0 || currentPage >= totalPages)
            return;

        currentPage++;
        await LoadSearches();
    }

    private string BuildUrl(string baseEndpoint, bool includePaging)
    {
        var queryParams = new List<string>();

        if (!string.IsNullOrWhiteSpace(filters.Source))
            queryParams.Add($"source={Uri.EscapeDataString(filters.Source)}");

        if (filters.CityId.HasValue)
            queryParams.Add($"cityId={filters.CityId.Value}");

        if (filters.From.HasValue)
            queryParams.Add($"from={filters.From.Value:yyyy-MM-dd}");

        if (filters.To.HasValue)
            queryParams.Add($"to={filters.To.Value:yyyy-MM-dd}");

        if (filters.CheckInFrom.HasValue)
            queryParams.Add($"checkInFrom={filters.CheckInFrom.Value:yyyy-MM-dd}");

        if (filters.CheckInTo.HasValue)
            queryParams.Add($"checkInTo={filters.CheckInTo.Value:yyyy-MM-dd}");

        if (filters.Guests.HasValue && filters.Guests.Value > 0)
            queryParams.Add($"guests={filters.Guests.Value}");

        if (filters.RoomTypeId.HasValue)
            queryParams.Add($"roomTypeId={filters.RoomTypeId.Value}");

        if (filters.MinRating.HasValue)
            queryParams.Add($"minRating={filters.MinRating.Value.ToString(CultureInfo.InvariantCulture)}");

        if (filters.MinPrice.HasValue)
            queryParams.Add($"minPrice={filters.MinPrice.Value.ToString(CultureInfo.InvariantCulture)}");

        if (filters.MaxPrice.HasValue)
            queryParams.Add($"maxPrice={filters.MaxPrice.Value.ToString(CultureInfo.InvariantCulture)}");

        if (includePaging)
        {
            queryParams.Add($"page={currentPage}");
            queryParams.Add($"pageSize={pageSize}");
        }

        return queryParams.Count == 0
            ? baseEndpoint
            : $"{baseEndpoint}?{string.Join("&", queryParams)}";
    }

    private static int MaxCount(List<DashboardCountItem> items)
    {
        return items.Count == 0 ? 0 : items.Max(x => x.Count);
    }

    private static int MaxDateCount(List<DashboardDateItem> items)
    {
        return items.Count == 0 ? 0 : items.Max(x => x.Count);
    }

    private static string BarWidth(int count, int maxCount)
    {
        if (maxCount <= 0 || count <= 0)
            return "0%";

        var width = (decimal)count * 100m / maxCount;
        var normalized = width < 4m ? 4m : Math.Min(width, 100m);

        return normalized.ToString("0.##", CultureInfo.InvariantCulture) + "%";
    }

    private class FilterModel
    {
        public string? Source { get; set; }
        public int? CityId { get; set; }
        public DateTime? From { get; set; }
        public DateTime? To { get; set; }
        public DateTime? CheckInFrom { get; set; }
        public DateTime? CheckInTo { get; set; }
        public int? Guests { get; set; }
        public int? RoomTypeId { get; set; }
        public double? MinRating { get; set; }
        public decimal? MinPrice { get; set; }
        public decimal? MaxPrice { get; set; }
        public string? ReportEmail { get; set; }
    }

    private class SearchAuditDto
    {
        public int Id { get; set; }
        public int CityId { get; set; }
        public string City { get; set; } = "";
        public Guid? UserId { get; set; }
        public string UserDisplay { get; set; } = "";
        public string UserEmail { get; set; } = "";
        public string UserCountry { get; set; } = "";
        public string UserPassportNumber { get; set; } = "";
        public DateTime CheckIn { get; set; }
        public DateTime CheckOut { get; set; }
        public int Nights { get; set; }
        public int LeadTimeDays { get; set; }
        public int Guests { get; set; }
        public decimal? MinPrice { get; set; }
        public decimal? MaxPrice { get; set; }
        public string PriceRangeLabel { get; set; } = "";
        public int? RoomTypeId { get; set; }
        public string? RoomType { get; set; }
        public double? MinRating { get; set; }
        public string Source { get; set; } = "";
        public DateTime CreatedAt { get; set; }
    }

    private class CityDto
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string? CountryCode { get; set; }
    }

    private class RoomTypeDto
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
    }

    private class PagedResult<T>
    {
        public int Page { get; set; }
        public int PageSize { get; set; }
        public int TotalItems { get; set; }
        public int TotalPages { get; set; }
        public List<T> Items { get; set; } = new();
    }

    private class DashboardDto
    {
        public int TotalSearches { get; set; }
        public int WebSearches { get; set; }
        public int IntegrationSearches { get; set; }
        public int DistinctCities { get; set; }
        public decimal AverageGuests { get; set; }
        public decimal AverageNights { get; set; }
        public decimal AverageLeadTimeDays { get; set; }
        public string TopCity { get; set; } = "-";
        public string TopRoomType { get; set; } = "-";
        public int EstimatedReservations { get; set; }
        public decimal EstimatedConversionRate { get; set; }
        public List<DashboardCountItem> BySource { get; set; } = new();
        public List<DashboardCountItem> TopCities { get; set; } = new();
        public List<DashboardDateItem> BySearchDay { get; set; } = new();
        public List<DashboardDateItem> ByCheckInDate { get; set; } = new();
        public List<DashboardCountItem> ByRoomType { get; set; } = new();
        public List<DashboardCountItem> ByGuests { get; set; } = new();
        public List<DashboardCountItem> ByLengthOfStay { get; set; } = new();
        public List<DashboardCountItem> LeadTimeBuckets { get; set; } = new();
