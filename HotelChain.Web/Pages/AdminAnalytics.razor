@page "/admin/analytics"
@using System.Net.Http.Json
@inject HttpClient Http
@inject IJSRuntime JS

<h3>Analytics de búsquedas</h3>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success">@successMessage</div>
}

<div class="card p-3 mb-3">
    <h5>Filtros</h5>

    <div class="row">
        <div class="col-md-3 mb-2">
            <label>Origen</label>
            <select class="form-select" @bind="filters.Source">
                <option value="">Todos</option>
                <option value="WEB">WEB</option>
                <option value="INTEGRATION">INTEGRATION</option>
            </select>
        </div>

        <div class="col-md-3 mb-2">
            <label>Ciudad</label>
            <select class="form-select" @bind="filters.CityId">
                <option value="">Todas</option>
                @foreach (var city in cities)
                {
                    <option value="@city.Id">@city.Name</option>
                }
            </select>
        </div>

        <div class="col-md-3 mb-2">
            <label>Desde</label>
            <InputDate class="form-control" @bind-Value="filters.From" />
        </div>

        <div class="col-md-3 mb-2">
            <label>Hasta</label>
            <InputDate class="form-control" @bind-Value="filters.To" />
        </div>
    </div>

    <div class="row">
        <div class="col-md-2 mb-2">
            <label>Huéspedes</label>
            <input type="number" min="1" class="form-control" @bind="filters.Guests" />
        </div>

        <div class="col-md-3 mb-2">
            <label>Tipo habitación</label>
            <select class="form-select" @bind="filters.RoomTypeId">
                <option value="">Todos</option>
                @foreach (var roomType in roomTypes)
                {
                    <option value="@roomType.Id">@roomType.Name</option>
                }
            </select>
        </div>

        <div class="col-md-2 mb-2">
            <label>Rating mín.</label>
            <input type="number" min="0" max="5" step="0.1" class="form-control" @bind="filters.MinRating" />
        </div>

        <div class="col-md-2 mb-2">
            <label>Precio mín.</label>
            <input type="number" min="0" step="0.01" class="form-control" @bind="filters.MinPrice" />
        </div>

        <div class="col-md-3 mb-2">
            <label>Precio máx.</label>
            <input type="number" min="0" step="0.01" class="form-control" @bind="filters.MaxPrice" />
        </div>
    </div>

    <div class="d-flex gap-2 mt-3">
        <button class="btn btn-primary" @onclick="SearchFromFirstPage" disabled="@isLoading">
            @(isLoading ? "Buscando..." : "Buscar")
        </button>

        <button class="btn btn-outline-secondary" @onclick="ClearFilters" disabled="@isLoading">
            Limpiar
        </button>

        <button type="button" class="btn btn-outline-success" @onclick="ExportCsv" disabled="@(isLoading || isExporting)">
            @(isExporting ? "Exportando..." : "Exportar CSV")
        </button>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-4">
        <div class="card p-3 h-100">
            <div class="text-muted small">Total búsquedas</div>
            <div class="fs-2 fw-bold">@dashboard.TotalSearches</div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card p-3 h-100">
            <div class="text-muted small">Fuentes distintas</div>
            <div class="fs-2 fw-bold">@dashboard.BySource.Count</div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card p-3 h-100">
            <div class="text-muted small">Ciudades en dashboard</div>
            <div class="fs-2 fw-bold">@dashboard.TopCities.Count</div>
        </div>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-lg-4">
        <div class="card p-3 h-100">
            <h5>Búsquedas por origen</h5>

            @if (dashboard.BySource.Count == 0)
            {
                <p class="text-muted mb-0">Sin datos para mostrar.</p>
            }
            else
            {
                @foreach (var item in dashboard.BySource)
                {
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span>@item.Label</span>
                            <strong>@item.Count</strong>
                        </div>
                        <div class="hc-chart-track">
                            <div class="hc-chart-bar" style="width:@GetBarWidth(item.Count, dashboard.BySourceMaxCount)%"></div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card p-3 h-100">
            <h5>Top ciudades</h5>

            @if (dashboard.TopCities.Count == 0)
            {
                <p class="text-muted mb-0">Sin datos para mostrar.</p>
            }
            else
            {
                @foreach (var item in dashboard.TopCities)
                {
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span>@item.Label</span>
                            <strong>@item.Count</strong>
                        </div>
                        <div class="hc-chart-track">
                            <div class="hc-chart-bar" style="width:@GetBarWidth(item.Count, dashboard.TopCitiesMaxCount)%"></div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card p-3 h-100">
            <h5>Búsquedas por día</h5>

            @if (dashboard.ByDay.Count == 0)
            {
                <p class="text-muted mb-0">Sin datos para mostrar.</p>
            }
            else
            {
                @foreach (var item in dashboard.ByDay)
                {
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span>@item.Date.ToString("dd/MM")</span>
                            <strong>@item.Count</strong>
                        </div>
                        <div class="hc-chart-track">
                            <div class="hc-chart-bar" style="width:@GetBarWidth(item.Count, dashboard.ByDayMaxCount)%"></div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

<div class="card p-3">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h5 class="mb-0">Búsquedas registradas</h5>
        <span class="text-muted">
            Total: @totalItems registro@(totalItems == 1 ? "" : "s")
        </span>
    </div>

    @if (isLoading && searches.Count == 0)
    {
        <p>Cargando búsquedas...</p>
    }
    else if (searches.Count == 0)
    {
        <p>No hay búsquedas registradas para esos filtros.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-bordered">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Origen</th>
                        <th>Ciudad</th>
                        <th>Check-in</th>
                        <th>Check-out</th>
                        <th>Huéspedes</th>
                        <th>Precio</th>
                        <th>Tipo habitación</th>
                        <th>Rating mín.</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in searches)
                    {
                        <tr>
                            <td>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@item.Source</td>
                            <td>@item.City</td>
                            <td>@item.CheckIn.ToString("dd/MM/yyyy")</td>
                            <td>@item.CheckOut.ToString("dd/MM/yyyy")</td>
                            <td>@item.Guests</td>
                            <td>@FormatPriceRange(item.MinPrice, item.MaxPrice)</td>
                            <td>@(string.IsNullOrWhiteSpace(item.RoomType) ? "-" : item.RoomType)</td>
                            <td>@(item.MinRating.HasValue ? item.MinRating.Value.ToString("0.0") : "-")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-3">
            <div class="text-muted">
                Página @currentPage de @(totalPages == 0 ? 1 : totalPages)
            </div>

            <div class="d-flex gap-2">
                <button class="btn btn-outline-primary"
                        @onclick="PreviousPage"
                        disabled="@(isLoading || currentPage <= 1)">
                    Anterior
                </button>

                <button class="btn btn-outline-primary"
                        @onclick="NextPage"
                        disabled="@(isLoading || currentPage >= totalPages || totalPages == 0)">
                    Siguiente
                </button>
            </div>
        </div>
    }
</div>

<style>
    .hc-chart-track {
        width: 100%;
        height: 12px;
        background: #e9ecef;
        border-radius: 999px;
        overflow: hidden;
    }

    .hc-chart-bar {
        height: 100%;
        background: #0d6efd;
        border-radius: 999px;
        min-width: 6px;
    }
</style>

@code {
    private const string SearchesEndpoint = "api/admin/analytics/searches";
    private const string DashboardEndpoint = "api/admin/analytics/searches/dashboard";
    private const string ExportEndpoint = "api/admin/analytics/searches/export";
    private const string CitiesEndpoint = "api/public/cities";
    private const string RoomTypesEndpoint = "api/public/room-types";
    private const int DefaultPageSize = 25;

    private List<SearchAuditDto> searches = new();
    private List<CityDto> cities = new();
    private List<RoomTypeDto> roomTypes = new();

    private DashboardVm dashboard = new();

    private string? errorMessage;
    private string? successMessage;
    private bool isLoading;
    private bool isExporting;

    private FilterModel filters = new();

    private int currentPage = 1;
    private int pageSize = DefaultPageSize;
    private int totalItems;
    private int totalPages;

    protected override async Task OnInitializedAsync()
    {
        await LoadCities();
        await LoadRoomTypes();
        await LoadAllAnalyticsData();
    }

    private async Task LoadCities()
    {
        try
        {
            cities = await Http.GetFromJsonAsync<List<CityDto>>(CitiesEndpoint) ?? new();
        }
        catch (Exception ex)
        {
            errorMessage = $"No se pudieron cargar las ciudades: {ex.Message}";
        }
    }

    private async Task LoadRoomTypes()
    {
        try
        {
            roomTypes = await Http.GetFromJsonAsync<List<RoomTypeDto>>(RoomTypesEndpoint) ?? new();
        }
        catch (Exception ex)
        {
            errorMessage = $"No se pudieron cargar los tipos de habitación: {ex.Message}";
        }
    }

    private async Task SearchFromFirstPage()
    {
        currentPage = 1;
        await LoadAllAnalyticsData();
    }

    private async Task LoadAllAnalyticsData()
    {
        await LoadDashboard();
        await LoadSearches();
    }

    private async Task LoadDashboard()
    {
        try
        {
            var url = BuildUrl(DashboardEndpoint, includePaging: false);
            var result = await Http.GetFromJsonAsync<DashboardDto>(url);

            dashboard = new DashboardVm
            {
                TotalSearches = result?.TotalSearches ?? 0,
                BySource = result?.BySource ?? new(),
                TopCities = result?.TopCities ?? new(),
                ByDay = result?.ByDay ?? new()
            };
        }
        catch (Exception ex)
        {
            errorMessage = $"Error cargando dashboard: {ex.Message}";
            dashboard = new DashboardVm();
        }
    }

    private async Task LoadSearches()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            successMessage = null;

            var url = BuildUrl(SearchesEndpoint, includePaging: true);
            var result = await Http.GetFromJsonAsync<PagedResult<SearchAuditDto>>(url);

            searches = result?.Items ?? new();
            currentPage = result?.Page ?? 1;
            pageSize = result?.PageSize ?? DefaultPageSize;
            totalItems = result?.TotalItems ?? 0;
            totalPages = result?.TotalPages ?? 0;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error cargando analytics: {ex.Message}";
            searches = new();
            totalItems = 0;
            totalPages = 0;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ExportCsv()
    {
        try
        {
            isExporting = true;
            errorMessage = null;
            successMessage = null;

            var url = BuildUrl(ExportEndpoint, includePaging: false);
            var response = await Http.GetAsync(url);

            if (!response.IsSuccessStatusCode)
            {
                var errorText = await response.Content.ReadAsStringAsync();
                errorMessage = $"No se pudo exportar el CSV: {errorText}";
                return;
            }

            var bytes = await response.Content.ReadAsByteArrayAsync();

            if (bytes.Length == 0)
            {
                errorMessage = "El archivo CSV llegó vacío.";
                return;
            }

            var base64 = Convert.ToBase64String(bytes);

            await JS.InvokeVoidAsync("downloadFileFromBase64", new
            {
                fileName = $"searches-report-{DateTime.Now:yyyyMMdd-HHmmss}.csv",
                contentType = "text/csv",
                base64
            });

            successMessage = "CSV exportado correctamente.";
        }
        catch (Exception ex)
        {
            errorMessage = $"Error exportando CSV: {ex.Message}";
        }
        finally
        {
            isExporting = false;
        }
    }

    private async Task ClearFilters()
    {
        filters = new FilterModel();
        currentPage = 1;
        successMessage = null;
        errorMessage = null;
        await LoadAllAnalyticsData();
    }

    private async Task PreviousPage()
    {
        if (currentPage <= 1)
            return;

        currentPage--;
        await LoadSearches();
    }

    private async Task NextPage()
    {
        if (totalPages == 0 || currentPage >= totalPages)
            return;

        currentPage++;
        await LoadSearches();
    }

    private string BuildUrl(string baseEndpoint, bool includePaging)
    {
        var queryParams = new List<string>();

        if (!string.IsNullOrWhiteSpace(filters.Source))
            queryParams.Add($"source={Uri.EscapeDataString(filters.Source)}");

        if (filters.CityId.HasValue)
            queryParams.Add($"cityId={filters.CityId.Value}");

        if (filters.From.HasValue)
            queryParams.Add($"from={filters.From.Value:yyyy-MM-dd}");

        if (filters.To.HasValue)
            queryParams.Add($"to={filters.To.Value:yyyy-MM-dd}");

        if (filters.Guests.HasValue && filters.Guests.Value > 0)
            queryParams.Add($"guests={filters.Guests.Value}");

        if (filters.RoomTypeId.HasValue)
            queryParams.Add($"roomTypeId={filters.RoomTypeId.Value}");

        if (filters.MinRating.HasValue)
            queryParams.Add($"minRating={filters.MinRating.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)}");

        if (filters.MinPrice.HasValue)
            queryParams.Add($"minPrice={filters.MinPrice.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)}");

        if (filters.MaxPrice.HasValue)
            queryParams.Add($"maxPrice={filters.MaxPrice.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)}");

        if (includePaging)
        {
            queryParams.Add($"page={currentPage}");
            queryParams.Add($"pageSize={pageSize}");
        }

        if (queryParams.Count == 0)
            return baseEndpoint;

        return $"{baseEndpoint}?{string.Join("&", queryParams)}";
    }

    private static decimal GetBarWidth(int count, int maxCount)
    {
        if (maxCount <= 0 || count <= 0)
            return 0;

        var width = (decimal)count * 100m / maxCount;
        return width < 4m ? 4m : Math.Min(width, 100m);
    }

    private static string FormatPriceRange(decimal? minPrice, decimal? maxPrice)
    {
        if (!minPrice.HasValue && !maxPrice.HasValue)
            return "-";

        if (minPrice.HasValue && maxPrice.HasValue)
            return $"Q {minPrice.Value:0.00} - Q {maxPrice.Value:0.00}";

        if (minPrice.HasValue)
            return $"Desde Q {minPrice.Value:0.00}";

        return $"Hasta Q {maxPrice!.Value:0.00}";
    }

    private class FilterModel
    {
        public string? Source { get; set; }
        public int? CityId { get; set; }
        public DateTime? From { get; set; }
        public DateTime? To { get; set; }
        public int? Guests { get; set; }
        public int? RoomTypeId { get; set; }
        public double? MinRating { get; set; }
        public decimal? MinPrice { get; set; }
        public decimal? MaxPrice { get; set; }
    }

    private class SearchAuditDto
    {
        public int Id { get; set; }
        public int CityId { get; set; }
        public string City { get; set; } = "";
        public Guid? UserId { get; set; }
        public DateTime CheckIn { get; set; }
        public DateTime CheckOut { get; set; }
        public int Guests { get; set; }
        public decimal? MinPrice { get; set; }
        public decimal? MaxPrice { get; set; }
        public int? RoomTypeId { get; set; }
        public string? RoomType { get; set; }
        public double? MinRating { get; set; }
        public string Source { get; set; } = "";
        public DateTime CreatedAt { get; set; }
    }

    private class CityDto
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
    }

    private class RoomTypeDto
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
    }

    private class PagedResult<T>
    {
        public int Page { get; set; }
        public int PageSize { get; set; }
        public int TotalItems { get; set; }
        public int TotalPages { get; set; }
        public List<T> Items { get; set; } = new();
    }

    private class DashboardDto
    {
        public int TotalSearches { get; set; }
        public List<DashboardCountItem> BySource { get; set; } = new();
        public List<DashboardCityItem> TopCities { get; set; } = new();
        public List<DashboardDayItem> ByDay { get; set; } = new();
    }

    private class DashboardCountItem
    {
        public string Label { get; set; } = "";
        public int Count { get; set; }
    }

    private class DashboardCityItem
    {
        public int CityId { get; set; }
        public string Label { get; set; } = "";
        public int Count { get; set; }
    }

    private class DashboardDayItem
    {
        public DateTime Date { get; set; }
        public int Count { get; set; }
    }

    private class DashboardVm
    {
        public int TotalSearches { get; set; }
        public List<DashboardCountItem> BySource { get; set; } = new();
        public List<DashboardCityItem> TopCities { get; set; } = new();
        public List<DashboardDayItem> ByDay { get; set; } = new();

        public int BySourceMaxCount => BySource.Count == 0 ? 0 : BySource.Max(x => x.Count);
        public int TopCitiesMaxCount => TopCities.Count == 0 ? 0 : TopCities.Max(x => x.Count);
        public int ByDayMaxCount => ByDay.Count == 0 ? 0 : ByDay.Max(x => x.Count);
    }
}