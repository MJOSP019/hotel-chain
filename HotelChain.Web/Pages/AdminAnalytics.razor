    {
        public string Label { get; set; } = "";
        public int Searches { get; set; }
        public int Reservations { get; set; }
        public decimal ConversionRate { get; set; }
    }

    private class EmailExportRequest
    {
        public string? Email { get; set; }
    }

    private RenderFragment KpiCard(string Label, string Value, string Hint) => @<div class="hc-kpi">
        <div class="hc-kpi-label">@Label</div>
        <div class="hc-kpi-value">@Value</div>
        <div class="hc-kpi-hint">@Hint</div>
    </div>;

    private RenderFragment AnalyticsChart(string Title, List<DashboardCountItem> Items, string EmptyText) => @<div class="hc-analytics-card h-100">
        <h5 class="mb-2">@Title</h5>
        @if (Items.Count == 0)
        {
            <p class="text-muted mb-0">@EmptyText</p>
        }
        else
        {
            @foreach (var item in Items)
            {
                <div class="hc-chart-row">
                    <div class="hc-chart-label">
                        <span>@item.Label</span>
                        <strong>@item.Count</strong>
                    </div>
                    <div class="hc-chart-track">
                        <div class="hc-chart-bar" style="width:@BarWidth(item.Count, MaxCount(Items))"></div>
                    </div>
                </div>
            }
        }
    </div>;

    private RenderFragment AnalyticsDateChart(string Title, List<DashboardDateItem> Items, string EmptyText) => @<div class="hc-analytics-card h-100">
        <h5 class="mb-2">@Title</h5>
        @if (Items.Count == 0)
        {
            <p class="text-muted mb-0">@EmptyText</p>
        }
        else
        {
            @foreach (var item in Items)
            {
                <div class="hc-chart-row">
                    <div class="hc-chart-label">
                        <span>@item.Date.ToString("dd/MM")</span>
                        <strong>@item.Count</strong>
                    </div>
                    <div class="hc-chart-track">
                        <div class="hc-chart-bar" style="width:@BarWidth(item.Count, MaxDateCount(Items))"></div>
                    </div>
                </div>
            }
        }
    </div>;
}
