@page "/hotels/{Id:int}"
@using System.Net.Http.Headers
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.WebUtilities
@using HotelChain.Web.Models
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>Detalle del hotel</PageTitle>

<div class="hotel-detail-page">
    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger hotel-alert">@errorMessage</div>
    }
    else if (hotel is null)
    {
        <div class="hotel-loading">
            <div class="hotel-loading__card">
                <h4>Cargando información del hotel...</h4>
                <p>Estamos obteniendo el detalle, las opciones de habitación y las opiniones publicadas.</p>
            </div>
        </div>
    }
    else
    {
        <section class="hotel-hero">
            <div class="hotel-hero__top">
                <button class="btn hotel-btn-secondary" @onclick="GoBackToSearch">
                    Volver a resultados
                </button>
            </div>

            <div class="hotel-hero__content">
                <div class="hotel-hero__main">
                    <div class="hotel-badge">HotelChain Collection · Propiedad de la cadena</div>
                    <h1>@hotel.Name</h1>
                    <p class="hotel-hero__city">@hotel.City</p>

                    <div class="hotel-hero__meta">
                        <div class="hotel-meta-card">
                            <span class="hotel-meta-card__label">Código</span>
                            <strong>@hotel.Code</strong>
                        </div>

                        <div class="hotel-meta-card hotel-meta-card--wide">
                            <span class="hotel-meta-card__label">Dirección</span>
                            <strong>@hotel.Address</strong>
                        </div>

                        @if (HasSearchContext)
                        {
                            <div class="hotel-meta-card">
                                <span class="hotel-meta-card__label">Estadía</span>
                                <strong>@GetStaySummary()</strong>
                            </div>

                            <div class="hotel-meta-card">
                                <span class="hotel-meta-card__label">Noches</span>
                                <strong>@GetStayNights()</strong>
                            </div>
                        }
                    </div>
                </div>

                <div class="hotel-rating-card">
                    <div class="hotel-rating-card__stars">@GetStars(hotel.AverageRating)</div>
                    <div class="hotel-rating-card__value">
                        @(hotel.ReviewsCount > 0 ? hotel.AverageRating.ToString("0.00") : "Sin calificaciones")
                    </div>
                    <div class="hotel-rating-card__count">@GetReviewsLabel(hotel.ReviewsCount)</div>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(hotel.Description))
            {
                <div class="hotel-description-panel">
                    <div class="hotel-description-panel__label">Descripción del hotel</div>
                    <p>@hotel.Description</p>
                </div>
            }
            else
            {
                <div class="hotel-description-panel">
                    <div class="hotel-description-panel__label">Descripción del hotel</div>
                    <p>Este hotel forma parte de nuestra cadena y cuenta con opciones disponibles para tu próxima reservación.</p>
                </div>
            }
        </section>

        @if (!string.IsNullOrWhiteSpace(hotel.MainImageUrl))
        {
            <section class="hotel-section">
                <div class="hotel-main-image-card">
                    <img src="@hotel.MainImageUrl" alt="Imagen principal de @hotel.Name" class="hotel-main-image" />
                </div>
            </section>
        }

        <section class="hotel-section">
            <div class="hotel-info-grid">
                <article class="info-card">
                    <div class="info-card__label">Ciudad</div>
                    <h4>@hotel.City</h4>
                    <p>Ubicación donde se encuentra este hotel dentro de la cadena.</p>
                </article>

                <article class="info-card">
                    <div class="info-card__label">Dirección</div>
                    <h4>Ubicación del hotel</h4>
                    <p>@hotel.Address</p>
                </article>

                <article class="info-card">
                    <div class="info-card__label">Experiencia</div>
                    <h4>Opiniones de huéspedes</h4>
                    <p>@GetExperienceText()</p>
                </article>

                <article class="info-card">
                    <div class="info-card__label">Proceso de reserva</div>
                    <h4>Reserva directa desde el detalle</h4>
                    <p>@GetBookingProcessText()</p>
                </article>
            </div>
        </section>

        @if (!string.IsNullOrWhiteSpace(hotel.Amenities) || !string.IsNullOrWhiteSpace(hotel.ZoneInfo))
        {
            <section class="hotel-section">
                <div class="hotel-info-grid">
                    @if (!string.IsNullOrWhiteSpace(hotel.Amenities))
                    {
                        <article class="info-card info-card--wide">
                            <div class="info-card__label">Amenidades</div>
                            <h4>Servicios principales del hotel</h4>
                            <p>@hotel.Amenities</p>
                        </article>
                    }

                    @if (!string.IsNullOrWhiteSpace(hotel.ZoneInfo))
                    {
                        <article class="info-card info-card--wide">
                            <div class="info-card__label">Zona</div>
                            <h4>Información del entorno</h4>
                            <p>@hotel.ZoneInfo</p>
                        </article>
                    }
                </div>
            </section>
        }

        @if (HasSearchContext)
        {
            <section class="hotel-section">
                <div class="booking-context-card">
                    <div class="booking-context-card__item">
                        <span class="booking-context-card__label">Check-in</span>
                        <strong>@searchCheckIn?.ToString("dd/MM/yyyy")</strong>
                    </div>

                    <div class="booking-context-card__item">
                        <span class="booking-context-card__label">Check-out</span>
                        <strong>@searchCheckOut?.ToString("dd/MM/yyyy")</strong>
                    </div>

                    <div class="booking-context-card__item">
                        <span class="booking-context-card__label">Huéspedes</span>
                        <strong>@searchGuests</strong>
                    </div>

                    <div class="booking-context-card__item">
                        <span class="booking-context-card__label">Noches</span>
                        <strong>@GetStayNights()</strong>
                    </div>
                </div>
            </section>
        }

        <section class="hotel-section">
            <div class="hotel-section__header hotel-section__header--with-action">
                <div>
                    <div class="hotel-badge hotel-badge--light">Habitaciones</div>
                    <h3>Opciones de habitación</h3>
                    <p>
                        Explora las habitaciones activas disponibles en esta propiedad de la cadena
                        y continúa con tu proceso de reservación.
                    </p>
                </div>

                <div class="hotel-section__actions">
                    <button class="btn hotel-btn-secondary" @onclick="GoBackToSearch">
                        Volver a resultados
                    </button>
                </div>
            </div>

            @if (hotel.RoomOptions is not null && hotel.RoomOptions.Any())
            {
                <div class="rooms-summary-card">
                    <div class="rooms-summary-card__item">
                        <span class="rooms-summary-card__label">Opciones disponibles</span>
                        <strong>@hotel.RoomOptions.Count</strong>
                    </div>

                    <div class="rooms-summary-card__item">
                        <span class="rooms-summary-card__label">Precio más bajo</span>
                        <strong>Q @hotel.RoomOptions.Min(x => x.BasePricePerNight).ToString("0.00")</strong>
                    </div>

                    <div class="rooms-summary-card__item">
                        <span class="rooms-summary-card__label">Capacidad máxima</span>
                        <strong>@hotel.RoomOptions.Max(x => x.MaxGuests) huésped(es)</strong>
                    </div>

                    <div class="rooms-summary-card__item">
                        <span class="rooms-summary-card__label">Con imagen</span>
                        <strong>@hotel.RoomOptions.Count(x => !string.IsNullOrWhiteSpace(x.ImageUrl))</strong>
                    </div>
                </div>

                <div class="rooms-grid">
                    @foreach (var room in hotel.RoomOptions.OrderBy(x => x.BasePricePerNight).ThenBy(x => x.RoomType))
                    {
                        <article class="room-card">
                            @if (!string.IsNullOrWhiteSpace(room.ImageUrl))
                            {
                                <div class="room-card__image-wrapper">
                                    <img src="@room.ImageUrl" alt="Imagen de referencia de @room.RoomType" class="room-card__image" />
                                </div>
                            }
                            else
                            {
                                <div class="room-card__image-placeholder">
                                    <span>Sin imagen de referencia</span>
                                </div>
                            }

                            <div class="room-card__header">
                                <div>
                                    <div class="room-card__eyebrow">Opción de habitación</div>
                                    <h4>@room.RoomType</h4>
                                </div>

                                <div class="room-card__price">
                                    <span class="room-card__price-label">Precio</span>
                                    <span class="room-card__price-value">Q @room.BasePricePerNight.ToString("0.00")</span>
                                    <span class="room-card__price-suffix">por noche</span>
                                </div>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(room.ShortDescription))
                            {
                                <p class="room-card__description">@room.ShortDescription</p>
                            }

                            <div class="room-card__body">
                                <div class="room-feature">
                                    <span class="room-feature__label">Tipo</span>
                                    <strong>@room.RoomType</strong>
                                </div>

                                <div class="room-feature">
                                    <span class="room-feature__label">Máx. huéspedes</span>
                                    <strong>@room.MaxGuests</strong>
                                </div>

                                <div class="room-feature">
                                    <span class="room-feature__label">Disponibles</span>
                                    <strong>@room.AvailableUnits</strong>
                                </div>

                                <div class="room-feature">
                                    <span class="room-feature__label">Cama</span>
                                    <strong>@(string.IsNullOrWhiteSpace(room.BedType) ? "No especificada" : room.BedType)</strong>
                                </div>

                                <div class="room-feature">
                                    <span class="room-feature__label">Área</span>
                                    <strong>@GetAreaText(room.AreaSquareMeters)</strong>
                                </div>
                            </div>

                            @if (HasSearchContext)
                            {
                                <div class="room-estimate-card">
                                    <span class="room-estimate-card__label">Total estimado para tu estadía</span>
                                    <strong>Q @GetEstimatedStayTotal(room.BasePricePerNight).ToString("0.00")</strong>
                                </div>
                            }

                            <div class="room-card__footer">
                                <p class="room-card__hint">
                                    @GetRoomHint()
                                </p>

                                <button class="btn hotel-btn-primary hotel-btn-primary--full" @onclick="() => ReserveRoom(room.RoomTypeId)">
                                    Reservar esta opción
                                </button>
                            </div>
                        </article>
                    }
                </div>
            }
            else
            {
                <div class="empty-card">
                    <h4>Sin habitaciones activas</h4>
                    <p>No hay opciones de habitación activas para este hotel en este momento.</p>
                </div>
            }
        </section>

        <section class="hotel-section">
            <div class="hotel-section__header">
                <div>
                    <div class="hotel-badge hotel-badge--light">Opiniones</div>
                    <h3>Comentarios y calificaciones</h3>
                    <p>Opiniones compartidas por usuarios registrados sobre su experiencia en este hotel.</p>
                </div>
            </div>

            @if (hotel.Reviews is not null && hotel.Reviews.Any())
            {
                <div class="reviews-summary">
                    <div class="reviews-summary__score">
                        <span class="reviews-summary__value">@hotel.AverageRating.ToString("0.00")</span>
                        <span class="reviews-summary__stars">@GetStars(hotel.AverageRating)</span>
                    </div>

                    <div class="reviews-summary__text">
                        <strong>@GetReviewsLabel(hotel.ReviewsCount)</strong>
                        <p>Las opiniones ayudan a otros usuarios a conocer mejor la experiencia de hospedarse en este hotel.</p>
                    </div>
                </div>

                <div class="reviews-list">
                    @foreach (var review in hotel.Reviews.OrderByDescending(x => x.CreatedAt))
                    {
                        @RenderReview(review, 0)
                    }
                </div>
            }
            else
            {
                <div class="empty-card">
                    <h4>Sin opiniones todavía</h4>
                    <p>Este hotel todavía no tiene comentarios publicados. Sé la primera persona en compartir su experiencia.</p>
                </div>
            }
        </section>

        @if (isLoggedIn)
        {
            <section class="hotel-section">
                <div class="review-form-card">
                    <div class="hotel-section__header mb-3">
                        <div>
                            <div class="hotel-badge hotel-badge--light">Tu opinión</div>
                            <h3>Comparte tu experiencia</h3>
                            <p>Califica este hotel y deja un comentario para otros usuarios de la cadena.</p>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(successMessage))
                    {
                        <div class="alert alert-success hotel-alert">@successMessage</div>
                    }

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="hotel-label">Calificación</label>
                            <select class="form-select hotel-input" @bind="newReview.Rating">
                                <option value="1">1 estrella</option>
                                <option value="2">2 estrellas</option>
                                <option value="3">3 estrellas</option>
                                <option value="4">4 estrellas</option>
                                <option value="5">5 estrellas</option>
                            </select>
                        </div>

                        <div class="col-12">
                            <label class="hotel-label">Comentario</label>
                            <textarea class="form-control hotel-input hotel-textarea" rows="5" @bind="newReview.Comment" placeholder="Cuéntanos cómo fue tu experiencia en este hotel."></textarea>
                        </div>
                    </div>

                    <div class="mt-3">
                        <button class="btn hotel-btn-primary" @onclick="SubmitReview">
                            Publicar opinión
                        </button>
                    </div>
                </div>
            </section>
        }
        else
        {
            <div class="alert alert-info hotel-alert">
                Inicia sesión para comentar y calificar este hotel.
            </div>
        }
    }
</div>

<style>
    .hotel-detail-page {
        padding: 1.5rem 0 2rem 0;
        color: #0f172a;
    }

    .hotel-alert {
        border-radius: 16px;
    }

    .hotel-loading {
        padding: 2rem 0;
    }

    .hotel-loading__card {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 24px;
        padding: 2rem;
        box-shadow: 0 14px 35px rgba(15, 23, 42, 0.08);
    }

    .hotel-loading__card h4 {
        margin-bottom: 0.5rem;
        font-weight: 800;
    }

    .hotel-loading__card p {
        margin: 0;
        color: #64748b;
    }

    .hotel-hero {
        background:
            radial-gradient(circle at top right, rgba(59, 130, 246, 0.16), transparent 26%),
            linear-gradient(135deg, #0f172a 0%, #162033 45%, #1e293b 100%);
        color: #fff;
        border-radius: 28px;
        padding: 1.5rem 1.5rem 2rem 1.5rem;
        margin-bottom: 1.5rem;
        box-shadow: 0 24px 60px rgba(15, 23, 42, 0.22);
        position: relative;
        overflow: hidden;
    }

    .hotel-hero::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg, rgba(255,255,255,0.02), transparent 30%);
        pointer-events: none;
    }

    .hotel-hero__top,
    .hotel-hero__content,
    .hotel-description-panel {
        position: relative;
        z-index: 1;
    }

    .hotel-hero__top {
        margin-bottom: 1.25rem;
    }

    .hotel-hero__content {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1.5rem;
        flex-wrap: wrap;
    }

    .hotel-hero__main {
        flex: 1 1 620px;
    }

    .hotel-badge {
        display: inline-flex;
        align-items: center;
        padding: 0.38rem 0.75rem;
        border-radius: 999px;
        background: rgba(255,255,255,0.12);
        color: #dbeafe;
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.03em;
        text-transform: uppercase;
        margin-bottom: 1rem;
    }

    .hotel-badge--light {
        background: #eff6ff;
        color: #1d4ed8;
    }

    .hotel-hero h1 {
        font-size: clamp(2rem, 4vw, 3.1rem);
        font-weight: 800;
        margin-bottom: 0.55rem;
        line-height: 1.05;
    }

    .hotel-hero__city {
        font-size: 1.02rem;
        color: rgba(255,255,255,0.78);
        margin-bottom: 1.15rem;
    }

    .hotel-hero__meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.85rem;
    }

    .hotel-meta-card {
        min-width: 170px;
        padding: 0.95rem 1rem;
        border-radius: 18px;
        background: rgba(255,255,255,0.10);
        border: 1px solid rgba(255,255,255,0.12);
        backdrop-filter: blur(6px);
    }

    .hotel-meta-card--wide {
        min-width: 280px;
        max-width: 520px;
    }

    .hotel-meta-card__label {
        display: block;
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: rgba(255,255,255,0.70);
        margin-bottom: 0.2rem;
    }

    .hotel-meta-card strong {
        color: #fff;
        font-size: 1rem;
    }

    .hotel-rating-card {
        min-width: 220px;
        padding: 1.2rem;
        border-radius: 22px;
        background: rgba(255,255,255,0.10);
        border: 1px solid rgba(255,255,255,0.12);
        text-align: center;
        backdrop-filter: blur(6px);
    }

    .hotel-rating-card__stars {
        font-size: 1.35rem;
        color: #fbbf24;
        letter-spacing: 0.05em;
        margin-bottom: 0.45rem;
    }

    .hotel-rating-card__value {
        font-size: 1.75rem;
        font-weight: 800;
        color: #fff;
        line-height: 1.1;
    }

    .hotel-rating-card__count {
        margin-top: 0.25rem;
        color: rgba(255,255,255,0.72);
        font-size: 0.95rem;
    }

    .hotel-description-panel {
        margin-top: 1.5rem;
        padding: 1rem 1.1rem;
        border-radius: 20px;
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.10);
    }

    .hotel-description-panel__label {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: rgba(255,255,255,0.72);
        margin-bottom: 0.35rem;
        font-weight: 700;
    }

    .hotel-description-panel p {
        margin: 0;
        color: rgba(255,255,255,0.90);
        line-height: 1.65;
    }

    .hotel-main-image-card {
        background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
        border: 1px solid #e2e8f0;
        border-radius: 24px;
        padding: 0.8rem;
        box-shadow: 0 14px 30px rgba(15, 23, 42, 0.06);
    }

    .hotel-main-image {
        width: 100%;
        height: 340px;
        object-fit: cover;
        border-radius: 18px;
        display: block;
    }

    .hotel-section {
        margin-top: 1.5rem;
    }

    .hotel-section__header {
        margin-bottom: 1rem;
    }

    .hotel-section__header--with-action {
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .hotel-section__header h3 {
        margin: 0.3rem 0 0.25rem 0;
        font-weight: 800;
        color: #0f172a;
    }

    .hotel-section__header p {
        margin: 0;
        color: #64748b;
    }

    .hotel-section__actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .hotel-info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1rem;
    }

    .info-card {
        background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
        border: 1px solid #e2e8f0;
        border-radius: 22px;
        padding: 1.2rem;
        box-shadow: 0 14px 30px rgba(15, 23, 42, 0.06);
    }

    .info-card--wide {
        min-height: 100%;
    }

    .info-card__label {
        font-size: 0.76rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #64748b;
        margin-bottom: 0.35rem;
        font-weight: 700;
    }

    .info-card h4 {
        margin: 0 0 0.4rem 0;
        font-size: 1.05rem;
        color: #0f172a;
        font-weight: 800;
    }

    .info-card p {
        margin: 0;
        color: #475569;
        line-height: 1.6;
        white-space: pre-line;
    }

    .booking-context-card {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 1rem;
        background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
        border: 1px solid #e2e8f0;
        border-radius: 22px;
        padding: 1rem;
        box-shadow: 0 12px 28px rgba(15, 23, 42, 0.06);
    }

    .booking-context-card__item {
        background: rgba(255,255,255,0.78);
        border: 1px solid #e2e8f0;
        border-radius: 18px;
        padding: 0.85rem;
    }

    .booking-context-card__label {
        display: block;
        font-size: 0.76rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #64748b;
        margin-bottom: 0.25rem;
        font-weight: 700;
    }

    .booking-context-card__item strong {
        color: #0f172a;
        font-size: 1rem;
    }

    .rooms-summary-card {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 1rem;
        margin-bottom: 1rem;
        background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
        border: 1px solid #e2e8f0;
        border-radius: 22px;
        padding: 1rem;
        box-shadow: 0 12px 28px rgba(15, 23, 42, 0.06);
    }

    .rooms-summary-card__item {
        background: rgba(255,255,255,0.78);
        border: 1px solid #e2e8f0;
        border-radius: 18px;
        padding: 0.85rem;
    }

    .rooms-summary-card__label {
        display: block;
        font-size: 0.76rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #64748b;
        margin-bottom: 0.25rem;
        font-weight: 700;
    }

    .rooms-summary-card__item strong {
        color: #0f172a;
        font-size: 1rem;
    }

    .rooms-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 1rem;
        margin-top: 1rem;
    }

    .room-card {
        background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
        border: 1px solid #e2e8f0;
        border-radius: 24px;
        padding: 1.2rem;
        box-shadow: 0 16px 34px rgba(15, 23, 42, 0.07);
        display: flex;
        flex-direction: column;
        gap: 1rem;
        height: 100%;
    }

    .room-card__image-wrapper {
        margin: -0.2rem -0.2rem 0 -0.2rem;
    }

    .room-card__image {
        width: 100%;
        height: 210px;
        object-fit: cover;
