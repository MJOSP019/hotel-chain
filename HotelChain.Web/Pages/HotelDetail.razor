@code {
    [Parameter]
    public int Id { get; set; }

    private HotelDetailDto? hotel;
    private string? errorMessage;
    private string? successMessage;
    private bool isLoggedIn;

    private int? searchCityId;
    private DateTime? searchCheckIn;
    private DateTime? searchCheckOut;
    private int? searchGuests;

    private int? replyingToReviewId;
    private string replyText = "";
    private HashSet<int> collapsedReviewIds = new();

    private CreateHotelReviewRequest newReview = new()
    {
        Rating = 5,
        Comment = ""
    };

    private bool HasSearchContext =>
        searchCheckIn.HasValue && searchCheckOut.HasValue && searchGuests.HasValue;

    protected override async Task OnInitializedAsync()
    {
        ReadSearchContextFromQuery();
        await CheckLoginAsync();
        await LoadHotelAsync();
    }

    private void ReadSearchContextFromQuery()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var qs = QueryHelpers.ParseQuery(uri.Query);

        if (qs.TryGetValue("cityId", out var cityIdStr) && int.TryParse(cityIdStr, out var cityId))
            searchCityId = cityId;

        if (qs.TryGetValue("guests", out var guestsStr) && int.TryParse(guestsStr, out var guests))
            searchGuests = guests;

        if (qs.TryGetValue("checkIn", out var checkInStr) && DateTime.TryParse(checkInStr, out var checkIn))
            searchCheckIn = checkIn;

        if (qs.TryGetValue("checkOut", out var checkOutStr) && DateTime.TryParse(checkOutStr, out var checkOut))
            searchCheckOut = checkOut;
    }

    private async Task CheckLoginAsync()
    {
        var token = await JS.InvokeAsync<string>("auth.getToken");
        isLoggedIn = !string.IsNullOrWhiteSpace(token);
    }

    private async Task LoadHotelAsync()
    {
        try
        {
            errorMessage = null;

            var http = HttpClientFactory.CreateClient("Api");
            var query = new List<string>();

            if (searchCheckIn.HasValue)
                query.Add($"checkIn={searchCheckIn.Value:yyyy-MM-dd}");

            if (searchCheckOut.HasValue)
                query.Add($"checkOut={searchCheckOut.Value:yyyy-MM-dd}");

            if (searchGuests.HasValue)
                query.Add($"guests={searchGuests.Value}");

            var url = $"api/public/hotels/{Id}";
            if (query.Count > 0)
                url += $"?{string.Join("&", query)}";

            hotel = await http.GetFromJsonAsync<HotelDetailDto>(url);

            if (hotel is not null)
            {
                collapsedReviewIds = new HashSet<int>();
                CollapseRepliesByDefault(hotel.Reviews);
            }

            if (hotel is null)
            {
                errorMessage = "No se pudo cargar el detalle del hotel.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error cargando hotel: {ex.Message}";
        }
    }

    private async Task SubmitReview()
    {
        try
        {
            errorMessage = null;
            successMessage = null;

            if (newReview.Rating < 1 || newReview.Rating > 5)
            {
                errorMessage = "La calificación debe estar entre 1 y 5.";
                return;
            }

            var token = await JS.InvokeAsync<string>("auth.getToken");
            if (string.IsNullOrWhiteSpace(token))
            {
                errorMessage = "Debes iniciar sesión.";
                return;
            }

            var http = HttpClientFactory.CreateClient("Api");
            http.DefaultRequestHeaders.Authorization =
                new AuthenticationHeaderValue("Bearer", token);

            var response = await http.PostAsJsonAsync(
                $"api/public/hotels/{Id}/reviews",
                newReview);

            if (response.IsSuccessStatusCode)
            {
                successMessage = "Tu opinión se publicó correctamente.";

                newReview = new CreateHotelReviewRequest
                {
                    Rating = 5,
                    Comment = ""
                };

                await LoadHotelAsync();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                errorMessage = $"No se pudo publicar la opinión. {body}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al publicar comentario: {ex.Message}";
        }
    }

    private async Task SubmitReply(int parentReviewId)
    {
        try
        {
            errorMessage = null;
            successMessage = null;

            if (string.IsNullOrWhiteSpace(replyText))
            {
                errorMessage = "La respuesta no puede estar vacía.";
                return;
            }

            var token = await JS.InvokeAsync<string>("auth.getToken");
            if (string.IsNullOrWhiteSpace(token))
            {
                errorMessage = "Debes iniciar sesión.";
                return;
            }

            var http = HttpClientFactory.CreateClient("Api");
            http.DefaultRequestHeaders.Authorization =
                new AuthenticationHeaderValue("Bearer", token);

            var response = await http.PostAsJsonAsync(
                $"api/public/hotels/{Id}/reviews",
                new CreateHotelReviewRequest
                {
                    Rating = 0,
                    Comment = replyText.Trim(),
                    ParentReviewId = parentReviewId
                });

            if (response.IsSuccessStatusCode)
            {
                successMessage = "Tu respuesta se publicó correctamente.";
                replyText = "";
                replyingToReviewId = null;
                await LoadHotelAsync();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                errorMessage = $"No se pudo publicar la respuesta. {body}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al publicar respuesta: {ex.Message}";
        }
    }

    private void StartReply(int reviewId)
    {
        replyingToReviewId = reviewId;
        replyText = "";
        successMessage = null;
    }

    private void CancelReply()
    {
        replyingToReviewId = null;
        replyText = "";
    }

    private bool HasReplies(HotelReviewDto review)
    {
        return review.Replies is not null && review.Replies.Any();
    }

    private bool AreRepliesExpanded(HotelReviewDto review)
    {
        return !collapsedReviewIds.Contains(review.Id);
    }

    private void ToggleReplies(int reviewId)
    {
        if (!collapsedReviewIds.Add(reviewId))
            collapsedReviewIds.Remove(reviewId);
    }

    private void CollapseRepliesByDefault(IEnumerable<HotelReviewDto> reviews)
    {
        foreach (var review in reviews)
        {
            if (HasReplies(review))
                collapsedReviewIds.Add(review.Id);

            if (review.Replies is not null && review.Replies.Any())
                CollapseRepliesByDefault(review.Replies);
        }
    }

    private async Task ReserveRoom(int roomTypeId)
    {
        try
        {
            errorMessage = null;
            successMessage = null;

            if (!searchCheckIn.HasValue || !searchCheckOut.HasValue || !searchGuests.HasValue)
            {
                errorMessage = "Para reservar desde esta vista necesitas llegar con fechas y número de huéspedes desde la búsqueda.";
                return;
            }

            var token = await JS.InvokeAsync<string>("auth.getToken");
            if (string.IsNullOrWhiteSpace(token))
            {
                errorMessage = "Debes iniciar sesión para reservar.";
                return;
            }

            var http = HttpClientFactory.CreateClient("Api");
            http.DefaultRequestHeaders.Authorization =
                new AuthenticationHeaderValue("Bearer", token);

            var body = new
            {
                hotelId = Id,
                roomTypeId = roomTypeId,
                checkIn = searchCheckIn.Value,
                checkOut = searchCheckOut.Value,
                guests = searchGuests.Value
            };

            var response = await http.PostAsJsonAsync("api/public/reservations", body);

            if (response.IsSuccessStatusCode)
            {
                var data = await response.Content.ReadFromJsonAsync<ReserveResponse>();

                if (data is not null)
                {
                    successMessage = $"Reserva creada correctamente: {data.Code}";
                    Navigation.NavigateTo($"/checkout?code={data.Code}");
                    return;
                }

                successMessage = "Reserva creada correctamente.";
                return;
            }

            var errorBody = await response.Content.ReadAsStringAsync();
            errorMessage = $"No se pudo crear la reserva. {errorBody}";
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al reservar habitación: {ex.Message}";
        }
    }

    private void GoBackToSearch()
    {
        var query = new Dictionary<string, string?>();

        if (searchCityId.HasValue)
            query["cityId"] = searchCityId.Value.ToString();

        if (searchCheckIn.HasValue)
            query["checkIn"] = searchCheckIn.Value.ToString("yyyy-MM-dd");

        if (searchCheckOut.HasValue)
            query["checkOut"] = searchCheckOut.Value.ToString("yyyy-MM-dd");

        if (searchGuests.HasValue)
            query["guests"] = searchGuests.Value.ToString();

        var url = QueryHelpers.AddQueryString("/search", query);
        Navigation.NavigateTo(url);
    }

    private string GetStaySummary()
    {
        if (!searchCheckIn.HasValue || !searchCheckOut.HasValue || !searchGuests.HasValue)
            return "Sin contexto";

        return $"{searchCheckIn:dd/MM} - {searchCheckOut:dd/MM} · {searchGuests} huésped(es)";
    }

    private int GetStayNights()
    {
        if (!searchCheckIn.HasValue || !searchCheckOut.HasValue)
            return 0;

        var nights = (searchCheckOut.Value.Date - searchCheckIn.Value.Date).Days;
        return nights > 0 ? nights : 0;
    }

    private decimal GetEstimatedStayTotal(decimal pricePerNight)
    {
        var nights = GetStayNights();
        return nights > 0 ? pricePerNight * nights : pricePerNight;
    }

    private string GetAreaText(decimal? areaSquareMeters)
    {
        if (!areaSquareMeters.HasValue || areaSquareMeters.Value <= 0)
            return "No especificada";

        return $"{areaSquareMeters.Value:0.##} m²";
    }

    private string GetRoomHint()
    {
        if (HasSearchContext)
            return $"Disponible para la estadía seleccionada: {searchCheckIn:dd/MM/yyyy} al {searchCheckOut:dd/MM/yyyy}, para {searchGuests} huésped(es).";

        return "Para reservar esta opción, vuelve a la búsqueda y selecciona las fechas y huéspedes de tu viaje.";
    }

    private string GetBookingProcessText()
    {
        if (HasSearchContext)
            return "Ya traes fechas y huéspedes desde la búsqueda, así que puedes reservar directamente desde esta página.";

        return "Puedes revisar la información del hotel aquí y luego volver a la búsqueda para seleccionar fechas y huéspedes antes de reservar.";
    }

    private string GetStars(decimal rating)
    {
        var rounded = (int)Math.Round(rating, MidpointRounding.AwayFromZero);
        rounded = Math.Max(0, Math.Min(5, rounded));

        return new string('★', rounded) + new string('☆', 5 - rounded);
    }

    private string GetStars(int rating)
    {
        var normalized = Math.Max(0, Math.Min(5, rating));
        return new string('★', normalized) + new string('☆', 5 - normalized);
    }

    private string GetReviewsLabel(int count)
    {
        return count switch
        {
            0 => "Sin opiniones publicadas",
            1 => "1 opinión publicada",
            _ => $"{count} opiniones publicadas"
        };
    }

    private string GetExperienceText()
    {
        if (hotel is null)
            return "Aún no hay suficiente información disponible.";

        if (hotel.ReviewsCount == 0)
            return "Todavía no hay opiniones publicadas para este hotel.";

        if (hotel.AverageRating >= 4.5m)
            return "Los usuarios han dejado una experiencia excelente en este hotel.";

        if (hotel.AverageRating >= 4.0m)
            return "Los usuarios han valorado muy bien su estadía en este hotel.";

        if (hotel.AverageRating >= 3.0m)
            return "Este hotel cuenta con opiniones positivas y comentarios útiles para nuevos huéspedes.";

        return "Las opiniones publicadas pueden ayudarte a evaluar mejor este hotel antes de reservar.";
    }

    private RenderFragment RenderReview(HotelReviewDto review, int level) => builder =>
    {
        var sequence = 0;
        var isReply = level > 0;
        var visualLevel = Math.Min(level, 4);
        var margin = visualLevel * 24;

        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "review-thread");
        builder.AddAttribute(sequence++, "style", $"margin-left:{margin}px;");

        builder.OpenElement(sequence++, "article");
        builder.AddAttribute(sequence++, "class", isReply ? "review-card review-card--reply" : "review-card");

        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "review-card__header");

        builder.OpenElement(sequence++, "div");

        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "review-card__user");
        builder.AddContent(sequence++, review.UserName);
        builder.CloseElement();

        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "review-card__meta");

        if (isReply)
        {
            builder.OpenElement(sequence++, "span");
            builder.AddAttribute(sequence++, "class", "review-card__tag");
            builder.AddContent(sequence++, "Respuesta");
            builder.CloseElement();
        }

        if (!review.ParentReviewId.HasValue)
        {
            builder.OpenElement(sequence++, "div");
            builder.AddAttribute(sequence++, "class", "review-card__rating");
            builder.AddContent(sequence++, GetStars(review.Rating));

            builder.OpenElement(sequence++, "span");
            builder.AddAttribute(sequence++, "class", "review-card__rating-text");
            builder.AddContent(sequence++, $"({review.Rating}/5)");
            builder.CloseElement();

            builder.CloseElement();
        }

        builder.CloseElement();
        builder.CloseElement();

        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "review-card__date");
        builder.AddContent(sequence++, review.CreatedAt.ToString("dd/MM/yyyy HH:mm"));
        builder.CloseElement();

        builder.CloseElement();

        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class",
            string.IsNullOrWhiteSpace(review.Comment)
                ? "review-card__body review-card__body--muted"
                : "review-card__body");
        builder.AddContent(sequence++,
            string.IsNullOrWhiteSpace(review.Comment)
                ? "El usuario publicó una calificación sin comentario adicional."
                : review.Comment);
        builder.CloseElement();

        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "review-card__actions");

        if (isLoggedIn)
        {
            builder.OpenElement(sequence++, "button");
            builder.AddAttribute(sequence++, "type", "button");
            builder.AddAttribute(sequence++, "class", "review-reply-button");
            builder.AddAttribute(sequence++, "onclick", EventCallback.Factory.Create(this, () => StartReply(review.Id)));
            builder.AddContent(sequence++, "Responder");
            builder.CloseElement();
        }

        if (HasReplies(review))
        {
            builder.OpenElement(sequence++, "button");
            builder.AddAttribute(sequence++, "type", "button");
            builder.AddAttribute(sequence++, "class", "review-toggle-button");
            builder.AddAttribute(sequence++, "onclick", EventCallback.Factory.Create(this, () => ToggleReplies(review.Id)));
            builder.AddContent(
                sequence++,
                AreRepliesExpanded(review)
                    ? "Ocultar respuestas"
                    : $"Ver respuestas ({review.Replies.Count})");
            builder.CloseElement();
        }

        builder.CloseElement();

        if (replyingToReviewId == review.Id)
        {
            builder.OpenElement(sequence++, "div");
            builder.AddAttribute(sequence++, "class", "review-reply-form");

            builder.OpenElement(sequence++, "label");
            builder.AddAttribute(sequence++, "class", "hotel-label");
            builder.AddContent(sequence++, "Tu respuesta");
            builder.CloseElement();

            builder.OpenElement(sequence++, "textarea");
            builder.AddAttribute(sequence++, "class", "form-control hotel-input hotel-textarea");
            builder.AddAttribute(sequence++, "rows", "4");
            builder.AddAttribute(sequence++, "placeholder", "Escribe tu respuesta a este comentario.");
            builder.AddAttribute(sequence++, "value", BindConverter.FormatValue(replyText));
            builder.AddAttribute(sequence++, "onchange", EventCallback.Factory.CreateBinder<string>(this, __value => replyText = __value, replyText));
            builder.CloseElement();

            builder.OpenElement(sequence++, "div");
            builder.AddAttribute(sequence++, "class", "review-reply-form__actions");

            builder.OpenElement(sequence++, "button");
            builder.AddAttribute(sequence++, "type", "button");
            builder.AddAttribute(sequence++, "class", "btn hotel-btn-primary");
            builder.AddAttribute(sequence++, "onclick", EventCallback.Factory.Create(this, () => SubmitReply(review.Id)));
            builder.AddContent(sequence++, "Publicar respuesta");
            builder.CloseElement();

            builder.OpenElement(sequence++, "button");
            builder.AddAttribute(sequence++, "type", "button");
            builder.AddAttribute(sequence++, "class", "btn hotel-btn-secondary");
            builder.AddAttribute(sequence++, "onclick", EventCallback.Factory.Create(this, CancelReply));
            builder.AddContent(sequence++, "Cancelar");
            builder.CloseElement();

            builder.CloseElement();
            builder.CloseElement();
        }

        builder.CloseElement();

        if (HasReplies(review) && AreRepliesExpanded(review))
        {
            builder.OpenElement(sequence++, "div");
            builder.AddAttribute(sequence++, "class", "review-thread__children");

            foreach (var reply in review.Replies.OrderBy(x => x.CreatedAt))
            {
                builder.AddContent(sequence++, RenderReview(reply, level + 1));
            }

            builder.CloseElement();
        }

        builder.CloseElement();
    };

    private class ReserveResponse
    {
        public int Id { get; set; }
        public string Code { get; set; } = "";
        public string Status { get; set; } = "";
        public decimal TotalAmount { get; set; }
    }
}
