        }
    }

    @@media (max-width: 767.98px) {
        .hc-shell__utility-inner,
        .hc-shell__content,
        .hc-shell__footer-top,
        .hc-shell__footer-bottom,
        .hc-shell__navbar-inner {
            width: min(100%, calc(100% - 1rem));
        }

        .hc-shell__content {
            padding-top: 1rem;
        }

        .hc-shell__footer-grid {
            grid-template-columns: 1fr;
        }

        .hc-shell__brand-text strong {
            font-size: 1.05rem;
        }

        .hc-shell__brand-text small {
            font-size: 0.82rem;
        }
