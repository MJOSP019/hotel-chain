        display: grid;
        grid-template-columns: minmax(260px, 320px) minmax(0, 1fr);
        gap: 2rem;
    }

    .hc-shell__footer-brand {
        min-width: 0;
    }

    .hc-shell__footer-logo {
        display: flex;
        align-items: flex-start;
        gap: 0.9rem;
    }

    .hc-shell__footer-logo-mark {
        width: 54px;
        height: 54px;
        border-radius: 16px;
        background: #111111;
        color: #ffffff;
        display: inline-flex;
        align-items: center;
        justify-content: center;
