@inherits LayoutComponentBase

<div class="hc-shell">
    <header class="hc-shell__header">
        <div class="hc-shell__utilitybar">
            <div class="hc-shell__utility-inner">
                <div class="hc-shell__utility-left">
                    <span class="hc-shell__utility-item">Portal oficial</span>
                    <span class="hc-shell__utility-separator">•</span>
                    <span class="hc-shell__utility-item">Cadena hotelera</span>
                </div>

                <div class="hc-shell__utility-right">
                    <a class="hc-shell__utility-link" href="/amenities">Amenidades</a>
                    <a class="hc-shell__utility-link" href="/check-in-checkout">Check-in y checkout</a>
                    <a class="hc-shell__utility-link" href="/my-reservations">Mis viajes</a>
                </div>
            </div>
        </div>

        <div class="hc-shell__navbar">
            <div class="hc-shell__navbar-inner">
                <a class="hc-shell__brand" href="/">
                    <span class="hc-shell__brand-mark">HC</span>

                    <span class="hc-shell__brand-text">
                        <strong>HotelChain Collection</strong>
                        <small>Reservas, estadías y experiencias dentro de la cadena</small>
                    </span>
                </a>

                <div class="hc-shell__nav">
                    <NavMenu />
                </div>
            </div>
        </div>
    </header>

    <main class="hc-shell__content">
        @Body
    </main>

    <footer class="hc-shell__footer">
        <div class="hc-shell__footer-top">
            <div class="hc-shell__footer-brand">
                <div class="hc-shell__footer-logo">
                    <span class="hc-shell__footer-logo-mark">HC</span>
                    <div>
                        <strong>HotelChain Collection</strong>
                        <p>Una experiencia de cadena hotelera con búsqueda, reserva, operación y seguimiento en un solo portal.</p>
                    </div>
                </div>
            </div>

            <div class="hc-shell__footer-grid">
                <div class="hc-shell__footer-column">
                    <h4>Atención al cliente</h4>
                    <a href="/search">Buscar hoteles</a>
                    <a href="/check-in-checkout">Proceso de check-in</a>
                    <a href="/hotel-rules">Políticas de hospedaje</a>
                    <a href="/evacuation-info">Seguridad y evacuación</a>
                </div>

                <div class="hc-shell__footer-column">
                    <h4>Explorar</h4>
                    <a href="/amenities">Amenidades</a>
                    <a href="/room-types">Tipos de habitación</a>
                    <a href="/login">Iniciar sesión</a>
                    <a href="/register">Crear cuenta</a>
                </div>

                <div class="hc-shell__footer-column">
                    <h4>Contacto</h4>
                    <span>Teléfono: +502 2222-0000</span>
                    <span>Dirección: Ciudad de Guatemala, Guatemala</span>
                    <span>Soporte: soporte@hotelchain.com</span>
                </div>

                <div class="hc-shell__footer-column">
                    <h4>Información legal</h4>
                    <a href="/hotel-rules">Términos y condiciones</a>
                    <a href="/hotel-rules">Políticas generales</a>
                    <a href="/evacuation-info">Información de seguridad</a>
                </div>
            </div>
        </div>

        <div class="hc-shell__footer-bottom">
            <span>© @DateTime.Now.Year HotelChain Collection. Todos los derechos reservados.</span>
        </div>
    </footer>
</div>

<style>
    .hc-shell {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        background: #f3f4f6;
        color: #111827;
    }

    .hc-shell__header {
        position: sticky;
        top: 0;
        z-index: 100;
        background: #ffffff;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.08);
    }

    .hc-shell__utilitybar {
        background: #111111;
        color: rgba(255,255,255,0.86);
        border-top: 3px solid #2f2f2f;
    }

    .hc-shell__utility-inner,
    .hc-shell__navbar-inner,
    .hc-shell__content,
    .hc-shell__footer-top,
    .hc-shell__footer-bottom {
        width: min(1280px, calc(100% - 2rem));
        margin: 0 auto;
    }

    .hc-shell__utility-inner {
        min-height: 42px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        font-size: 0.9rem;
    }

    .hc-shell__utility-left,
    .hc-shell__utility-right {
        display: flex;
        align-items: center;
        gap: 0.9rem;
        flex-wrap: wrap;
    }

    .hc-shell__utility-separator {
        opacity: 0.45;
    }

    .hc-shell__utility-link {
        color: rgba(255,255,255,0.86);
        text-decoration: none;
        font-weight: 500;
    }

    .hc-shell__utility-link:hover {
        color: #ffffff;
    }

    .hc-shell__navbar {
        background: #ffffff;
        border-bottom: 1px solid #e5e7eb;
    }

    .hc-shell__navbar-inner {
        min-height: 86px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1.5rem;
    }

    .hc-shell__brand {
        display: inline-flex;
        align-items: center;
        gap: 0.95rem;
        text-decoration: none;
        color: #111827;
        min-width: 0;
        flex-shrink: 0;
    }

    .hc-shell__brand:hover {
        color: #111827;
    }

    .hc-shell__brand-mark {
        width: 60px;
        height: 60px;
        border-radius: 18px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #111111 0%, #2d3748 100%);
        color: #ffffff;
        font-weight: 800;
        font-size: 1.05rem;
        letter-spacing: 0.08em;
        box-shadow: 0 10px 24px rgba(0, 0, 0, 0.14);
