@using System.Net.Http.Headers
@using System.Text.Json
@implements IDisposable
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject HttpClient Http

<div class="hc-nav">
    <button type="button" class="hc-nav__toggle" title="Abrir/cerrar menú" @onclick="ToggleNavMenu">
        Menú
    </button>

    <div class="@(collapseNavMenu ? "hc-nav__panel hc-nav__panel--collapsed" : "hc-nav__panel")">
        <nav class="hc-nav__links">
            <NavLink class="hc-nav__link" href="" Match="NavLinkMatch.All">
                Inicio
            </NavLink>

            <NavLink class="hc-nav__link" href="search">
                Buscar hoteles
            </NavLink>

            <div class="hc-nav__group hc-nav__group--info">
                <span class="hc-nav__group-label">Información del hotel</span>

                <div class="hc-nav__admin-links hc-nav__admin-links--info">
                    <NavLink class="hc-nav__admin-link" href="amenities">
                        Amenidades
                    </NavLink>

                    <NavLink class="hc-nav__admin-link" href="room-types">
                        Tipos de habitación
                    </NavLink>

                    <NavLink class="hc-nav__admin-link" href="check-in-checkout">
                        Check-in y checkout
                    </NavLink>

                    <NavLink class="hc-nav__admin-link" href="hotel-rules">
                        Reglas del hotel
                    </NavLink>

                    <NavLink class="hc-nav__admin-link" href="evacuation-info">
                        Evacuación
                    </NavLink>
                </div>
            </div>

            @if (canSeeMyReservations)
            {
                <NavLink class="hc-nav__link" href="my-reservations">
                    Mis viajes
                </NavLink>
            }

            @if (!isLoggedIn)
            {
                <NavLink class="hc-nav__link" href="login">
                    Iniciar sesión
                </NavLink>

                <NavLink class="hc-nav__link hc-nav__link--primary" href="register">
                    Inscríbete
                </NavLink>
            }

            @if (isAdmin)
            {
                <div class="hc-nav__group">
                    <span class="hc-nav__group-label">Administración</span>

                    <div class="hc-nav__admin-links">
                        <NavLink class="hc-nav__admin-link" href="admin/hotels">
                            Hoteles
                        </NavLink>

                        <NavLink class="hc-nav__admin-link" href="admin/rooms">
                            Habitaciones
                        </NavLink>

                        <NavLink class="hc-nav__admin-link" href="admin/inventories">
                            Inventario
                        </NavLink>

                        <NavLink class="hc-nav__admin-link" href="admin/reservations">
                            Reservaciones
                        </NavLink>

                        <NavLink class="hc-nav__admin-link" href="admin/users">
                            Usuarios
                        </NavLink>

                        <NavLink class="hc-nav__admin-link" href="admin/analytics">
                            Analytics
                        </NavLink>
                    </div>
                </div>
            }

            @if (isLoggedIn)
            {
                <button type="button" class="hc-nav__link hc-nav__link--button" @onclick="Logout">
                    Cerrar sesión
                </button>
            }
        </nav>
    </div>
</div>

<style>
    .hc-nav {
        width: 100%;
        position: relative;
    }

    .hc-nav__toggle {
        display: none;
        border: 1px solid #d1d5db;
        background: #ffffff;
        color: #111827;
        border-radius: 12px;
        min-height: 42px;
        padding: 0.65rem 0.95rem;
        font-weight: 700;
    }

    .hc-nav__panel {
        width: 100%;
    }

    .hc-nav__links {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        flex-wrap: wrap;
        gap: 0.55rem;
    }

    .hc-nav__link,
    .hc-nav__link--button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 42px;
        padding: 0.72rem 0.95rem;
        border-radius: 999px;
        text-decoration: none;
        border: 1px solid transparent;
        background: transparent;
        color: #111827;
        font-weight: 600;
        transition: all 0.18s ease;
        white-space: nowrap;
    }

    .hc-nav__link:hover,
    .hc-nav__link--button:hover {
        background: #f3f4f6;
        color: #111827;
        border-color: #e5e7eb;
    }

    .hc-nav__link.active {
        background: #111111;
        color: #ffffff;
        border-color: #111111;
        box-shadow: 0 10px 24px rgba(17, 17, 17, 0.16);
    }

    .hc-nav__link--primary {
        background: #111111;
        color: #ffffff;
        border-color: #111111;
    }

    .hc-nav__link--primary:hover {
        background: #000000;
        color: #ffffff;
        border-color: #000000;
    }

    .hc-nav__link--button {
        cursor: pointer;
    }

    .hc-nav__group {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        margin-left: 0.25rem;
        padding-left: 0.75rem;
        border-left: 1px solid #e5e7eb;
        flex-wrap: wrap;
    }

    .hc-nav__group-label {
        font-size: 0.78rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #6b7280;
    }

    .hc-nav__admin-links {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.45rem;
    }

    .hc-nav__admin-link {
        display: inline-flex;
        align-items: center;
        min-height: 36px;
        padding: 0.48rem 0.8rem;
        border-radius: 999px;
        text-decoration: none;
        background: #f9fafb;
        color: #374151;
        border: 1px solid #e5e7eb;
        font-size: 0.9rem;
        font-weight: 600;
        transition: all 0.18s ease;
    }

    .hc-nav__admin-link:hover {
        background: #f3f4f6;
        color: #111827;
        border-color: #d1d5db;
    }

    .hc-nav__admin-link.active {
        background: #e5e7eb;
        color: #111827;
        border-color: #d1d5db;
    }

    .hc-nav__group--info {
        margin-left: 0;
        padding-left: 0;
        border-left: none;
    }

    .hc-nav__admin-links--info {
        gap: 0.4rem;
    }

    @@media (max-width: 991.98px) {
        .hc-nav__toggle {
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .hc-nav__panel {
            position: absolute;
            top: calc(100% + 0.75rem);
            right: 0;
            width: min(100%, 420px);
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 20px;
            box-shadow: 0 22px 50px rgba(15, 23, 42, 0.14);
            padding: 0.9rem;
        }

        .hc-nav__panel--collapsed {
            display: none;
        }

        .hc-nav__links {
            justify-content: flex-start;
            align-items: stretch;
            flex-direction: column;
            gap: 0.45rem;
        }

        .hc-nav__link,
        .hc-nav__link--button,
        .hc-nav__admin-link {
            width: 100%;
            justify-content: flex-start;
            border-radius: 14px;
        }

        .hc-nav__group {
            display: flex;
            flex-direction: column;
            align-items: stretch;
            gap: 0.55rem;
            margin-left: 0;
            padding-left: 0;
            border-left: none;
            border-top: 1px solid #e5e7eb;
            padding-top: 0.8rem;
            margin-top: 0.35rem;
        }

        .hc-nav__admin-links {
            flex-direction: column;
            align-items: stretch;
        }
    }

    @@media (min-width: 992px) {
        .hc-nav__panel--collapsed {
            display: block;
        }
    }
</style>

@code {
    private bool collapseNavMenu = true;
    private bool isLoggedIn;
    private bool isAdmin;
    private bool isRegistered;
    private bool isWebService;
    private bool canSeeMyReservations;

    protected override async Task OnInitializedAsync()
    {
        Nav.LocationChanged += OnLocationChanged;
        await RefreshAuthState();
    }

    private async void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        await RefreshAuthState();

        if (collapseNavMenu == false)
            collapseNavMenu = true;

        await InvokeAsync(StateHasChanged);
    }

    private async Task RefreshAuthState()
    {
        var token = await JS.InvokeAsync<string>("auth.getToken");

        isLoggedIn = !string.IsNullOrWhiteSpace(token);
        isAdmin = false;
        isRegistered = false;
        isWebService = false;
        canSeeMyReservations = false;

        if (!isLoggedIn)
            return;

        try
        {
            var roles = GetRolesFromJwt(token);

            isAdmin = roles.Any(r => string.Equals(r, "ADMIN", StringComparison.OrdinalIgnoreCase));
            isRegistered = roles.Any(r => string.Equals(r, "REGISTERED", StringComparison.OrdinalIgnoreCase));
            isWebService = roles.Any(r => string.Equals(r, "WEBSERVICE", StringComparison.OrdinalIgnoreCase));

            canSeeMyReservations = isAdmin || isRegistered;
        }
        catch
        {
            isLoggedIn = false;
            isAdmin = false;
            isRegistered = false;
            isWebService = false;
            canSeeMyReservations = false;
        }
    }

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private async Task Logout()
    {
        await JS.InvokeVoidAsync("auth.clearToken");
        Http.DefaultRequestHeaders.Authorization = null;
        isLoggedIn = false;
        isAdmin = false;
        isRegistered = false;
        isWebService = false;
        canSeeMyReservations = false;
        collapseNavMenu = true;
        Nav.NavigateTo("/login");
    }

    private static List<string> GetRolesFromJwt(string jwt)
    {
        var parts = jwt.Split('.');
        if (parts.Length < 2)
            return new List<string>();

        var payload = parts[1];
        payload = payload.Replace('-', '+').Replace('_', '/');

        switch (payload.Length % 4)
        {
            case 2:
                payload += "==";
                break;
            case 3:
                payload += "=";
                break;
        }

        var jsonBytes = Convert.FromBase64String(payload);
        using var doc = JsonDocument.Parse(jsonBytes);

        var roles = new List<string>();
        var root = doc.RootElement;

        AddRolesFromClaim(root, "role", roles);
        AddRolesFromClaim(root, "roles", roles);
        AddRolesFromClaim(root, "http://schemas.microsoft.com/ws/2008/06/identity/claims/role", roles);

        return roles;
    }

    private static void AddRolesFromClaim(JsonElement root, string claimName, List<string> roles)
    {
        if (!root.TryGetProperty(claimName, out var claim))
            return;

        if (claim.ValueKind == JsonValueKind.String)
        {
            var value = claim.GetString();
            if (!string.IsNullOrWhiteSpace(value))
                roles.Add(value);
        }
        else if (claim.ValueKind == JsonValueKind.Array)
        {
            foreach (var item in claim.EnumerateArray())
            {
                if (item.ValueKind == JsonValueKind.String)
                {
                    var value = item.GetString();
                    if (!string.IsNullOrWhiteSpace(value))
                        roles.Add(value);
                }
            }
        }
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }
}